<Page x:Class="UnoAcpClient.Presentation.Views.Chat.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UnoAcpClient.Presentation.Views.Chat"
    xmlns:vm="using:UnoAcpClient.Presentation.ViewModels.Chat"
    xmlns:converters="using:UnoAcpClient.Presentation.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
   <Page.Resources>
   <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
   <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
   <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
   <converters:PlanStatusToColorConverter x:Key="PlanStatusToColorConverter"/>
   <converters:TimeFormatConverter x:Key="TimeFormatConverter"/>
   </Page.Resources>
   <Grid RowDefinitions="Auto,Auto,*,Auto">
   <!-- 传输配置面板 (Row 0) -->
   <Border Grid.Row="0"
           Background="{ThemeResource CardBackgroundFillColorDefault}"
           BorderBrush="{ThemeResource CardBorderBrush}"
           BorderThickness="0,0,0,1"
           Padding="16"
           Visibility="{x:Bind ViewModel.ShowTransportConfigPanel, Converter={StaticResource BoolToVisibilityConverter}}">
    <StackPanel Spacing="12">
     <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="连接配置" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
      <Button Content="隐藏" Command="{x:Bind ViewModel.ToggleTransportConfigPanelCommand}" FontSize="12"/>
     </StackPanel>

     <!-- 传输类型选择 -->
     <StackPanel Orientation="Horizontal" Spacing="16">
      <RadioButton Content="Stdio (本地)"
                   IsChecked="{x:Bind ViewModel.TransportConfig.IsStdio, Mode=OneWay}"
                   GroupName="TransportType"
                   CommandParameter="Stdio"
                   Click="OnTransportTypeChanged"/>
      <RadioButton Content="WebSocket (远程)"
                   IsChecked="{x:Bind ViewModel.TransportConfig.IsWebSocket, Mode=OneWay}"
                   GroupName="TransportType"
                   CommandParameter="WebSocket"
                   Click="OnTransportTypeChanged"/>
      <RadioButton Content="HTTP SSE (远程)"
                   IsChecked="{x:Bind ViewModel.TransportConfig.IsHttpSse, Mode=OneWay}"
                   GroupName="TransportType"
                   CommandParameter="HttpSse"
                   Click="OnTransportTypeChanged"/>
     </StackPanel>

     <!-- Stdio 配置 -->
     <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.TransportConfig.IsStdio, Converter={StaticResource BoolToVisibilityConverter}}">
      <StackPanel Orientation="Horizontal" Spacing="8">
       <TextBlock Text="命令:" Width="60" VerticalAlignment="Center"/>
       <TextBox Text="{x:Bind ViewModel.TransportConfig.StdioCommand, Mode=TwoWay}"
                PlaceholderText="例如：agent-command"
                MinWidth="300"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal" Spacing="8">
       <TextBlock Text="参数:" Width="60" VerticalAlignment="Center"/>
       <TextBox Text="{x:Bind ViewModel.TransportConfig.StdioArgs, Mode=TwoWay}"
                PlaceholderText="例如：--port 8080"/>
      </StackPanel>
     </StackPanel>

     <!-- 远程配置 (WebSocket/HTTP SSE) -->
     <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.TransportConfig.IsWebSocket, Converter={StaticResource BoolToVisibilityConverter}}">
      <StackPanel Orientation="Horizontal" Spacing="8">
       <TextBlock Text="URL:" Width="60" VerticalAlignment="Center"/>
       <TextBox Text="{x:Bind ViewModel.TransportConfig.RemoteUrl, Mode=TwoWay}"
                PlaceholderText="例如：ws://localhost:8080 或 wss://example.com"
                MinWidth="400"/>
      </StackPanel>
     </StackPanel>

     <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.TransportConfig.IsHttpSse, Converter={StaticResource BoolToVisibilityConverter}}">
      <StackPanel Orientation="Horizontal" Spacing="8">
       <TextBlock Text="URL:" Width="60" VerticalAlignment="Center"/>
       <TextBox Text="{x:Bind ViewModel.TransportConfig.RemoteUrl, Mode=TwoWay}"
                PlaceholderText="例如：http://localhost:8080 或 https://example.com"
                MinWidth="400"/>
      </StackPanel>
     </StackPanel>

     <!-- 错误信息 -->
     <TextBlock Text="{x:Bind ViewModel.ConnectionErrorMessage}"
                Foreground="Red"
                Visibility="{x:Bind ViewModel.ConnectionErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>

     <!-- 应用配置按钮 -->
     <Button Content="应用配置"
             Command="{x:Bind ViewModel.ApplyTransportConfigCommand}"
             IsEnabled="{x:Bind ViewModel.IsConnecting, Converter={StaticResource InverseBooleanConverter}}"
             HorizontalAlignment="Left"
             Padding="16,8"/>
    </StackPanel>
   </Border>

   <!-- 顶部状态栏 (Row 1) -->
   <StackPanel Grid.Row="1" Padding="16" Orientation="Vertical" Spacing="8">
            <!-- 连接状态和 Agent 信息 -->
            <StackPanel Orientation="Horizontal" Spacing="16">
                <Ellipse Width="12" Height="12" Fill="Green"/>
                <TextBlock Text="已连接到 Agent:" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.AgentName, Mode=OneWay}" VerticalAlignment="Center" FontWeight="Bold"/>
                <TextBlock Text=" (" VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.AgentVersion, Mode=OneWay}" VerticalAlignment="Center"/>
                <TextBlock Text=")" VerticalAlignment="Center"/>
                <Button Content="断开连接"
                    Command="{x:Bind ViewModel.DisconnectCommand}"
                    HorizontalAlignment="Right"
                    Margin="120,0,0,0"/>
            </StackPanel>

            <!-- 会话模式选择 -->
            <StackPanel Orientation="Horizontal" Spacing="8"
                Visibility="{x:Bind ViewModel.IsSessionActive, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="当前模式:" VerticalAlignment="Center" Width="60"/>
                <ComboBox ItemsSource="{x:Bind ViewModel.AvailableModes, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}"
                    Width="200"
                    DisplayMemberPath="ModeName"
                    PlaceholderText="选择模式..."/>
                <Button Content="应用模式"
                    Command="{x:Bind ViewModel.SetModeCommand}"
                    CommandParameter="{x:Bind ViewModel.SelectedMode, Mode=OneWay}"/>
            </StackPanel>

            <!-- 配置选项面板 -->
            <StackPanel Spacing="8"
                Visibility="{x:Bind ViewModel.ShowConfigOptionsPanel, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="配置选项" FontWeight="Bold" FontSize="14"/>
                <ItemsControl ItemsSource="{x:Bind ViewModel.ConfigOptions, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ConfigOptionViewModel">
                            <StackPanel Margin="0,4" Spacing="4">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind Description}" FontSize="11" Foreground="Gray"
                                    Visibility="{x:Bind Description, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- 布尔类型 - ToggleSwitch -->
                                <ToggleSwitch Header="{x:Bind Name}"
                                    IsOn="{x:Bind BoolValue, Mode=TwoWay}"
                                    Visibility="{x:Bind IsBoolType, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- 选择类型 - ComboBox -->
                                <ComboBox ItemsSource="{x:Bind Options, Mode=OneWay}"
                                    SelectedItem="{x:Bind SelectedOption, Mode=TwoWay}"
                                    DisplayMemberPath="Name"
                                    Width="200"
                                    Visibility="{x:Bind IsSelectType, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- 数字类型 - NumberBox -->
                                <NumberBox Value="{x:Bind NumberValue, Mode=TwoWay}"
                                    Header="{x:Bind Name}"
                                    Width="200"
                                    Visibility="{x:Bind IsNumberType, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <!-- 字符串类型 - TextBox -->
                                <TextBox Text="{x:Bind TextValue, Mode=TwoWay}"
                                    Header="{x:Bind Name}"
                                    PlaceholderText="输入值..."
                                    Width="300"
                                    Visibility="{x:Bind IsStringType, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- 错误信息 -->
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                Foreground="Red"
                Visibility="{x:Bind ViewModel.ErrorMessage, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>

        <!-- 消息历史 -->
        <ScrollViewer Grid.Row="1" Padding="16" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{x:Bind ViewModel.MessageHistory, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ChatMessageViewModel">
                        <StackPanel Margin="4" MaxWidth="400">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefault}"
                                BorderBrush="{ThemeResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Title}"
                                        FontWeight="Bold"
                                        FontSize="12"
                                        Visibility="{x:Bind Title, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Margin="0,0,0,8"/>

                                    <!-- 文本内容 -->
                                    <TextBlock Text="{x:Bind TextContent}"
                                        TextWrapping="Wrap"
                                        Visibility="{x:Bind HasTextContent, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                    <!-- 工具调用信息 -->
                                    <StackPanel Visibility="{x:Bind HasToolCall, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="工具:" FontWeight="Bold"/>
                                            <TextBlock Text="{x:Bind ToolCallId}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <TextBlock Text="类型:" FontWeight="Bold"/>
                                            <TextBlock Text="{x:Bind ToolCallKind}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <TextBlock Text="状态:" FontWeight="Bold"/>
                                            <TextBlock Text="{x:Bind ToolCallStatus}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 计划条目信息 -->
                                    <StackPanel Visibility="{x:Bind HasPlanEntry, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="{x:Bind PlanEntry.StatusDisplayName}" Foreground="Blue"/>
                                    <TextBlock Text="{x:Bind PlanEntry.Content}" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- 资源内容块 -->
                                    <Border Background="LightGray"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,4,0,0"
                                    Visibility="{x:Bind HasResourceContent, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind ResourceViewModel.DisplayTitle}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{x:Bind ResourceViewModel.Uri}" FontSize="9" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind ResourceViewModel.Content}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="10" MaxHeight="150"/>
                                    </StackPanel>
                                    </Border>

                                    <!-- 资源链接 -->
                                    <Border Background="LightYellow"
                                    CornerRadius="4"
                                    Padding="8"
                                    Margin="0,4,0,0"
                                    Visibility="{x:Bind HasResourceLink, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind ResourceViewModel.DisplayTitle}" FontWeight="Bold" FontSize="12"/>
                                    <TextBlock Text="{x:Bind ResourceViewModel.Uri}" FontSize="9" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                    <HyperlinkButton Content="{x:Bind ResourceViewModel.LinkText}" NavigateUri="{x:Bind ResourceViewModel.Uri}"/>
                                    </StackPanel>
                                    </Border>

                                    <TextBlock Text="{x:Bind Timestamp, Converter={StaticResource TimeFormatConverter}}" FontSize="10" Opacity="0.6" Margin="0,8,0,0" HorizontalAlignment="Right"/>

                                    <TextBlock Text="{x:Bind Timestamp, Converter={StaticResource TimeFormatConverter}}"
                                        FontSize="10"
                                        Opacity="0.6"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 计划面板 -->
        <Border Grid.Row="2"
            Background="{ThemeResource CardBackgroundFillColorDefault}"
            BorderBrush="{ThemeResource CardBorderBrush}"
            BorderThickness="0,1,0,0"
            Padding="16"
            Visibility="{x:Bind ViewModel.ShowPlanPanel, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel Spacing="8">
                <TextBlock Text="Agent 计划" FontWeight="Bold" FontSize="16"/>
                <ItemsControl ItemsSource="{x:Bind ViewModel.CurrentPlan, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PlanEntryViewModel">
                            <StackPanel Margin="0,4" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind StatusDisplayName}"
                                        Foreground="{x:Bind Status, Converter={StaticResource PlanStatusToColorConverter}}"/>
                                    <TextBlock Text="{x:Bind PriorityDisplayName}" FontStyle="Italic"/>
                                    <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- 消息输入 -->
        <StackPanel Grid.Row="2"
            Padding="16"
            Orientation="Vertical"
            Spacing="8"
            Visibility="{x:Bind ViewModel.IsSessionActive, Converter={StaticResource BoolToVisibilityConverter}}"
            Margin="0,16,0,0">
            <TextBox PlaceholderText="输入消息..."
                Text="{x:Bind ViewModel.CurrentPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                TextWrapping="Wrap"
                AcceptsReturn="True"
                Height="80"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="发送" Command="{x:Bind ViewModel.SendPromptCommand}"/>
                <Button Content="取消会话" Command="{x:Bind ViewModel.CancelSessionCommand}"/>
                <Button Content="清除历史"
                    Command="{x:Bind ViewModel.ClearHistoryCommand}"
                    Margin="120,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- 初始化和连接按钮 -->
        <StackPanel Grid.Row="2"
            Padding="16"
            Orientation="Horizontal"
            Spacing="8"
            Visibility="{x:Bind ViewModel.IsSessionActive, Converter={StaticResource InverseBoolConverter}}"
            Margin="0,16,0,0">
            <Button Content="创建新会话"
                Command="{x:Bind ViewModel.CreateNewSessionCommand}"
                IsEnabled="{x:Bind ViewModel.IsConnecting, Converter={StaticResource InverseBooleanConverter}}"/>
        </StackPanel>
    </Grid>
</Page>
