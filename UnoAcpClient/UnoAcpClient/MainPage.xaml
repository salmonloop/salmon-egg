<Page
    x:Class="UnoAcpClient.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:UnoAcpClient.Presentation.ViewModels"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <!-- 极简导航项样式 (Nav Rail) -->
        <Style x:Key="NavRailItemStyle" TargetType="ListViewItem">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="LayoutRoot" Background="{TemplateBinding Background}" Height="64">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="SelectionIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPanel.Foreground" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- 选中状态指示条 -->
                            <Rectangle x:Name="SelectionIndicator"
                                       Width="3" Height="24"
                                       Fill="{ThemeResource AccentBrush}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <ContentPresenter x:Name="ContentPanel"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 二级导航项样式 (Sub Menu) -->
        <Style x:Key="SubMenuItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                            <Setter Target="OuterBorder.BorderBrush" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="SubMenuContentPresenter.Foreground" Value="{ThemeResource AccentBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="SubMenuContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 第一列：极简一级导航 (Nav Rail) -->
        <!-- Background 使用 Transparent 配合 App.xaml 中的 Mica 支持，BorderBrush 使用标准分隔线 -->
        <Grid Grid.Column="0"
              Width="72"
              Background="Transparent"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 主业务导航 (顶部) -->
            <ListView x:Name="MainRailNav" Grid.Row="0"
                      SelectionMode="Single"
                      Padding="0,12,0,0"
                      ItemContainerStyle="{StaticResource NavRailItemStyle}"
                      SelectionChanged="OnMainRailNavSelectionChanged">
                <ListViewItem x:Name="ChatNavItem">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE8BD;" FontSize="20"/>
                        <TextBlock Text="对话" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ListViewItem>
            </ListView>

            <!-- 系统设置导航 (底部) -->
            <ListView x:Name="BottomRailNav" Grid.Row="1"
                      Margin="0,0,0,16"
                      SelectionMode="Single"
                      ItemContainerStyle="{StaticResource NavRailItemStyle}"
                      SelectionChanged="OnBottomRailNavSelectionChanged">
                <ListViewItem x:Name="SettingsNavItem">
                    <StackPanel Spacing="4">
                        <FontIcon Glyph="&#xE713;" FontSize="20"/>
                        <TextBlock Text="设置" FontSize="10" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ListViewItem>
            </ListView>
        </Grid>

        <!-- 第二列：二级导航栏 (名为“设置”) -->
        <Grid x:Name="SubMenuColumn" Grid.Column="1"
              Width="200"
              Background="Transparent"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,1,0"
              Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="设置" FontSize="16" FontWeight="SemiBold" Margin="20,24,16,16" VerticalAlignment="Center"/>

            <ListView x:Name="SubMenuList"
                      Grid.Row="1"
                      SelectionMode="Single"
                      ItemContainerStyle="{StaticResource SubMenuItemStyle}"
                      SelectionChanged="OnSubMenuSelectionChanged">
                <ListViewItem Content="常规" />
                <ListViewItem Content="外观" />
                <ListViewItem Content="连接状态" />
            </ListView>
        </Grid>

        <!-- 第三列：主内容区 -->
        <Frame x:Name="ContentFrame"
               Grid.Column="2"
               Background="Transparent" />
    </Grid>
</Page>
