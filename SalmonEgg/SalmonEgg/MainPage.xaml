<Page
    x:Class="SalmonEgg.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels"
    xmlns:nav="using:SalmonEgg.Presentation.ViewModels.Navigation"
    xmlns:navModels="using:SalmonEgg.Presentation.Models.Navigation"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:searchModels="using:SalmonEgg.Presentation.Models.Search"
    xmlns:navViews="using:SalmonEgg.Presentation.Views.Navigation"
    xmlns:chatViews="using:SalmonEgg.Presentation.Views.Chat"
    xmlns:navUi="using:SalmonEgg.Presentation.Navigation"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:chatVm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:taskOverview="using:SalmonEgg.Presentation.Core.ViewModels.Chat.TaskOverview"
    xmlns:behaviors="using:SalmonEgg.Presentation.Behaviors"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False"
    KeyboardAcceleratorPlacementMode="Hidden">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:PlanStatusToColorConverter x:Key="PlanStatusToColorConverter" />
        <converters:PlanStatusLabelConverter x:Key="PlanStatusLabelConverter" />
        <converters:PlanPriorityLabelConverter x:Key="PlanPriorityLabelConverter" />
        <converters:TaskOverviewChangeKindLabelConverter x:Key="TaskOverviewChangeKindLabelConverter" />
        <converters:EnumToBooleanConverter x:Key="EnumToBoolConverter" />
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />
        <converters:LayoutPaddingConverter x:Key="PaddingConverter" />
        <converters:GridLengthConverter x:Key="GridLengthConverter" />

        <x:Double x:Key="NavCompactPaneLength">72</x:Double>
        <x:Double x:Key="NavOpenPaneLength">300</x:Double>

        <!-- Navigation section header sizing (keep consistent + tweakable in one place) -->
        <x:Double x:Key="NavSectionHeaderMinHeight">32</x:Double>
        <x:Double x:Key="NavSectionHeaderActionButtonSize">24</x:Double>
        <x:Double x:Key="NavProjectActionButtonSize">24</x:Double>
        <x:Double x:Key="SearchBoxMinWidthWide">220</x:Double>
        <x:Double x:Key="SearchBoxMaxWidthWide">360</x:Double>
        <x:Double x:Key="SearchBoxMinWidthMedium">180</x:Double>
        <x:Double x:Key="SearchBoxMaxWidthMedium">300</x:Double>

        <DataTemplate x:Key="StartNavTemplate" x:DataType="nav:StartNavItemViewModel">
            <NavigationViewItem AutomationProperties.AutomationId="{x:Bind navUi:MainNavigationAutomationIds.StartItem()}"
                                Tag="{x:Bind navModels:NavItemTag.Start}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </NavigationViewItem.Icon>
                <NavigationViewItem.Content>
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               VerticalAlignment="Center" />
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </DataTemplate>
        
        <DataTemplate x:Key="DiscoverSessionsNavTemplate" x:DataType="nav:DiscoverSessionsNavItemViewModel">
            <NavigationViewItem AutomationProperties.AutomationId="{x:Bind navUi:MainNavigationAutomationIds.DiscoverSessionsItem()}"
                                Tag="{x:Bind navModels:NavItemTag.DiscoverSessions}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Find" />
                </NavigationViewItem.Icon>
                <NavigationViewItem.Content>
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               VerticalAlignment="Center" />
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="SettingsNavTemplate" x:DataType="nav:SettingsNavItemViewModel">
            <NavigationViewItem AutomationProperties.AutomationId="{x:Bind navUi:MainNavigationAutomationIds.SettingsItem()}"
                                Tag="{x:Bind navModels:NavItemTag.Settings}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Setting" />
                </NavigationViewItem.Icon>
                <NavigationViewItem.Content>
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               VerticalAlignment="Center" />
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="SessionsLabelTemplate" x:DataType="nav:SessionsLabelNavItemViewModel">
            <NavigationViewItemHeader Content="{x:Bind Title, Mode=OneWay}"
                                      AutomationProperties.AutomationId="{x:Bind navUi:MainNavigationAutomationIds.SessionsLabel()}" />
        </DataTemplate>

        <DataTemplate x:Key="AddProjectTemplate" x:DataType="nav:AddProjectNavItemViewModel">
            <NavigationViewItem SelectsOnInvoked="False"
                                IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                                AutomationProperties.AutomationId="{x:Bind navUi:MainNavigationAutomationIds.AddProject()}"
                                Tag="{x:Bind navModels:NavItemTag.AddProject}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Add" />
                </NavigationViewItem.Icon>
                <NavigationViewItem.Content>
                    <TextBlock x:Uid="NavAddProjectLabel"
                               TextTrimming="CharacterEllipsis"
                               MaxLines="1"
                               VerticalAlignment="Center" />
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="ProjectNavTemplate" x:DataType="nav:ProjectNavItemViewModel">
            <NavigationViewItem MenuItemsSource="{x:Bind Children, Mode=OneWay}"
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                SelectsOnInvoked="False"
                                HorizontalContentAlignment="Stretch"
                                AutomationProperties.AutomationId="{x:Bind navUi:MainNavigationAutomationIds.ProjectItem(ProjectId)}"
                                Tag="{x:Bind navModels:NavItemTag.Project(ProjectId)}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Folder" />
                </NavigationViewItem.Icon>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="*">
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   VerticalAlignment="Center" />
                    </Grid>
                </NavigationViewItem.Content>

                <NavigationViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="ProjectNavNewSessionItem"
                                        Command="{x:Bind CreateSessionCommand}" />
                    </MenuFlyout>
                </NavigationViewItem.ContextFlyout>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="SessionNavTemplate" x:DataType="nav:SessionNavItemViewModel">
            <NavigationViewItem SelectsOnInvoked="True"
                                AutomationProperties.AutomationId="{x:Bind navUi:MainNavigationAutomationIds.SessionItem(SessionId)}"
                                AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}"
                                Tag="{x:Bind navModels:NavItemTag.Session(SessionId)}"
                                ContentTransitions="{x:Bind models:UiMotionController.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Comment" />
                </NavigationViewItem.Icon>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                          ColumnSpacing="8">
                        <ProgressRing Width="14"
                                      Height="14"
                                      IsActive="{x:Bind IsPlaceholder, Mode=OneWay}"
                                      Visibility="{x:Bind IsPlaceholder, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Title, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"/>

                        <Ellipse Grid.Column="2"
                                 Width="8"
                                 Height="8"
                                 Fill="{ThemeResource AccentBrush}"
                                 AutomationProperties.AutomationId="{x:Bind navUi:MainNavigationAutomationIds.SessionUnread(SessionId)}"
                                 VerticalAlignment="Center"
                                 Visibility="{x:Bind HasUnreadAttention, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind RelativeTimeText, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Opacity="0.55"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </NavigationViewItem.Content>

                <NavigationViewItem.ContextFlyout>
                    <MenuFlyout Closed="OnSessionNavFlyoutClosed">
                        <MenuFlyoutItem x:Uid="SessionNavArchiveItem"
                                        AutomationProperties.AutomationId="MainNav.Session.Context.Archive"
                                        Click="OnSessionArchiveMenuItemClick"
                                        CommandParameter="{x:Bind}"
                                        IsEnabled="{x:Bind IsPlaceholder, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
                        <MenuFlyoutItem x:Uid="SessionNavMoveItem"
                                        AutomationProperties.AutomationId="MainNav.Session.Context.Move"
                                        Click="OnSessionMoveMenuItemClick"
                                        CommandParameter="{x:Bind}" />
                        <MenuFlyoutItem x:Uid="SessionNavCopySessionIdItem"
                                        AutomationProperties.AutomationId="MainNav.Session.Context.CopySessionId"
                                        Command="{x:Bind CopySessionIdCommand}" />
                    </MenuFlyout>
                </NavigationViewItem.ContextFlyout>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="MoreNavTemplate" x:DataType="nav:MoreSessionsNavItemViewModel">
            <NavigationViewItem Content="{x:Bind Title, Mode=OneWay}"
                                SelectsOnInvoked="False"
                                AutomationProperties.AutomationId="{x:Bind navUi:MainNavigationAutomationIds.MoreItem(ProjectId)}"
                                Tag="{x:Bind navModels:NavItemTag.More(ProjectId)}"
                                ContentTransitions="{x:Bind models:UiMotionController.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="More" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </DataTemplate>

        <navViews:MainNavItemTemplateSelector x:Key="MainNavItemTemplateSelector"
                                              StartTemplate="{StaticResource StartNavTemplate}"
                                              DiscoverSessionsTemplate="{StaticResource DiscoverSessionsNavTemplate}"
                                              SettingsTemplate="{StaticResource SettingsNavTemplate}"
                                              LabelTemplate="{StaticResource SessionsLabelTemplate}"
                                              AddProjectTemplate="{StaticResource AddProjectTemplate}"
                                              ProjectTemplate="{StaticResource ProjectNavTemplate}"
                                              SessionTemplate="{StaticResource SessionNavTemplate}"
                                              MoreTemplate="{StaticResource MoreNavTemplate}" />

        <Style x:Key="SubMenuResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Right"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightPanelResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Left"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid x:Name="LayoutRoot"
          XYFocusKeyboardNavigation="Enabled">
        <VisualStateManager.VisualStateGroups>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="Transparent"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Loaded="OnAppTitleBarLoaded"
                SizeChanged="OnAppTitleBarSizeChanged"
                Height="{x:Bind LayoutVM.TitleBarHeight, Mode=OneWay}">
            <Grid x:Name="AppTitleBarLayoutRoot">
                <Grid x:Name="TitleBarDragRegion" Background="Transparent" />
                <Grid x:Name="AppTitleBarContent"
                      Padding="{x:Bind LayoutVM.TitleBarPadding, Mode=OneWay, Converter={StaticResource PaddingConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="TitleBarLeftButtons"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="4"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                        <Button x:Name="TitleBarBackButton"
                                x:Uid="TitleBarBackButton"
                                Style="{StaticResource TitleBarCommandButtonStyle}"
                                XYFocusDown="{x:Bind MainNavView, Mode=OneWay}"
                                Content="Icon"
                                ContentTemplate="{StaticResource TitleBarBackIconTemplate}"
                                Click="OnTitleBarBackClick">
                        </Button>
                        <Button x:Name="TitleBarToggleLeftNavButton"
                                x:Uid="TitleBarToggleLeftNavButton"
                                Style="{StaticResource TitleBarCommandButtonStyle}"
                                AutomationProperties.AutomationId="TitleBar.ToggleSidebar"
                                XYFocusDown="{x:Bind MainNavView, Mode=OneWay}"
                                Content="Icon"
                                ContentTemplate="{StaticResource TitleBarToggleLeftNavIconTemplate}"
                                Click="OnToggleLeftNavClick">
                        </Button>
                        <Button x:Name="TitleBarMiniWindowButton"
                                x:Uid="TitleBarMiniWindowButton"
                                Style="{StaticResource TitleBarCommandButtonStyle}"
                                AutomationProperties.AutomationId="TitleBar.OpenMiniWindow"
                                XYFocusDown="{x:Bind MainNavView, Mode=OneWay}"
                                Visibility="{x:Bind Preferences.IsMiniWindowSupported, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                Content="Icon"
                                ContentTemplate="{StaticResource TitleBarOpenMiniWindowIconTemplate}"
                                Command="{x:Bind ChatVM.OpenMiniWindowCommand}">
                        </Button>
                    </StackPanel>

                    <AutoSuggestBox x:Name="TopSearchBox"
                                    x:Uid="TopSearchBox"
                                    Grid.Column="1"
                                    QueryIcon="Find"
                                    Visibility="{x:Bind LayoutVM.SearchBoxVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                    MinWidth="{x:Bind LayoutVM.SearchBoxMinWidth, Mode=OneWay}"
                                    MaxWidth="{x:Bind LayoutVM.SearchBoxMaxWidth, Mode=OneWay}"
                                    Text="{x:Bind SearchVM.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    ItemsSource="{x:Bind SearchVM.SuggestionEntries, Mode=OneWay}"
                                    SuggestionChosen="OnSearchSuggestionChosen"
                                    TextChanged="OnSearchTextChanged"
                                    QuerySubmitted="OnSearchQuerySubmitted"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                        <AutoSuggestBox.ItemTemplate>
                            <DataTemplate x:DataType="searchModels:SearchSuggestionEntry">
                                <Grid Padding="12,8"
                                      AutomationProperties.AutomationId="{x:Bind AutomationId}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0"
                                              Glyph="{x:Bind IconGlyph}"
                                              Margin="0,0,12,0"
                                              FontSize="16"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                              Visibility="{x:Bind IconGlyph, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <StackPanel Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                Spacing="2">
                                        <TextBlock Text="{x:Bind Title}"
                                                   FontSize="14"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind SecondaryText}"
                                                   FontSize="12"
                                                   Opacity="0.7"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{x:Bind SecondaryText, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </AutoSuggestBox.ItemTemplate>
                    </AutoSuggestBox>

                    <StackPanel x:Name="TitleBarRightButtons"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center"
                                Margin="0">
                        <ToggleButton x:Name="BottomPanelButton"
                                       x:Uid="BottomPanelButton"
                                       AutomationProperties.AutomationId="TitleBar.BottomPanel"
                                       Tag="BottomPanel"
                                       Style="{StaticResource TitleBarToggleButtonStyle}"
                                       XYFocusDown="{x:Bind MainNavView, Mode=OneWay}"
                                       Visibility="{x:Bind LayoutVM.ShowAuxiliaryTitleBarButtons, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                       IsEnabled="{x:Bind LayoutVM.CanToggleBottomPanel, Mode=OneWay}"
                                       ToolTipService.ToolTip="{x:Bind GetBottomPanelButtonToolTip(LayoutVM.CanToggleBottomPanel), Mode=OneWay}"
                                       Content="Icon"
                                       Command="{x:Bind LayoutVM.ToggleBottomPanelCommand}"
                                       ContentTemplate="{x:Bind GetBottomPanelButtonIconTemplate(LayoutVM.BottomPanelMode), Mode=OneWay}"
                                       IsChecked="{x:Bind LayoutVM.BottomPanelMode, Mode=OneWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Dock}" />
                        <ToggleButton x:Name="TaskOverviewPanelButton"
                                      x:Uid="TaskOverviewPanelButton"
                                      AutomationProperties.AutomationId="TitleBar.TaskOverviewPanel"
                                      Tag="TaskOverview"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      XYFocusDown="{x:Bind MainNavView, Mode=OneWay}"
                                      Visibility="{x:Bind LayoutVM.ShowAuxiliaryTitleBarButtons, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                      IsEnabled="{x:Bind LayoutVM.CanToggleTaskOverviewPanel, Mode=OneWay}"
                                      ToolTipService.ToolTip="{x:Bind GetTaskOverviewPanelButtonToolTip(LayoutVM.CanToggleTaskOverviewPanel), Mode=OneWay}"
                                      Content="Icon"
                                      Command="{x:Bind LayoutVM.ToggleTaskOverviewPanelCommand}"
                                      ContentTemplate="{x:Bind GetTaskOverviewPanelButtonIconTemplate(LayoutVM.RightPanelMode), Mode=OneWay}"
                                      IsChecked="{x:Bind LayoutVM.RightPanelMode, Mode=OneWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=TaskOverview}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <NavigationView x:Name="MainNavView"
                            Background="Transparent"
                            AutomationProperties.AutomationId="MainNavView"
                            XYFocusKeyboardNavigation="Enabled"
                            XYFocusRight="{x:Bind ContentFrame, Mode=OneWay}"
                            XYFocusUp="{x:Bind TitleBarToggleLeftNavButton, Mode=OneWay}"
                            CompactPaneLength="{x:Bind LayoutVM.NavCompactPaneLength, Mode=OneWay}"
                            OpenPaneLength="{x:Bind LayoutVM.NavOpenPaneLength, Mode=OneWay}"
                            PaneDisplayMode="Auto"
                            CompactModeThresholdWidth="640"
                            ExpandedModeThresholdWidth="1000"
                            IsPaneOpen="{x:Bind LayoutVM.IsNavPaneOpen, Mode=OneWay}"
                            IsBackButtonVisible="Collapsed"
                            IsPaneToggleButtonVisible="False"
                            IsSettingsVisible="False"
                            AlwaysShowHeader="False"
                            SelectedItem="{x:Bind NavVM.ProjectedControlSelectedItem, Mode=OneWay}"
                            Padding="{x:Bind LayoutVM.NavViewPadding, Mode=OneWay, Converter={StaticResource PaddingConverter}}"
                            MenuItemsSource="{x:Bind NavVM.Items, Mode=OneWay}"
                            FooterMenuItemsSource="{x:Bind NavVM.FooterItems, Mode=OneWay}"
                            MenuItemTemplateSelector="{StaticResource MainNavItemTemplateSelector}"
                            ItemInvoked="OnMainNavItemInvoked"
                            DisplayModeChanged="OnMainNavPanePresentationChanged"
                            PaneOpened="OnMainNavPanePresentationChanged"
                            PaneClosed="OnMainNavPanePresentationChanged">
                <NavigationView.Content>
                    <SplitView x:Name="RightPanelSplitView"
                               Background="Transparent"
                               PanePlacement="Right"
                               DisplayMode="Inline"
                               IsPaneOpen="{x:Bind LayoutVM.RightPanelVisible, Mode=OneWay}"
                               OpenPaneLength="{x:Bind LayoutVM.RightPanelOpenPaneLength, Mode=OneWay}">
                        <SplitView.Content>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="{x:Bind LayoutVM.BottomPanelHeight, Mode=OneWay, Converter={StaticResource GridLengthConverter}}" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Frame x:Name="ContentFrame"
                                           Background="Transparent" />

                                    <ContentControl x:Name="ShellLoadingOverlayPresenter"
                                                    Grid.Row="0"
                                                    x:Uid="ChatViewLoadingOverlay"
                                                    AutomationProperties.AutomationId="ChatView.LoadingOverlay"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    HorizontalContentAlignment="Stretch"
                                                    VerticalContentAlignment="Stretch"
                                                    IsTabStop="False"
                                                    IsHitTestVisible="{x:Bind ShellOverlayVM.ShowsBlockingMask, Mode=OneWay}"
                                                    Visibility="{x:Bind ShellOverlayVM.ShowsPresenter, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Grid>
                                            <Border Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                                                    AutomationProperties.AutomationId="ChatView.LoadingOverlayMask"
                                                    Visibility="{x:Bind ShellOverlayVM.ShowsBlockingMask, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <controls:ChatSkeleton VerticalAlignment="Stretch"
                                                                       HorizontalAlignment="Stretch" />
                                            </Border>

                                            <Grid>
                                                <Border VerticalAlignment="Bottom"
                                                        HorizontalAlignment="Center"
                                                        Margin="0,0,0,48"
                                                        Padding="16,8"
                                                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="20"
                                                        Visibility="{x:Bind ShellOverlayVM.ShowsStatusPill, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <ProgressRing IsActive="True" Width="16" Height="16" />
                                                        <TextBlock AutomationProperties.AutomationId="ChatView.LoadingOverlayStatus"
                                                                   Text="{x:Bind ShellOverlayVM.StatusText, Mode=OneWay}"
                                                                   FontSize="12"
                                                                   FontWeight="Medium"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </ContentControl>
                                </Grid>

                                <chatViews:BottomPanelHost x:Name="BottomPanelHost"
                                                           Grid.Row="1"
                                                           x:Load="{x:Bind LayoutVM.SupportsLocalTerminal, Mode=OneWay}"
                                                           Visibility="{x:Bind LayoutVM.BottomPanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                           LocalTerminalSession="{x:Bind ChatVM.ActiveLocalTerminalSession, Mode=OneWay}" />
                            </Grid>
                        </SplitView.Content>

                        <SplitView.Pane>
                            <Grid x:Name="RightPanelPane"
                                  AutomationProperties.AutomationId="RightPanel.Root"
                                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                  BorderThickness="1,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" MinHeight="64" Padding="16,8,8,8">
                                    <StackPanel VerticalAlignment="Center"
                                                Spacing="2">
                                        <TextBlock x:Name="RightPanelTitle"
                                                   AutomationProperties.AutomationId="RightPanel.Title"
                                                   Text="{x:Bind GetRightPanelTitle(LayoutVM.RightPanelMode), Mode=OneWay}"
                                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                        <TextBlock AutomationProperties.AutomationId="RightPanel.TaskOverviewSummary"
                                                   AutomationProperties.Name="{x:Bind GetTaskOverviewSummaryAutomationName(ChatVM.TaskOverviewState), Mode=OneWay}"
                                                   Text="{x:Bind GetTaskOverviewSummaryText(ChatVM.TaskOverviewState), Mode=OneWay}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                </Grid>

                                <ScrollViewer Grid.Row="1"
                                              AutomationProperties.AutomationId="RightPanel.TaskOverviewRoot">
                                    <StackPanel Padding="16" Spacing="16">
                                        <StackPanel AutomationProperties.AutomationId="RightPanel.TaskOverview.CurrentPlan"
                                                    AutomationProperties.Name="{x:Bind GetTaskOverviewCurrentPlanAutomationName(ChatVM.TaskOverviewCurrentPlanContent, ChatVM.TaskOverviewCurrentPlanStatus, ChatVM.TaskOverviewCurrentPlanPriority), Mode=OneWay}"
                                                    Spacing="8"
                                                    Visibility="{x:Bind ChatVM.ShouldShowTaskOverviewCurrentPlan, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock x:Uid="TaskOverviewCurrentPlanLabel"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="12">
                                                <Grid ColumnDefinitions="*,Auto"
                                                      ColumnSpacing="12">
                                                    <TextBlock Text="{x:Bind ChatVM.TaskOverviewCurrentPlanContent, Mode=OneWay}"
                                                               TextWrapping="WrapWholeWords"
                                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind ChatVM.TaskOverviewCurrentPlanStatus, Mode=OneWay, Converter={StaticResource PlanStatusLabelConverter}}"
                                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock Text="{x:Bind ChatVM.TaskOverviewCurrentPlanPriority, Mode=OneWay, Converter={StaticResource PlanPriorityLabelConverter}}"
                                                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Spacing="8"
                                                    Visibility="{x:Bind ChatVM.ShouldShowTaskOverviewVisiblePlanList, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <TextBlock x:Uid="TaskOverviewPlanSectionTitle"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <ListView AutomationProperties.AutomationId="RightPanel.TaskOverview.PlanList"
                                                      ItemsSource="{x:Bind ChatVM.TaskOverviewVisiblePlanEntries, Mode=OneWay}"
                                                      SelectionMode="None">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="chatVm:PlanEntryViewModel">
                                                        <Grid Padding="0,8"
                                                              ColumnDefinitions="Auto,*,Auto"
                                                              ColumnSpacing="12">
                                                            <Ellipse Width="8"
                                                                     Height="8"
                                                                     VerticalAlignment="Center"
                                                                     Fill="{x:Bind Status, Mode=OneWay, Converter={StaticResource PlanStatusToColorConverter}}" />
                                                            <TextBlock Grid.Column="1"
                                                                       Text="{x:Bind Content, Mode=OneWay}"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center" />
                                                            <StackPanel Grid.Column="2"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{x:Bind Status, Mode=OneWay, Converter={StaticResource PlanStatusLabelConverter}}"
                                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                                           HorizontalAlignment="Right" />
                                                                <TextBlock Text="{x:Bind Priority, Mode=OneWay, Converter={StaticResource PlanPriorityLabelConverter}}"
                                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                           HorizontalAlignment="Right" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <TextBlock Text="{x:Bind GetTaskOverviewMorePlanText(ChatVM.TaskOverviewHiddenPlanCount), Mode=OneWay}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Visibility="{x:Bind ChatVM.ShouldShowTaskOverviewMorePlanItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </StackPanel>

                                        <StackPanel Spacing="8">
                                            <TextBlock x:Uid="TaskOverviewChangesSectionTitle"
                                                       Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                            <ListView AutomationProperties.AutomationId="RightPanel.TaskOverview.ChangesList"
                                                      ItemsSource="{x:Bind ChatVM.TaskOverviewVisibleChanges, Mode=OneWay}"
                                                      SelectionMode="None"
                                                      Visibility="{x:Bind ChatVM.TaskOverviewState.ShouldShowChangesList, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate x:DataType="taskOverview:TaskOverviewChangeViewModel">
                                                        <Grid Padding="0,8"
                                                              ColumnDefinitions="*,Auto"
                                                              ColumnSpacing="12">
                                                            <StackPanel VerticalAlignment="Center"
                                                                        ToolTipService.ToolTip="{x:Bind Path, Mode=OneWay}">
                                                                <TextBlock Text="{x:Bind FileName, Mode=OneWay}"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{x:Bind DirectoryPath, Mode=OneWay}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                           Style="{ThemeResource CaptionTextBlockStyle}" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{x:Bind Kind, Mode=OneWay, Converter={StaticResource TaskOverviewChangeKindLabelConverter}}"
                                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                                           HorizontalAlignment="Right" />
                                                                <TextBlock Text="{x:Bind LineSummary, Mode=OneWay}"
                                                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                           HorizontalAlignment="Right" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <TextBlock Text="{x:Bind GetTaskOverviewMoreChangesText(ChatVM.TaskOverviewHiddenChangeCount), Mode=OneWay}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       Visibility="{x:Bind ChatVM.ShouldShowTaskOverviewMoreChanges, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                        </StackPanel>

                                        <StackPanel Visibility="{x:Bind ChatVM.TaskOverviewState.ShouldShowEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Margin="0,40">
                                            <TextBlock x:Uid="TaskOverviewEmptyTitle"
                                                       AutomationProperties.AutomationId="RightPanel.TaskOverview.EmptyTitle"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" />
                                            <TextBlock x:Uid="TaskOverviewEmptySubtitle"
                                                       Opacity="0.7"
                                                       Margin="0,8,0,0"
                                                       TextAlignment="Center"
                                                       HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>

                                <controls:ResizeGrip x:Name="RightPanelResizer" 
                                                     Grid.Row="0"
                                                     Grid.RowSpan="2"
                                                     HorizontalAlignment="Left" 
                                                     VerticalAlignment="Stretch" 
                                                     Width="6" 
                                                     Background="Transparent" 
                                                     Style="{StaticResource RightPanelResizerThumbStyle}" 
                                                     PointerPressed="OnRightPanelResizerPointerPressed" 
                                                     PointerMoved="OnRightPanelResizerPointerMoved"
                                                     PointerReleased="OnRightPanelResizerPointerReleased"
                                                     PointerCaptureLost="OnRightPanelResizerPointerCaptureLost" />
                            </Grid>
                        </SplitView.Pane>
                    </SplitView>
                </NavigationView.Content>
            </NavigationView>

            <Button x:Name="AutomationArchiveSelectedButton"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="1"
                    Height="1"
                    Opacity="0.01"
                    Visibility="{x:Bind IsGuiAutomationMode, Mode=OneTime, Converter={StaticResource BoolToVisibilityConverter}}"
                    AutomationProperties.AutomationId="MainNav.Session.AutomationArchiveSelected"
                    Click="OnAutomationArchiveSelectedClick" />

            <TextBlock x:Name="MainNavAutomationSelectionStateText"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Width="1"
                       Height="1"
                       Opacity="0.01"
                       Visibility="{x:Bind IsGuiAutomationMode, Mode=OneTime, Converter={StaticResource BoolToVisibilityConverter}}"
                       AutomationProperties.AutomationId="MainNav.Automation.SelectionState" />

            <controls:ResizeGrip x:Name="LeftNavResizer"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Stretch"
                                 Width="6"
                                 Background="Transparent"
                                 Style="{StaticResource SubMenuResizerThumbStyle}"
                                 Visibility="{x:Bind LayoutVM.IsNavResizerVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                 PointerPressed="OnLeftNavResizerPointerPressed"
                                 PointerMoved="OnLeftNavResizerPointerMoved"
                                 PointerReleased="OnLeftNavResizerPointerReleased"
                                 PointerCaptureLost="OnLeftNavResizerPointerCaptureLost">
                <controls:ResizeGrip.RenderTransform>
                    <TranslateTransform x:Name="LeftNavResizerTransform" X="{x:Bind LayoutVM.LeftNavResizerLeft, Mode=OneWay}" />
                </controls:ResizeGrip.RenderTransform>
            </controls:ResizeGrip>
        </Grid>
    </Grid>
</Page>
