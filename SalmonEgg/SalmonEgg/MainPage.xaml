<Page
    x:Class="SalmonEgg.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels"
    xmlns:nav="using:SalmonEgg.Presentation.ViewModels.Navigation"
    xmlns:navModels="using:SalmonEgg.Presentation.Models.Navigation"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:searchModels="using:SalmonEgg.Presentation.Models.Search"
    xmlns:navViews="using:SalmonEgg.Presentation.Views.Navigation"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:chatVm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:behaviors="using:SalmonEgg.Presentation.Behaviors"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:PlanStatusToColorConverter x:Key="PlanStatusToColorConverter" />
        <converters:EnumToBooleanConverter x:Key="EnumToBoolConverter" />
        <converters:EnumToVisibilityConverter x:Key="EnumToVisibilityConverter" />

        <x:Double x:Key="NavCompactPaneLength">72</x:Double>
        <x:Double x:Key="NavOpenPaneLength">300</x:Double>

        <!-- Navigation section header sizing (keep consistent + tweakable in one place) -->
        <x:Double x:Key="NavSectionHeaderMinHeight">32</x:Double>
        <x:Double x:Key="NavSectionHeaderActionButtonSize">24</x:Double>
        <x:Double x:Key="NavProjectActionButtonSize">24</x:Double>
        <x:Double x:Key="SearchBoxMinWidthWide">220</x:Double>
        <x:Double x:Key="SearchBoxMaxWidthWide">360</x:Double>
        <x:Double x:Key="SearchBoxMinWidthMedium">180</x:Double>
        <x:Double x:Key="SearchBoxMaxWidthMedium">300</x:Double>

        <DataTemplate x:Key="StartNavTemplate" x:DataType="nav:StartNavItemViewModel">
            <NavigationViewItem Content="{x:Bind Title, Mode=OneWay}"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </DataTemplate>
        
        <DataTemplate x:Key="SessionsHeaderTemplate" x:DataType="nav:SessionsHeaderNavItemViewModel">
            <NavigationViewItem MinHeight="{StaticResource NavSectionHeaderMinHeight}"
                                HorizontalContentAlignment="Stretch"
                                Padding="0"
                                SelectsOnInvoked="False">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Add" 
                                Visibility="{x:Bind ShowCompactButton, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                </NavigationViewItem.Icon>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8"
                          Visibility="{x:Bind ShowHeaderLabel, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                   Style="{StaticResource NavigationViewItemHeaderTextStyle}"
                                   Foreground="{ThemeResource NavigationViewItemHeaderForeground}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Width="{StaticResource NavSectionHeaderActionButtonSize}"
                                Height="{StaticResource NavSectionHeaderActionButtonSize}"
                                MinWidth="{StaticResource NavSectionHeaderActionButtonSize}"
                                MinHeight="{StaticResource NavSectionHeaderActionButtonSize}"
                                Padding="0"
                                HorizontalAlignment="Right"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                BorderBrush="{ThemeResource SubtleFillColorTransparentBrush}"
                                BorderThickness="0"
                                ToolTipService.ToolTip="添加项目"
                                Command="{x:Bind AddProjectCommand}"
                                AutomationProperties.Name="添加项目">
                            <FontIcon Glyph="&#xE710;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="14" />
                        </Button>
                    </Grid>
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="ProjectNavTemplate" x:DataType="nav:ProjectNavItemViewModel">
            <NavigationViewItem MenuItemsSource="{x:Bind Children, Mode=OneWay}"
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                HorizontalContentAlignment="Stretch"
                                SelectsOnInvoked="False"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Folder" />
                </NavigationViewItem.Icon>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="*"
                          Visibility="{x:Bind IsPaneOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   VerticalAlignment="Center" />
                    </Grid>
                </NavigationViewItem.Content>

                <NavigationViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="ProjectNavNewSessionItem"
                                        Command="{x:Bind CreateSessionCommand}" />
                    </MenuFlyout>
                </NavigationViewItem.ContextFlyout>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="SessionNavTemplate" x:DataType="nav:SessionNavItemViewModel">
            <NavigationViewItem SelectsOnInvoked="True"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Comment" />
                </NavigationViewItem.Icon>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <ProgressRing Width="14"
                                      Height="14"
                                      IsActive="{x:Bind IsPlaceholder, Mode=OneWay}"
                                      Visibility="{x:Bind IsPlaceholder, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Title, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"/>

                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind RelativeTimeText, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Opacity="0.55"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </NavigationViewItem.Content>

                <NavigationViewItem.ContextFlyout>
                    <MenuFlyout Closed="OnSessionNavFlyoutClosed">
                        <MenuFlyoutItem x:Uid="SessionNavArchiveItem"
                                        Click="OnSessionArchiveMenuItemClick"
                                        CommandParameter="{x:Bind}"
                                        IsEnabled="{x:Bind IsPlaceholder, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}" />
                        <MenuFlyoutItem x:Uid="SessionNavRenameItem"
                                        Command="{x:Bind RenameCommand}" />
                    </MenuFlyout>
                </NavigationViewItem.ContextFlyout>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="MoreNavTemplate" x:DataType="nav:MoreSessionsNavItemViewModel">
            <NavigationViewItem Content="{x:Bind Title, Mode=OneWay}"
                                SelectsOnInvoked="False"
                                Tag="{x:Bind navModels:NavItemTag.More(ProjectId)}"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="More" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </DataTemplate>

        <navViews:MainNavItemTemplateSelector x:Key="MainNavItemTemplateSelector"
                                              StartTemplate="{StaticResource StartNavTemplate}"
                                              HeaderTemplate="{StaticResource SessionsHeaderTemplate}"
                                              ProjectTemplate="{StaticResource ProjectNavTemplate}"
                                              SessionTemplate="{StaticResource SessionNavTemplate}"
                                              MoreTemplate="{StaticResource MoreNavTemplate}" />

        <Style x:Key="SubMenuResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Right"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightPanelResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Left"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid x:Name="LayoutRoot">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowWidthStates">
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="Left" />
                        <Setter Target="TopSearchBox.Visibility" Value="Visible" />
                        <Setter Target="TopSearchBox.MinWidth" Value="{StaticResource SearchBoxMinWidthWide}" />
                        <Setter Target="TopSearchBox.MaxWidth" Value="{StaticResource SearchBoxMaxWidthWide}" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Medium">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="640" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="LeftCompact" />
                        <Setter Target="TopSearchBox.Visibility" Value="Visible" />
                        <Setter Target="TopSearchBox.MinWidth" Value="{StaticResource SearchBoxMinWidthMedium}" />
                        <Setter Target="TopSearchBox.MaxWidth" Value="{StaticResource SearchBoxMaxWidthMedium}" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="LeftMinimal" />
                        <Setter Target="TopSearchBox.Visibility" Value="Collapsed" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="Transparent"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Height="48">
            <Grid>
                <Grid x:Name="TitleBarDragRegion" Background="Transparent" />
                <Grid x:Name="AppTitleBarContent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="TitleBarLeftButtons"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="4"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center">
                        <Button x:Name="TitleBarBackButton"
                                Style="{StaticResource TitleBarCommandButtonStyle}"
                                ToolTipService.ToolTip="返回"
                                AutomationProperties.Name="返回"
                                Click="OnTitleBarBackClick">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72B;"/>
                        </Button>
                        <Button x:Name="TitleBarToggleLeftNavButton"
                                Style="{StaticResource TitleBarCommandButtonStyle}"
                                ToolTipService.ToolTip="折叠左侧边栏"
                                AutomationProperties.Name="切换侧边栏"
                                Click="OnToggleLeftNavClick">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE700;"/>
                        </Button>
                    </StackPanel>

                    <TextBox x:Name="TopSearchBox"
                             x:Uid="TopSearchBox"
                             Grid.Column="1"
                             Height="32"
                             Text="{x:Bind SearchVM.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             behaviors:FocusMonitor.IsFocused="{x:Bind SearchVM.IsSearchBoxFocused, Mode=TwoWay}"
                             behaviors:FlyoutMonitor.IsOpen="{x:Bind SearchVM.IsSearchPanelOpen, Mode=TwoWay}"
                             CornerRadius="8"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <FlyoutBase.AttachedFlyout>
                            <Flyout Placement="BottomEdgeAlignedLeft"
                                    ShowMode="Transient"
                                    Opened="OnSearchPanelPopupOpened"
                                    Closed="OnSearchPanelPopupClosed">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="CornerRadius" Value="8" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="{ThemeResource SolidBackgroundFillColorBaseBrush}" />
                                        <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Visibility" Value="{x:Bind SearchVM.HasAnyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <Grid x:Name="SearchPanelBorder"
                                      MinWidth="{x:Bind TopSearchBox.ActualWidth}"
                                      MaxWidth="{x:Bind TopSearchBox.ActualWidth}"
                                      HorizontalAlignment="Stretch">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400" HorizontalAlignment="Stretch">
                                        <StackPanel HorizontalAlignment="Stretch">
                                            <muxc:ItemsRepeater ItemsSource="{x:Bind SearchVM.ResultGroups, Mode=OneWay}" HorizontalAlignment="Stretch">
                                                <muxc:ItemsRepeater.Layout>
                                                    <muxc:StackLayout Spacing="8" />
                                                </muxc:ItemsRepeater.Layout>
                                                <muxc:ItemsRepeater.ItemTemplate>
                                                    <DataTemplate x:DataType="searchModels:SearchResultGroup">
                                                        <StackPanel HorizontalAlignment="Stretch">
                                                            <TextBlock Text="{x:Bind Title}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                       Margin="16,12,16,4" />
                                                            <muxc:ItemsRepeater ItemsSource="{x:Bind Items}" HorizontalAlignment="Stretch">
                                                                <muxc:ItemsRepeater.Layout>
                                                                    <muxc:StackLayout Spacing="2" />
                                                                </muxc:ItemsRepeater.Layout>
                                                                <muxc:ItemsRepeater.ItemTemplate>
                                                                    <DataTemplate x:DataType="searchModels:SearchResultItem">
                                                                        <Button HorizontalAlignment="Stretch"
                                                                                HorizontalContentAlignment="Stretch"
                                                                                Padding="12,8"
                                                                                Margin="4,2"
                                                                                Command="{x:Bind ActivateCommand}"
                                                                                CommandParameter="{x:Bind}"
                                                                                AutomationProperties.Name="{x:Bind Title}">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <Setter Property="Background" Value="Transparent" />
                                                                                    <Setter Property="BorderThickness" Value="0" />
                                                                                    <Setter Property="CornerRadius" Value="4" />
                                                                                </Style>
                                                                            </Button.Style>
                                                                            <Grid HorizontalAlignment="Stretch">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <FontIcon Grid.Column="0"
                                                                                          Glyph="{x:Bind IconGlyph}"
                                                                                          Margin="0,0,12,0"
                                                                                          FontSize="16"
                                                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                                                                    <TextBlock Text="{x:Bind Title}"
                                                                                               FontSize="14" 
                                                                                               TextTrimming="CharacterEllipsis"/>
                                                                                    <TextBlock Text="{x:Bind Subtitle}"
                                                                                               FontSize="12"
                                                                                               Opacity="0.7"
                                                                                               TextTrimming="CharacterEllipsis"
                                                                                               Visibility="{x:Bind Subtitle, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </muxc:ItemsRepeater.ItemTemplate>
                                                            </muxc:ItemsRepeater>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </muxc:ItemsRepeater.ItemTemplate>
                                            </muxc:ItemsRepeater>

                                            <StackPanel Visibility="{x:Bind SearchVM.ShowSuggestions, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Margin="0,0,0,8"
                                                        HorizontalAlignment="Stretch">
                                                <TextBlock x:Uid="SearchPanelRecentTitle"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Margin="16,12,16,4" />
                                                <muxc:ItemsRepeater ItemsSource="{x:Bind SearchVM.RecentSearches, Mode=OneWay}" HorizontalAlignment="Stretch">
                                                    <muxc:ItemsRepeater.Layout>
                                                        <muxc:StackLayout Spacing="2" />
                                                    </muxc:ItemsRepeater.Layout>
                                                    <muxc:ItemsRepeater.ItemTemplate>
                                                        <DataTemplate x:DataType="searchModels:SearchHistoryItem">
                                                            <Button Content="{x:Bind Query}"
                                                                    Padding="12,8"
                                                                    Margin="4,2"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Left"
                                                                    Command="{x:Bind UseCommand}"
                                                                    CommandParameter="{x:Bind Query}">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Background" Value="Transparent" />
                                                                        <Setter Property="BorderThickness" Value="0" />
                                                                        <Setter Property="CornerRadius" Value="4" />
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </DataTemplate>
                                                    </muxc:ItemsRepeater.ItemTemplate>
                                                </muxc:ItemsRepeater>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <TextBlock x:Uid="SearchPanelEmptyText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,40"
                                               Opacity="0.6"
                                               Visibility="{x:Bind SearchVM.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                    </TextBox>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0">
                        <ToggleButton x:Name="DiffPanelButton"
                                      Tag="Diff"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      ToolTipService.ToolTip="Diff"
                                      AutomationProperties.Name="Diff 面板"
                                      Click="OnRightPanelButtonClick"
                                      IsChecked="{x:Bind NavVM.RightPanelMode, Mode=OneWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Diff}">
                            <SymbolIcon Symbol="Preview" />
                        </ToggleButton>
                        <ToggleButton x:Name="TodoPanelButton"
                                      Tag="Todo"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      ToolTipService.ToolTip="Todo"
                                      AutomationProperties.Name="Todo 面板"
                                      Click="OnRightPanelButtonClick"
                                      IsChecked="{x:Bind NavVM.RightPanelMode, Mode=OneWay, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Todo}">
                            <SymbolIcon Symbol="Bullets" />
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightPanelColumnDefinition" Width="Auto" />
            </Grid.ColumnDefinitions>

            <NavigationView x:Name="MainNavView"
                             Grid.Column="0"
                             Background="Transparent"
                             CompactPaneLength="{x:Bind NavVM.NavCompactPaneLength, Mode=OneWay}"
                             OpenPaneLength="{x:Bind NavVM.OpenPaneLength, Mode=OneWay}"
                             IsPaneOpen="{x:Bind NavVM.IsPaneOpen, Mode=TwoWay}"
                             IsBackButtonVisible="Collapsed"
                             IsPaneToggleButtonVisible="False"
                             IsSettingsVisible="True"
                             AlwaysShowHeader="False"
                             behaviors:NavigationViewDisplayModeMonitor.DisplayMode="{x:Bind NavVM.PaneDisplayMode, Mode=TwoWay}"
                             MenuItemsSource="{x:Bind NavVM.Items, Mode=OneWay}"
                             MenuItemTemplateSelector="{StaticResource MainNavItemTemplateSelector}"
                             SelectedItem="{x:Bind NavVM.SelectedItem, Mode=TwoWay}"
                             SelectionChanged="OnMainNavSelectionChanged"
                             ItemInvoked="OnMainNavItemInvoked"
                             DisplayModeChanged="OnMainNavDisplayModeChanged"
                             PaneOpened="OnMainNavPaneOpened"
                             PaneClosed="OnMainNavPaneClosed"
                             PaneClosing="OnMainNavPaneClosing">
                <NavigationView.Content>
                    <Frame x:Name="ContentFrame"
                           Background="Transparent"
                           ContentTransitions="{x:Bind models:UiMotion.Current.PageTransitions, Mode=OneWay}" />
                </NavigationView.Content>
            </NavigationView>

            <controls:ResizeGrip x:Name="LeftNavResizer"
                                 Grid.Column="0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Stretch"
                                 Width="6"
                                 Background="Transparent"
                                 Style="{StaticResource SubMenuResizerThumbStyle}"
                                 Visibility="{x:Bind NavVM.IsLeftNavResizerVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                 PointerPressed="OnLeftNavResizerPointerPressed"
                                 PointerMoved="OnLeftNavResizerPointerMoved"
                                 PointerReleased="OnLeftNavResizerPointerReleased"
                                 PointerCaptureLost="OnLeftNavResizerPointerCaptureLost">
                <controls:ResizeGrip.RenderTransform>
                    <TranslateTransform x:Name="LeftNavResizerTransform" />
                </controls:ResizeGrip.RenderTransform>
            </controls:ResizeGrip>

            <Grid x:Name="RightPanelColumn"
                  Grid.Column="1"
                  Width="0"
                  Visibility="Collapsed"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="1,0,0,0">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="RightPanelTranslate" />
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Height="48" Padding="16,0,8,0">
                    <TextBlock x:Name="RightPanelTitle" Text="Panel" VerticalAlignment="Center" Style="{ThemeResource BodyStrongTextBlockStyle}" />


                </Grid>

                <Grid Grid.Row="1">
                    <Grid Visibility="{x:Bind NavVM.RightPanelMode, Mode=OneWay, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Diff}">
                         <TextBlock x:Uid="DiffPanelPlaceholder" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                    </Grid>

                    <Grid Visibility="{x:Bind NavVM.RightPanelMode, Mode=OneWay, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Todo}">
                        <ScrollViewer>
                            <Grid Padding="16">
                                <ListView ItemsSource="{x:Bind ChatVM.PlanEntries, Mode=OneWay}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="chatVm:PlanEntryViewModel">
                                            <Border Margin="0,0,0,8" Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{x:Bind Status, Converter={StaticResource PlanStatusToColorConverter}}" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind Content}" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind StatusDisplayName}" FontSize="11" Opacity="0.8" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{x:Bind PriorityDisplayName}" FontSize="10" Opacity="0.5" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <StackPanel Visibility="{x:Bind ChatVM.ShouldShowPlanEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40">
                                    <TextBlock x:Uid="PlanEmptyTitle" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock x:Uid="PlanEmptySubtitle" Opacity="0.7" Margin="0,8,0,0" TextAlignment="Center" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>

                <controls:ResizeGrip x:Name="RightPanelResizer" 
                                     HorizontalAlignment="Left" 
                                     VerticalAlignment="Stretch" 
                                     Width="6" 
                                     Background="Transparent" 
                                     Style="{StaticResource RightPanelResizerThumbStyle}" 
                                     PointerPressed="OnRightPanelResizerPointerPressed" 
                                     PointerMoved="OnRightPanelResizerPointerMoved"
                                     PointerReleased="OnRightPanelResizerPointerReleased"
                                     PointerCaptureLost="OnRightPanelResizerPointerCaptureLost" />
            </Grid>
        </Grid>
    </Grid>
</Page>
