<Page
    x:Class="SalmonEgg.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels"
    xmlns:nav="using:SalmonEgg.Presentation.ViewModels.Navigation"
    xmlns:navModels="using:SalmonEgg.Presentation.Models.Navigation"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:navViews="using:SalmonEgg.Presentation.Views.Navigation"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Navigation section header sizing (keep consistent + tweakable in one place) -->
        <x:Double x:Key="NavSectionHeaderMinHeight">32</x:Double>
        <x:Double x:Key="NavSectionHeaderActionButtonSize">24</x:Double>
        <Thickness x:Key="NavSectionHeaderOuterMargin">0,2,0,0</Thickness>
        <Thickness x:Key="NavSectionHeaderContentPadding">0</Thickness>
        <Thickness x:Key="NavSectionHeaderDividerMargin">16,2,16,0</Thickness>
        <Thickness x:Key="NavSectionHeaderTitleMargin">12,0,0,0</Thickness>
        <x:Double x:Key="NavProjectActionButtonSize">24</x:Double>

        <!-- Project row uses a presenter without the expand chevron. -->
        <Style x:Key="ProjectNavItemPresenterStyle" TargetType="primitives:NavigationViewItemPresenter">
            <Setter Property="Foreground" Value="{ThemeResource NavigationViewItemForeground}" />
            <Setter Property="Background" Value="{ThemeResource NavigationViewItemBackground}" />
            <Setter Property="BorderBrush" Value="{ThemeResource NavigationViewItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="{StaticResource NavigationViewItemBorderThickness}" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:NavigationViewItemPresenter">
                        <Grid x:Name="LayoutRoot"
                              MinHeight="{ThemeResource NavigationViewItemOnLeftMinHeight}"
                              Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              Margin="{ThemeResource NavigationViewItemButtonMargin}"
                              Control.IsTemplateFocusTarget="True">
                            <Grid.Resources />

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="PointerStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundPointerOver}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundPointerOver}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundPointerOver}" />
                                            <Setter Target="Icon.(muxc:AnimatedIcon.State)" Value="PointerOver" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundPressed}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundPressed}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundPressed}" />
                                            <Setter Target="Icon.(muxc:AnimatedIcon.State)" Value="Pressed" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundSelected}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelected}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelected}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOverSelected">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundSelectedPointerOver}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelectedPointerOver}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelectedPointerOver}" />
                                            <Setter Target="Icon.(muxc:AnimatedIcon.State)" Value="PointerOver" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PressedSelected">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundSelectedPressed}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelectedPressed}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelectedPressed}" />
                                            <Setter Target="Icon.(muxc:AnimatedIcon.State)" Value="Pressed" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="DisabledStates">
                                    <VisualState x:Name="Enabled" />
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Opacity" Value="{ThemeResource ListViewItemDisabledThemeOpacity}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="IconStates">
                                    <VisualState x:Name="IconVisible" />
                                    <VisualState x:Name="IconCollapsed">
                                        <VisualState.Setters>
                                            <Setter Target="IconBox.Visibility" Value="Collapsed" />
                                            <Setter Target="IconColumn.Width" Value="8" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="InfoBadgeStates">
                                    <VisualState x:Name="InfoBadgeVisible" />
                                    <VisualState x:Name="InfoBadgeCollapsed">
                                        <VisualState.Setters>
                                            <Setter Target="InfoBadgePresenter.Visibility" Value="Collapsed" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="PaneAndTopLevelItemStates">
                                    <VisualState x:Name="NotClosedCompactAndTopLevelItem" />
                                    <VisualState x:Name="ClosedCompactAndTopLevelItem">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Margin" Value="{ThemeResource NavigationViewCompactItemContentPresenterMargin}" />
                                            <Setter Target="ContentGrid.Margin" Value="0,0,0,0" />
                                            <Setter Target="InfoBadgePresenter.(Grid.Column)" Value="0" />
                                            <Setter Target="InfoBadgePresenter.(Grid.ColumnSpan)" Value="3" />
                                            <Setter Target="InfoBadgePresenter.VerticalAlignment" Value="Top" />
                                            <Setter Target="InfoBadgePresenter.HorizontalAlignment" Value="Right" />
                                            <Setter Target="InfoBadgePresenter.Margin" Value="0,2,2,0" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid x:Name="PresenterContentRootGrid">
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Rectangle x:Name="SelectionIndicator"
                                               Width="{ThemeResource NavigationViewSelectionIndicatorWidth}"
                                               Height="{ThemeResource NavigationViewSelectionIndicatorHeight}"
                                               Fill="{ThemeResource NavigationViewSelectionIndicatorForeground}"
                                               Opacity="0.0"
                                               RadiusX="{ThemeResource NavigationViewSelectionIndicatorRadius}"
                                               RadiusY="{ThemeResource NavigationViewSelectionIndicatorRadius}" />
                                </Grid>
                                <Grid x:Name="ContentGrid"
                                      MinHeight="{ThemeResource NavigationViewItemOnLeftMinHeight}"
                                      Margin="0"
                                      HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="IconColumn" Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.SmallerIconWidth}">
                                        <Viewbox x:Name="IconBox"
                                                 Height="{ThemeResource NavigationViewItemOnLeftIconBoxHeight}"
                                                 HorizontalAlignment="Center"
                                                 Margin="{ThemeResource NavigationViewItemOnLeftIconBoxMargin}">
                                            <ContentPresenter x:Name="Icon"
                                                              Content="{TemplateBinding Icon}"
                                                              Foreground="{TemplateBinding Foreground}"
                                                              Background="{ThemeResource NavigationViewItemIconBackground}"
                                                              local:AnimatedIcon.State="Normal"
                                                              xmlns:local="using:Microsoft.UI.Xaml.Controls" />
                                        </Viewbox>
                                    </Border>
                                    <ContentPresenter x:Name="ContentPresenter"
                                                      Grid.Column="1"
                                                      Margin="{ThemeResource NavigationViewItemContentPresenterMargin}"
                                                      ContentTransitions="{TemplateBinding ContentTransitions}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      Content="{TemplateBinding Content}"
                                                      Foreground="{TemplateBinding Foreground}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                      Padding="{TemplateBinding Padding}"
                                                      AutomationProperties.AccessibilityView="Raw" />
                                    <ContentPresenter x:Name="InfoBadgePresenter"
                                                      Grid.Column="2"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding InfoBadge}" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

<Style x:Key="SessionsHeaderNavItemPresenterStyle" TargetType="primitives:NavigationViewItemPresenter">
            <Setter Property="Foreground" Value="{ThemeResource NavigationViewItemForeground}" />
            <Setter Property="Background" Value="{ThemeResource NavigationViewItemBackground}" />
            <Setter Property="BorderBrush" Value="{ThemeResource NavigationViewItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="{StaticResource NavigationViewItemBorderThickness}" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="primitives:NavigationViewItemPresenter">
                        <Grid x:Name="LayoutRoot"
                              MinHeight="{ThemeResource NavigationViewItemOnLeftMinHeight}"
                              Background="{TemplateBinding Background}"
                              CornerRadius="{TemplateBinding CornerRadius}"
                              Margin="{ThemeResource NavigationViewItemButtonMargin}"
                              Control.IsTemplateFocusTarget="True">
                            <Grid.Resources />

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="PointerStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundPointerOver}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundPointerOver}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundPointerOver}" />
                                            <Setter Target="Icon.(muxc:AnimatedIcon.State)" Value="PointerOver" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundPressed}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundPressed}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundPressed}" />
                                            <Setter Target="Icon.(muxc:AnimatedIcon.State)" Value="Pressed" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundSelected}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelected}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelected}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOverSelected">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundSelectedPointerOver}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelectedPointerOver}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelectedPointerOver}" />
                                            <Setter Target="Icon.(muxc:AnimatedIcon.State)" Value="PointerOver" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PressedSelected">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource NavigationViewItemBackgroundSelectedPressed}" />
                                            <Setter Target="Icon.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelectedPressed}" />
                                            <Setter Target="ContentPresenter.Foreground" Value="{ThemeResource NavigationViewItemForegroundSelectedPressed}" />
                                            <Setter Target="Icon.(muxc:AnimatedIcon.State)" Value="Pressed" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="DisabledStates">
                                    <VisualState x:Name="Enabled" />
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Opacity" Value="{ThemeResource ListViewItemDisabledThemeOpacity}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="IconStates">
                                    <VisualState x:Name="IconVisible" />
                                    <VisualState x:Name="IconCollapsed">
                                        <VisualState.Setters>
                                            <Setter Target="IconBox.Visibility" Value="Collapsed" />
                                            <Setter Target="IconColumn.Width" Value="0" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="InfoBadgeStates">
                                    <VisualState x:Name="InfoBadgeVisible" />
                                    <VisualState x:Name="InfoBadgeCollapsed">
                                        <VisualState.Setters>
                                            <Setter Target="InfoBadgePresenter.Visibility" Value="Collapsed" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>

                                <VisualStateGroup x:Name="PaneAndTopLevelItemStates">
                                    <VisualState x:Name="NotClosedCompactAndTopLevelItem" />
                                    <VisualState x:Name="ClosedCompactAndTopLevelItem">
                                        <VisualState.Setters>
                                            <Setter Target="ContentPresenter.Margin" Value="{ThemeResource NavigationViewCompactItemContentPresenterMargin}" />
                                            <Setter Target="ContentGrid.Margin" Value="0,0,0,0" />
                                            <Setter Target="IconColumn.Width" Value="0" />
                                            <Setter Target="InfoBadgePresenter.(Grid.Column)" Value="0" />
                                            <Setter Target="InfoBadgePresenter.(Grid.ColumnSpan)" Value="3" />
                                            <Setter Target="InfoBadgePresenter.VerticalAlignment" Value="Top" />
                                            <Setter Target="InfoBadgePresenter.HorizontalAlignment" Value="Right" />
                                            <Setter Target="InfoBadgePresenter.Margin" Value="0,2,2,0" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <Grid x:Name="PresenterContentRootGrid">
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <Rectangle x:Name="SelectionIndicator"
                                               Width="{ThemeResource NavigationViewSelectionIndicatorWidth}"
                                               Height="{ThemeResource NavigationViewSelectionIndicatorHeight}"
                                               Fill="{ThemeResource NavigationViewSelectionIndicatorForeground}"
                                               Opacity="0.0"
                                               RadiusX="{ThemeResource NavigationViewSelectionIndicatorRadius}"
                                               RadiusY="{ThemeResource NavigationViewSelectionIndicatorRadius}" />
                                </Grid>
                                <Grid x:Name="ContentGrid"
                                      MinHeight="{ThemeResource NavigationViewItemOnLeftMinHeight}"
                                      Margin="0"
                                      HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border x:Name="IconColumn" Width="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=TemplateSettings.SmallerIconWidth}">
                                        <Viewbox x:Name="IconBox"
                                                 Height="{ThemeResource NavigationViewItemOnLeftIconBoxHeight}"
                                                 HorizontalAlignment="Center"
                                                 Margin="{ThemeResource NavigationViewItemOnLeftIconBoxMargin}">
                                            <ContentPresenter x:Name="Icon"
                                                              Content="{TemplateBinding Icon}"
                                                              Foreground="{TemplateBinding Foreground}"
                                                              Background="{ThemeResource NavigationViewItemIconBackground}"
                                                              local:AnimatedIcon.State="Normal"
                                                              xmlns:local="using:Microsoft.UI.Xaml.Controls" />
                                        </Viewbox>
                                    </Border>
                                    <ContentPresenter x:Name="ContentPresenter"
                                                      Grid.Column="1"
                                                      Margin="{ThemeResource NavigationViewItemContentPresenterMargin}"
                                                      ContentTransitions="{TemplateBinding ContentTransitions}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      Content="{TemplateBinding Content}"
                                                      Foreground="{TemplateBinding Foreground}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                      Padding="{TemplateBinding Padding}"
                                                      AutomationProperties.AccessibilityView="Raw" />
                                    <ContentPresenter x:Name="InfoBadgePresenter"
                                                      Grid.Column="2"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding InfoBadge}" />
                                </Grid>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProjectNavItemStyle" TargetType="NavigationViewItem">
            <Setter Property="Foreground" Value="{ThemeResource NavigationViewItemForeground}" />
            <Setter Property="Background" Value="{ThemeResource NavigationViewItemBackground}" />
            <Setter Property="BorderBrush" Value="{ThemeResource NavigationViewItemBorderBrush}" />
            <Setter Property="BorderThickness" Value="{StaticResource NavigationViewItemBorderThickness}" />
            <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}" />
            <Setter Property="FontWeight" Value="Normal" />
            <Setter Property="FontSize" Value="{ThemeResource ControlContentThemeFontSize}" />
            <Setter Property="Margin" Value="{ThemeResource NavigationViewItemMargin}" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="TabNavigation" Value="Once" />
            <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="NavigationViewItem">
                        <Grid x:Name="NVIRootGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="ItemOnNavigationViewListPositionStates">
                                    <VisualState x:Name="OnLeftNavigation">
                                        <VisualState.Setters>
                                            <Setter Target="NavigationViewItemPresenter.Style" Value="{StaticResource ProjectNavItemPresenterStyle}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="OnTopNavigationPrimary">
                                        <VisualState.Setters>
                                            <Setter Target="NavigationViewItemPresenter.Margin" Value="{ThemeResource TopNavigationViewItemMargin}" />
                                            <Setter Target="NavigationViewItemPresenter.Style" Value="{StaticResource MUX_NavigationViewItemPresenterStyleWhenOnTopPane}" />
                                            <Setter Target="ChildrenFlyout.Placement" Value="BottomEdgeAlignedLeft" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="OnTopNavigationOverflow">
                                        <VisualState.Setters>
                                            <Setter Target="NavigationViewItemPresenter.Style" Value="{StaticResource MUX_NavigationViewItemPresenterStyleWhenOnTopPaneOverflow}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <primitives:NavigationViewItemPresenter x:Name="NavigationViewItemPresenter"
                                                                    Icon="{TemplateBinding Icon}"
                                                                    InfoBadge="{TemplateBinding InfoBadge}"
                                                                    ContentTransitions="{TemplateBinding ContentTransitions}"
                                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                    Padding="{TemplateBinding Padding}"
                                                                    Foreground="{TemplateBinding Foreground}"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    UseSystemFocusVisuals="{TemplateBinding UseSystemFocusVisuals}"
                                                                    VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                                                    HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                                                    VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                    HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                    ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                                    Content="{TemplateBinding Content}"
                                                                    CornerRadius="{TemplateBinding CornerRadius}"
                                                                    IsTabStop="false"
                                                                    Control.IsTemplateFocusTarget="True" />
                            <muxc:ItemsRepeater x:Load="False"
                                                    Grid.Row="1"
                                                    Visibility="Collapsed"
                                                    x:Name="NavigationViewItemMenuItemsHost">
                                <muxc:ItemsRepeater.Layout>
                                    <muxc:StackLayout Orientation="Vertical" />
                                </muxc:ItemsRepeater.Layout>
                            </muxc:ItemsRepeater>
                            <FlyoutBase.AttachedFlyout>
                                <Flyout x:Name="ChildrenFlyout" Placement="RightEdgeAlignedTop">
                                    <Flyout.FlyoutPresenterStyle>
                                        <Style TargetType="FlyoutPresenter">
                                            <Setter Property="Padding" Value="{ThemeResource NavigationViewItemChildrenMenuFlyoutPadding}" />
                                            <Setter Property="Margin" Value="0,-4,0,0" />
                                            <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Auto" />
                                            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
                                            <Setter Property="ScrollViewer.VerticalScrollMode" Value="Auto" />
                                            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
                                            <Setter Property="ScrollViewer.ZoomMode" Value="Disabled" />
                                            <Setter Property="CornerRadius" Value="{ThemeResource OverlayCornerRadius}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="FlyoutPresenter">
                                                        <ScrollViewer x:Name="ScrollViewer"
                                                                      ZoomMode="{TemplateBinding ScrollViewer.ZoomMode}"
                                                                      HorizontalScrollMode="{TemplateBinding ScrollViewer.HorizontalScrollMode}"
                                                                      HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                                      VerticalScrollMode="{TemplateBinding ScrollViewer.VerticalScrollMode}"
                                                                      VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                                                                      AutomationProperties.AccessibilityView="Raw">
                                                            <ContentPresenter x:Name="ContentPresenter"
                                                                              Background="{TemplateBinding Background}"
                                                                              BorderBrush="{TemplateBinding BorderBrush}"
                                                                              BorderThickness="{TemplateBinding BorderThickness}"
                                                                              Content="{TemplateBinding Content}"
                                                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                                                              Padding="{TemplateBinding Padding}"
                                                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                              CornerRadius="{TemplateBinding CornerRadius}" />
                                                        </ScrollViewer>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Flyout.FlyoutPresenterStyle>
                                    <Grid x:Name="FlyoutRootGrid">
                                        <Grid x:Name="FlyoutContentGrid" />
                                    </Grid>
                                </Flyout>
                            </FlyoutBase.AttachedFlyout>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 会话头部导航项样式 -->
        <Style x:Key="SessionsHeaderNavItemStyle" TargetType="NavigationViewItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="NavigationViewItem">
                        <primitives:NavigationViewItemPresenter x:Name="NavigationViewItemPresenter"
                                                                Icon="{TemplateBinding Icon}"
                                                                InfoBadge="{TemplateBinding InfoBadge}"
                                                                ContentTransitions="{TemplateBinding ContentTransitions}"
                                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                Padding="{TemplateBinding Padding}"
                                                                Foreground="{TemplateBinding Foreground}"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                UseSystemFocusVisuals="{TemplateBinding UseSystemFocusVisuals}"
                                                                VerticalAlignment="{TemplateBinding VerticalAlignment}"
                                                                HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                                                Content="{TemplateBinding Content}"
                                                                CornerRadius="{TemplateBinding CornerRadius}"
                                                                IsTabStop="false"
                                                                Control.IsTemplateFocusTarget="True"
                                                                Style="{StaticResource SessionsHeaderNavItemPresenterStyle}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="StartNavTemplate" x:DataType="nav:StartNavItemViewModel">
            <NavigationViewItem Content="{x:Bind Title, Mode=OneWay}"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="SessionsHeaderTemplate" x:DataType="nav:SessionsHeaderNavItemViewModel">
            <!-- Use a NavigationViewItem so it reliably renders across hosts, but neutralize hover/pressed visuals
                 via official theme resource overrides (no template hacks). -->
            <NavigationViewItem SelectsOnInvoked="False"
                                IsTabStop="False"
                                MinHeight="{StaticResource NavSectionHeaderMinHeight}"
                                HorizontalContentAlignment="Stretch"
                                Padding="0"
                                Style="{StaticResource SessionsHeaderNavItemStyle}"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Resources>
                    <StaticResource x:Key="NavigationViewItemBackground" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBackgroundPointerOver" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBackgroundPressed" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBackgroundSelected" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBackgroundSelectedPointerOver" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBackgroundSelectedPressed" ResourceKey="SubtleFillColorTransparentBrush" />

                    <StaticResource x:Key="NavigationViewItemBorderBrush" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBorderBrushPointerOver" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBorderBrushPressed" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBorderBrushSelected" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBorderBrushSelectedPointerOver" ResourceKey="SubtleFillColorTransparentBrush" />
                    <StaticResource x:Key="NavigationViewItemBorderBrushSelectedPressed" ResourceKey="SubtleFillColorTransparentBrush" />

                    <StaticResource x:Key="NavigationViewItemForeground" ResourceKey="TextFillColorSecondaryBrush" />
                    <StaticResource x:Key="NavigationViewItemForegroundPointerOver" ResourceKey="TextFillColorSecondaryBrush" />
                    <StaticResource x:Key="NavigationViewItemForegroundPressed" ResourceKey="TextFillColorSecondaryBrush" />
                    <StaticResource x:Key="NavigationViewItemForegroundSelected" ResourceKey="TextFillColorSecondaryBrush" />
                </NavigationViewItem.Resources>

                <NavigationViewItem.Content>
                    <Grid Margin="{StaticResource NavSectionHeaderOuterMargin}"
                          HorizontalAlignment="Stretch">
                        <!-- Expanded pane: label + action button aligned to the right. -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="{StaticResource NavSectionHeaderContentPadding}"
                              ColumnSpacing="8"
                              HorizontalAlignment="Stretch"
                              Visibility="{x:Bind IsPaneOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                       Margin="{StaticResource NavSectionHeaderTitleMargin}"
                                       Style="{StaticResource NavigationViewItemHeaderTextStyle}"
                                       Foreground="{ThemeResource NavigationViewItemHeaderForeground}"
                                       VerticalAlignment="Center"/>

                            <Button Grid.Column="1"
                                    Width="{StaticResource NavSectionHeaderActionButtonSize}"
                                    Height="{StaticResource NavSectionHeaderActionButtonSize}"
                                    MinWidth="{StaticResource NavSectionHeaderActionButtonSize}"
                                    MinHeight="{StaticResource NavSectionHeaderActionButtonSize}"
                                    Padding="0"
                                    HorizontalAlignment="Right"
                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                    Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                    BorderBrush="{ThemeResource SubtleFillColorTransparentBrush}"
                                    BorderThickness="0"
                                    ToolTipService.ToolTip="添加项目"
                                    Command="{x:Bind AddProjectCommand}"
                                    AutomationProperties.Name="添加项目">
                                <FontIcon Glyph="&#xE710;"
                                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                          FontSize="14" />
                            </Button>
                        </Grid>

                        <!-- Compact pane: center the + button in the rail. -->
                        <Grid Padding="0"
                              HorizontalAlignment="Stretch"
                              Visibility="{x:Bind IsPaneOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <Button Width="{StaticResource NavSectionHeaderActionButtonSize}"
                                    Height="{StaticResource NavSectionHeaderActionButtonSize}"
                                    MinWidth="{StaticResource NavSectionHeaderActionButtonSize}"
                                    MinHeight="{StaticResource NavSectionHeaderActionButtonSize}"
                                    Padding="0"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    CornerRadius="{ThemeResource ControlCornerRadius}"
                                    Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                    BorderBrush="{ThemeResource SubtleFillColorTransparentBrush}"
                                    BorderThickness="0"
                                    ToolTipService.ToolTip="添加项目"
                                    Command="{x:Bind AddProjectCommand}"
                                    AutomationProperties.Name="添加项目">
                                <FontIcon Glyph="&#xE710;"
                                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                          FontSize="14" />
                            </Button>
                        </Grid>

                    </Grid>
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="ProjectNavTemplate" x:DataType="nav:ProjectNavItemViewModel">
            <NavigationViewItem MenuItemsSource="{x:Bind Children, Mode=OneWay}"
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                HorizontalContentAlignment="Stretch"
                                Style="{StaticResource ProjectNavItemStyle}"
                                SelectsOnInvoked="False"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Folder" />
                </NavigationViewItem.Icon>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Width="{StaticResource NavProjectActionButtonSize}"
                                Height="{StaticResource NavProjectActionButtonSize}"
                                MinWidth="{StaticResource NavProjectActionButtonSize}"
                                MinHeight="{StaticResource NavProjectActionButtonSize}"
                                Padding="0"
                                HorizontalAlignment="Right"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                BorderBrush="{ThemeResource SubtleFillColorTransparentBrush}"
                                BorderThickness="0"
                                ToolTipService.ToolTip="在此项目中新建会话"
                                Command="{x:Bind CreateSessionCommand}"
                                AutomationProperties.Name="在此项目中新建会话">
                            <FontIcon Glyph="&#xE710;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="12" />
                        </Button>
                    </Grid>
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="SessionNavTemplate" x:DataType="nav:SessionNavItemViewModel">
            <NavigationViewItem SelectsOnInvoked="True"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Comment" />
                </NavigationViewItem.Icon>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <ProgressRing Width="14"
                                      Height="14"
                                      IsActive="{x:Bind IsPlaceholder, Mode=OneWay}"
                                      Visibility="{x:Bind IsPlaceholder, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Title, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"/>

                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind RelativeTimeText, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Opacity="0.55"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </NavigationViewItem.Content>

                <NavigationViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="重命名…"
                                        Command="{x:Bind RenameCommand}" />
                    </MenuFlyout>
                </NavigationViewItem.ContextFlyout>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="MoreNavTemplate" x:DataType="nav:MoreSessionsNavItemViewModel">
            <NavigationViewItem Content="{x:Bind Title, Mode=OneWay}"
                                SelectsOnInvoked="False"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="More" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </DataTemplate>

        <navViews:MainNavItemTemplateSelector x:Key="MainNavItemTemplateSelector"
                                              StartTemplate="{StaticResource StartNavTemplate}"
                                              HeaderTemplate="{StaticResource SessionsHeaderTemplate}"
                                              ProjectTemplate="{StaticResource ProjectNavTemplate}"
                                              SessionTemplate="{StaticResource SessionNavTemplate}"
                                              MoreTemplate="{StaticResource MoreNavTemplate}" />

        <!-- 极简导航项样式 (Nav Rail) -->
        <Style x:Key="NavRailItemStyle" TargetType="ListViewItem">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="LayoutRoot" Background="{TemplateBinding Background}" Height="64">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="SelectionIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPanel.Foreground" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- 选中状态指示条 -->
                            <Rectangle x:Name="SelectionIndicator"
                                       Width="3" Height="24"
                                       Fill="{ThemeResource AccentBrush}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <ContentPresenter x:Name="ContentPanel"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 会话头部导航项样式 -->
        <!-- 二级导航项样式 (Sub Menu) -->
        
<Style x:Key="SubMenuItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                            <Setter Target="OuterBorder.BorderBrush" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="SubMenuContentPresenter.Foreground" Value="{ThemeResource AccentBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="SubMenuContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProjectGroupItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource SubMenuItemStyle}">
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="SessionSubMenuItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource SubMenuItemStyle}">
            <!-- Keep the container full-width; indent via Padding instead of Margin -->
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="24,10"/>
        </Style>

        <Style x:Key="SubMenuResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Right"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightPanelResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Left"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid x:Name="LayoutRoot">
        <VisualStateManager.VisualStateGroups>
            <!-- Responsive shell layout (NavigationView + TitleBar). -->
            <VisualStateGroup x:Name="WindowWidthStates">
                <!-- Wide: fully expanded fixed pane; show hierarchy inline. -->
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="Left" />
                        <Setter Target="MainNavView.IsPaneOpen" Value="True" />
                        <Setter Target="TopSearchBox.Visibility" Value="Visible" />
                        <Setter Target="TopSearchBox.Width" Value="340" />
                        <Setter Target="ChatNavRoot.IsExpanded" Value="True" />
                    </VisualState.Setters>
                </VisualState>

                <!-- Medium: fixed compact rail + expanded pane (no dimming overlay). -->
                <VisualState x:Name="Medium">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="640" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="LeftCompact" />
                        <Setter Target="MainNavView.IsPaneOpen" Value="False" />
                        <Setter Target="TopSearchBox.Visibility" Value="Visible" />
                        <Setter Target="TopSearchBox.Width" Value="280" />
                        <Setter Target="ChatNavRoot.IsExpanded" Value="False" />
                    </VisualState.Setters>
                </VisualState>

                <!-- Narrow: keep content usable; menu becomes an overlay (minimal). -->
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="LeftMinimal" />
                        <Setter Target="MainNavView.IsPaneOpen" Value="False" />
                        <Setter Target="TopSearchBox.Visibility" Value="Collapsed" />
                        <Setter Target="ChatNavRoot.IsExpanded" Value="False" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Native title bar (full customization) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="Transparent"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Height="48">
            <Grid>
                <!-- Dedicated draggable region (Windows title bar best practice). -->
                <Grid x:Name="TitleBarDragRegion"
                      Background="Transparent" />

                <!-- Interactive content sits above the drag region; keep Background unset so empty space is draggable. -->
                <Grid x:Name="AppTitleBarContent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="TitleBarLeftButtons"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="4"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                    <Button x:Name="TitleBarBackButton"
                            Style="{StaticResource TitleBarCommandButtonStyle}"
                            ToolTipService.ToolTip="返回"
                            Click="OnTitleBarBackClick">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72B;"/>
                    </Button>
                    <Button x:Name="TitleBarToggleLeftNavButton"
                            Style="{StaticResource TitleBarCommandButtonStyle}"
                            ToolTipService.ToolTip="折叠左侧边栏"
                            Click="OnToggleLeftNavClick">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE700;"/>
                    </Button>
                    </StackPanel>

                    <TextBox x:Name="TopSearchBox"
                             Grid.Column="1"
                             Width="340"
                             Height="32"
                             PlaceholderText="搜索"
                             CornerRadius="8"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <ToggleButton x:Name="DiffPanelButton"
                                      Tag="Diff"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      ToolTipService.ToolTip="Diff"
                                      Click="OnRightPanelButtonClick">
                            <!-- SymbolIcon.Symbol must be a valid WinUI Symbol enum value -->
                            <SymbolIcon Symbol="Preview" />
                        </ToggleButton>
                        <ToggleButton x:Name="TodoPanelButton"
                                      Tag="Todo"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      ToolTipService.ToolTip="Todo"
                                      Click="OnRightPanelButtonClick">
                            <SymbolIcon Symbol="Bullets" />
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightPanelColumnDefinition" Width="Auto" />
            </Grid.ColumnDefinitions>

             <NavigationView x:Name="MainNavView"
                             Grid.Column="0"
                             Background="Transparent"
                             CompactPaneLength="72"
                             OpenPaneLength="240"
                             IsPaneOpen="True"
                             IsBackButtonVisible="Collapsed"
                             IsPaneToggleButtonVisible="False"
                             IsSettingsVisible="True"
                             AlwaysShowHeader="False"
                             MenuItemsSource="{x:Bind NavVM.Items, Mode=OneWay}"
                             MenuItemTemplateSelector="{StaticResource MainNavItemTemplateSelector}"
                             SelectedItem="{x:Bind NavVM.SelectedItem, Mode=TwoWay}"
                             SelectionChanged="OnMainNavSelectionChanged"
                             ItemInvoked="OnMainNavItemInvoked"
                             PaneOpened="OnMainNavPaneOpened"
                             PaneClosed="OnMainNavPaneClosed"
                             PaneClosing="OnMainNavPaneClosing">
                <NavigationView.Content>
                    <Frame x:Name="ContentFrame"
                           Background="Transparent" />
                </NavigationView.Content>
            </NavigationView>

            <!-- 右侧边栏：Diff / Todo / Files -->
            <Grid x:Name="RightPanelColumn"
                  Grid.Column="1"
                  Width="320"
                  Background="Transparent"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="1,0,0,0"
                  Visibility="Collapsed">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="RightPanelTranslate" X="0"/>
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="RightPanelTitle"
                           Grid.Row="0"
                           Text=""
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="20,24,16,16" />

                <Grid Grid.Row="1">
                    <Grid x:Name="DiffPanel" Visibility="Collapsed">
                        <TextBlock Text="Diff 面板占位" Opacity="0.7" Margin="20,8" />
                    </Grid>
                    <Grid x:Name="TodoPanel" Visibility="Collapsed">
                        <TextBlock Text="Todo 面板占位" Opacity="0.7" Margin="20,8" />
                    </Grid>
                </Grid>

                <controls:ResizeGrip x:Name="RightPanelResizer"
                                     Grid.RowSpan="2"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch"
                                     Width="6"
                                     Background="Transparent"
                                     Style="{StaticResource RightPanelResizerThumbStyle}"
                                     PointerPressed="OnRightPanelResizerPointerPressed"
                                     PointerMoved="OnRightPanelResizerPointerMoved"
                                     PointerReleased="OnRightPanelResizerPointerReleased"
                                     PointerCaptureLost="OnRightPanelResizerPointerCaptureLost" />
            </Grid>
        </Grid>
    </Grid>
</Page>




