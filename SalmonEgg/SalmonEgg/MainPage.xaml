<Page
    x:Class="SalmonEgg.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels"
    xmlns:nav="using:SalmonEgg.Presentation.ViewModels.Navigation"
    xmlns:navModels="using:SalmonEgg.Presentation.Models.Navigation"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:searchModels="using:SalmonEgg.Presentation.Models.Search"
    xmlns:navViews="using:SalmonEgg.Presentation.Views.Navigation"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:chatVm="using:SalmonEgg.Presentation.ViewModels.Chat"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:PlanStatusToColorConverter x:Key="PlanStatusToColorConverter" />
        <x:Double x:Key="NavCompactPaneLength">72</x:Double>
        <x:Double x:Key="NavOpenPaneLength">300</x:Double>

        <!-- Navigation section header sizing (keep consistent + tweakable in one place) -->
        <x:Double x:Key="NavSectionHeaderMinHeight">32</x:Double>
        <x:Double x:Key="NavSectionHeaderActionButtonSize">24</x:Double>
<x:Double x:Key="NavProjectActionButtonSize">24</x:Double>







        <!-- 会话头部导航项样式 -->


        <DataTemplate x:Key="StartNavTemplate" x:DataType="nav:StartNavItemViewModel">
            <NavigationViewItem Content="{x:Bind Title, Mode=OneWay}"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Home" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </DataTemplate>

        
        
        
        <DataTemplate x:Key="SessionsHeaderTemplate" x:DataType="nav:SessionsHeaderNavItemViewModel">
            <NavigationViewItem MinHeight="{StaticResource NavSectionHeaderMinHeight}"
                                HorizontalContentAlignment="Stretch"
                                Padding="0"
                                SelectsOnInvoked="False"
                                IsTabStop="False"
                                AllowFocusOnInteraction="False"
                                Visibility="{x:Bind IsPaneOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <NavigationViewItem.Resources>
                    <StaticResource x:Key="NavigationViewItemBackgroundPointerOver" ResourceKey="NavigationViewItemBackground" />
                    <StaticResource x:Key="NavigationViewItemBackgroundPressed" ResourceKey="NavigationViewItemBackground" />
                    <StaticResource x:Key="NavigationViewItemBackgroundSelected" ResourceKey="NavigationViewItemBackground" />
                    <StaticResource x:Key="NavigationViewItemForegroundPointerOver" ResourceKey="NavigationViewItemForeground" />
                    <StaticResource x:Key="NavigationViewItemForegroundPressed" ResourceKey="NavigationViewItemForeground" />
                    <StaticResource x:Key="NavigationViewItemForegroundSelected" ResourceKey="NavigationViewItemForeground" />
                </NavigationViewItem.Resources>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                   Style="{StaticResource NavigationViewItemHeaderTextStyle}"
                                   Foreground="{ThemeResource NavigationViewItemHeaderForeground}"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Width="{StaticResource NavSectionHeaderActionButtonSize}"
                                Height="{StaticResource NavSectionHeaderActionButtonSize}"
                                MinWidth="{StaticResource NavSectionHeaderActionButtonSize}"
                                MinHeight="{StaticResource NavSectionHeaderActionButtonSize}"
                                Padding="0"
                                HorizontalAlignment="Right"
                                CornerRadius="{ThemeResource ControlCornerRadius}"
                                Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                BorderBrush="{ThemeResource SubtleFillColorTransparentBrush}"
                                BorderThickness="0"
                                ToolTipService.ToolTip="添加项目"
                                Command="{x:Bind AddProjectCommand}"
                                AutomationProperties.Name="添加项目">
                            <FontIcon Glyph="&#xE710;"
                                      FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      FontSize="14" />
                        </Button>
                    </Grid>
                </NavigationViewItem.Content>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="SessionsCompactAddTemplate" x:DataType="nav:SessionsCompactAddNavItemViewModel">
            <NavigationViewItem SelectsOnInvoked="False"
                                Tag="{x:Bind navModels:NavItemTag.SessionsHeader}"
                                Visibility="{x:Bind IsPaneClosed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Add" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </DataTemplate>




        <DataTemplate x:Key="ProjectNavTemplate" x:DataType="nav:ProjectNavItemViewModel">
            <NavigationViewItem MenuItemsSource="{x:Bind Children, Mode=OneWay}"
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                HorizontalContentAlignment="Stretch"

                                SelectsOnInvoked="False"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Folder" />
                </NavigationViewItem.Icon>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="*"
                          Visibility="{x:Bind IsPaneOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   VerticalAlignment="Center" />
                    </Grid>
                </NavigationViewItem.Content>

                <NavigationViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="新建会话"
                                        Command="{x:Bind CreateSessionCommand}" />
                    </MenuFlyout>
                </NavigationViewItem.ContextFlyout>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="SessionNavTemplate" x:DataType="nav:SessionNavItemViewModel">
            <NavigationViewItem SelectsOnInvoked="True"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Comment" />
                </NavigationViewItem.Icon>

                <NavigationViewItem.Content>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <ProgressRing Width="14"
                                      Height="14"
                                      IsActive="{x:Bind IsPlaceholder, Mode=OneWay}"
                                      Visibility="{x:Bind IsPlaceholder, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Title, Mode=OneWay}"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"/>

                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind RelativeTimeText, Mode=OneWay}"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Opacity="0.55"
                                   Margin="8,0,0,0"/>
                    </Grid>
                </NavigationViewItem.Content>

                <NavigationViewItem.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="重命名…"
                                        Command="{x:Bind RenameCommand}" />
                    </MenuFlyout>
                </NavigationViewItem.ContextFlyout>
            </NavigationViewItem>
        </DataTemplate>

        <DataTemplate x:Key="MoreNavTemplate" x:DataType="nav:MoreSessionsNavItemViewModel">
            <NavigationViewItem Content="{x:Bind Title, Mode=OneWay}"
                                SelectsOnInvoked="False"
                                Tag="{x:Bind navModels:NavItemTag.More(ProjectId)}"
                                ContentTransitions="{x:Bind models:UiMotion.Current.NavItemTransitions, Mode=OneWay}">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="More" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </DataTemplate>

        <navViews:MainNavItemTemplateSelector x:Key="MainNavItemTemplateSelector"
                                              StartTemplate="{StaticResource StartNavTemplate}"
                                              HeaderTemplate="{StaticResource SessionsHeaderTemplate}"
                                              CompactAddTemplate="{StaticResource SessionsCompactAddTemplate}"
                                              ProjectTemplate="{StaticResource ProjectNavTemplate}"
                                              SessionTemplate="{StaticResource SessionNavTemplate}"
                                              MoreTemplate="{StaticResource MoreNavTemplate}" />

        <!-- 极简导航项样式 (Nav Rail) -->
        <Style x:Key="NavRailItemStyle" TargetType="ListViewItem">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="LayoutRoot" Background="{TemplateBinding Background}" Height="64">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="SelectionIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPanel.Foreground" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- 选中状态指示条 -->
                            <Rectangle x:Name="SelectionIndicator"
                                       Width="3" Height="24"
                                       Fill="{ThemeResource AccentBrush}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <ContentPresenter x:Name="ContentPanel"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 会话头部导航项样式 -->
        <!-- 二级导航项样式 (Sub Menu) -->

<Style x:Key="SubMenuItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                            <Setter Target="OuterBorder.BorderBrush" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="SubMenuContentPresenter.Foreground" Value="{ThemeResource AccentBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="SubMenuContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProjectGroupItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource SubMenuItemStyle}">
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="SessionSubMenuItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource SubMenuItemStyle}">
            <!-- Keep the container full-width; indent via Padding instead of Margin -->
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="24,10"/>
        </Style>

        <Style x:Key="SubMenuResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Right"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightPanelResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Left"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid x:Name="LayoutRoot">
        <VisualStateManager.VisualStateGroups>
            <!-- Responsive shell layout (NavigationView + TitleBar). -->
            <VisualStateGroup x:Name="WindowWidthStates">
                <!-- Wide: fully expanded fixed pane; show hierarchy inline. -->
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="Left" />
                        <Setter Target="MainNavView.IsPaneOpen" Value="True" />
                        <Setter Target="TopSearchBox.Visibility" Value="Visible" />
                        <Setter Target="TopSearchBox.Width" Value="340" />
                        <Setter Target="ChatNavRoot.IsExpanded" Value="True" />
                    </VisualState.Setters>
                </VisualState>

                <!-- Medium: fixed compact rail + expanded pane (no dimming overlay). -->
                <VisualState x:Name="Medium">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="640" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="LeftCompact" />
                        <Setter Target="MainNavView.IsPaneOpen" Value="False" />
                        <Setter Target="TopSearchBox.Visibility" Value="Visible" />
                        <Setter Target="TopSearchBox.Width" Value="280" />
                        <Setter Target="ChatNavRoot.IsExpanded" Value="False" />
                    </VisualState.Setters>
                </VisualState>

                <!-- Narrow: keep content usable; menu becomes an overlay (minimal). -->
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="LeftMinimal" />
                        <Setter Target="MainNavView.IsPaneOpen" Value="False" />
                        <Setter Target="TopSearchBox.Visibility" Value="Collapsed" />
                        <Setter Target="ChatNavRoot.IsExpanded" Value="False" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Native title bar (full customization) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="Transparent"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Height="48">
            <Grid>
                <!-- Dedicated draggable region (Windows title bar best practice). -->
                <Grid x:Name="TitleBarDragRegion"
                      Background="Transparent" />

                <!-- Interactive content sits above the drag region; keep Background unset so empty space is draggable. -->
                <Grid x:Name="AppTitleBarContent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="TitleBarLeftButtons"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="4"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                    <Button x:Name="TitleBarBackButton"
                            Style="{StaticResource TitleBarCommandButtonStyle}"
                            ToolTipService.ToolTip="返回"
                            Click="OnTitleBarBackClick">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72B;"/>
                    </Button>
                    <Button x:Name="TitleBarToggleLeftNavButton"
                            Style="{StaticResource TitleBarCommandButtonStyle}"
                            ToolTipService.ToolTip="折叠左侧边栏"
                            Click="OnToggleLeftNavClick">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE700;"/>
                    </Button>
                    </StackPanel>

                    <TextBox x:Name="TopSearchBox"
                             Grid.Column="1"
                             Width="340"
                             Height="32"
                             PlaceholderText="搜索"
                             Text="{x:Bind SearchVM.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             CornerRadius="8"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             GotFocus="OnSearchBoxGotFocus"
                             LostFocus="OnSearchBoxLostFocus">
                        <FlyoutBase.AttachedFlyout>
                            <Flyout Placement="BottomEdgeAlignedLeft" 
                                    AllowFocusOnInteraction="False"
                                    ShowMode="Transient">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style TargetType="FlyoutPresenter">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="MinWidth" Value="420" />
                                        <Setter Property="MaxWidth" Value="420" />
                                        <Setter Property="CornerRadius" Value="8" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Background" Value="{ThemeResource SolidBackgroundFillColorBaseBrush}" />
                                        <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Visibility" Value="{x:Bind SearchVM.HasAnyContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <Grid x:Name="SearchPanelBorder" HorizontalAlignment="Stretch">
                                    <!-- 搜索结果列表 -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400" HorizontalAlignment="Stretch">
                                        <StackPanel HorizontalAlignment="Stretch">
                                            <ItemsControl ItemsSource="{x:Bind SearchVM.ResultGroups, Mode=OneWay}" HorizontalAlignment="Stretch">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="searchModels:SearchResultGroup">
                                                        <StackPanel HorizontalAlignment="Stretch">
                                                            <!-- 分组标题 -->
                                                            <TextBlock Text="{x:Bind Title}"
                                                                       FontSize="12"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                       Margin="16,12,16,4" />

                                                            <!-- 分组项目 -->
                                                            <ItemsControl ItemsSource="{x:Bind Items}" HorizontalAlignment="Stretch">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="searchModels:SearchResultItem">
                                                                        <Button HorizontalAlignment="Stretch"
                                                                                HorizontalContentAlignment="Stretch"
                                                                                Padding="12,8"
                                                                                Margin="4,2"
                                                                                Click="OnSearchResultItemClick"
                                                                                Tag="{x:Bind}"
                                                                                AllowFocusOnInteraction="False">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <Setter Property="Background" Value="Transparent" />
                                                                                    <Setter Property="BorderThickness" Value="0" />
                                                                                    <Setter Property="CornerRadius" Value="4" />
                                                                                </Style>
                                                                            </Button.Style>
                                                                            <Grid HorizontalAlignment="Stretch">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <FontIcon Grid.Column="0"
                                                                                          Glyph="{x:Bind IconGlyph}"
                                                                                          Margin="0,0,12,0"
                                                                                          FontSize="16"
                                                                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                                                <StackPanel Grid.Column="1" HorizontalAlignment="Stretch">
                                                                                    <TextBlock Text="{x:Bind Title}"
                                                                                               FontSize="14" 
                                                                                               TextTrimming="CharacterEllipsis"/>
                                                                                    <TextBlock Text="{x:Bind Subtitle}"
                                                                                               FontSize="12"
                                                                                               Opacity="0.7"
                                                                                               TextTrimming="CharacterEllipsis"
                                                                                               Visibility="{x:Bind Subtitle, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- 最近搜索建议 -->
                                            <StackPanel Visibility="{x:Bind SearchVM.ShowSuggestions, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                                        Margin="0,0,0,8"
                                                        HorizontalAlignment="Stretch">
                                                <TextBlock Text="最近搜索"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           Margin="16,12,16,4" />
                                                <ItemsControl ItemsSource="{x:Bind SearchVM.RecentSearches, Mode=OneWay}" HorizontalAlignment="Stretch">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <Button Content="{x:Bind}"
                                                                    Padding="12,8"
                                                                    Margin="4,2"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Left"
                                                                    Click="OnSearchHistoryItemClick"
                                                                    Tag="{x:Bind}"
                                                                    AllowFocusOnInteraction="False">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Background" Value="Transparent" />
                                                                        <Setter Property="BorderThickness" Value="0" />
                                                                        <Setter Property="CornerRadius" Value="4" />
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </StackPanel>
                                    </ScrollViewer>

                                    <!-- 无结果提示 -->
                                    <TextBlock Text="无搜索结果"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,40"
                                               Opacity="0.6"
                                               Visibility="{x:Bind SearchVM.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                </Grid>
                            </Flyout>
                        </FlyoutBase.AttachedFlyout>
                    </TextBox>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <ToggleButton x:Name="DiffPanelButton"
                                      Tag="Diff"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      ToolTipService.ToolTip="Diff"
                                      Click="OnRightPanelButtonClick">
                            <!-- SymbolIcon.Symbol must be a valid WinUI Symbol enum value -->
                            <SymbolIcon Symbol="Preview" />
                        </ToggleButton>
                        <ToggleButton x:Name="TodoPanelButton"
                                      Tag="Todo"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      ToolTipService.ToolTip="Todo"
                                      Click="OnRightPanelButtonClick">
                            <SymbolIcon Symbol="Bullets" />
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RightPanelColumnDefinition" Width="Auto" />
            </Grid.ColumnDefinitions>

            <NavigationView x:Name="MainNavView"
                             Grid.Column="0"
                             Background="Transparent"
                             CompactPaneLength="{StaticResource NavCompactPaneLength}"
                             OpenPaneLength="{StaticResource NavOpenPaneLength}"
                             IsPaneOpen="True"
                             IsBackButtonVisible="Collapsed"
                             IsPaneToggleButtonVisible="False"
                             IsSettingsVisible="True"
                             AlwaysShowHeader="False"
                             MenuItemsSource="{x:Bind NavVM.Items, Mode=OneWay}"
                             MenuItemTemplateSelector="{StaticResource MainNavItemTemplateSelector}"
                             SelectedItem="{x:Bind NavVM.SelectedItem, Mode=TwoWay}"
                             SelectionChanged="OnMainNavSelectionChanged"
                             ItemInvoked="OnMainNavItemInvoked"
                             DisplayModeChanged="OnMainNavDisplayModeChanged"
                             PaneOpened="OnMainNavPaneOpened"
                             PaneClosed="OnMainNavPaneClosed"
                             PaneClosing="OnMainNavPaneClosing">
                <NavigationView.Content>
                    <Frame x:Name="ContentFrame"
                           Background="Transparent"
                           ContentTransitions="{x:Bind models:UiMotion.Current.PageTransitions, Mode=OneWay}" />
                </NavigationView.Content>
            </NavigationView>

            <controls:ResizeGrip x:Name="LeftNavResizer"
                                 Grid.Column="0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Stretch"
                                 Width="6"
                                 Background="Transparent"
                                 Style="{StaticResource SubMenuResizerThumbStyle}"
                                 Visibility="Collapsed"
                                 PointerPressed="OnLeftNavResizerPointerPressed"
                                 PointerMoved="OnLeftNavResizerPointerMoved"
                                 PointerReleased="OnLeftNavResizerPointerReleased"
                                 PointerCaptureLost="OnLeftNavResizerPointerCaptureLost">
                <controls:ResizeGrip.RenderTransform>
                    <TranslateTransform x:Name="LeftNavResizerTransform" />
                </controls:ResizeGrip.RenderTransform>
            </controls:ResizeGrip>

            <!-- 右侧边栏：Diff / Todo / Files -->
            <Grid x:Name="RightPanelColumn"
                  Grid.Column="1"
                  Width="320"
                  Background="Transparent"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="1,0,0,0"
                  Visibility="Collapsed">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="RightPanelTranslate" X="0"/>
                </Grid.RenderTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="RightPanelTitle"
                           Grid.Row="0"
                           Text=""
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="20,24,16,16" />

                <Grid Grid.Row="1">
                    <Grid x:Name="DiffPanel" Visibility="Collapsed">
                        <TextBlock Text="Diff 面板占位" Opacity="0.7" Margin="20,8" />
                    </Grid>
                    <Grid x:Name="TodoPanel" Visibility="Collapsed">
                        <Grid>
                            <Grid Visibility="{x:Bind ChatVM.ShouldShowPlanList, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ListView ItemsSource="{x:Bind ChatVM.CurrentPlan, Mode=OneWay}"
                                          SelectionMode="None"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Margin="12,0,12,12">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="chatVm:PlanEntryViewModel">
                                            <Border Margin="0,0,0,8"
                                                    Padding="8"
                                                    CornerRadius="8"
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Width="8"
                                                             Height="8"
                                                             VerticalAlignment="Center"
                                                             Fill="{x:Bind Status, Converter={StaticResource PlanStatusToColorConverter}}" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{x:Bind Content}"
                                                               Margin="8,0,8,0"
                                                               TextWrapping="Wrap" />
                                                    <StackPanel Grid.Column="2"
                                                                Orientation="Vertical"
                                                                HorizontalAlignment="Right">
                                                        <TextBlock Text="{x:Bind StatusDisplayName}"
                                                                   FontSize="12"
                                                                   Opacity="0.8"
                                                                   HorizontalAlignment="Right" />
                                                        <TextBlock Text="{x:Bind PriorityDisplayName}"
                                                                   FontSize="12"
                                                                   Opacity="0.6"
                                                                   HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                            <StackPanel Visibility="{x:Bind ChatVM.ShouldShowPlanEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="20,0">
                                <TextBlock Text="暂无计划"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="等待 Agent 更新"
                                           Opacity="0.7"
                                           Margin="0,6,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>

                <controls:ResizeGrip x:Name="RightPanelResizer"
                                     Grid.RowSpan="2"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch"
                                     Width="6"
                                     Background="Transparent"
                                     Style="{StaticResource RightPanelResizerThumbStyle}"
                                     PointerPressed="OnRightPanelResizerPointerPressed"
                                     PointerMoved="OnRightPanelResizerPointerMoved"
                                     PointerReleased="OnRightPanelResizerPointerReleased"
                                     PointerCaptureLost="OnRightPanelResizerPointerCaptureLost" />
            </Grid>
        </Grid>
    </Grid>
</Page>




