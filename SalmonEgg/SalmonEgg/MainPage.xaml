<Page
    x:Class="SalmonEgg.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels"
    xmlns:nav="using:SalmonEgg.Presentation.ViewModels.Navigation"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <!-- 极简导航项样式 (Nav Rail) -->
        <Style x:Key="NavRailItemStyle" TargetType="ListViewItem">
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="LayoutRoot" Background="{TemplateBinding Background}" Height="64">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="SelectionIndicator.Visibility" Value="Visible"/>
                                            <Setter Target="ContentPanel.Foreground" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="LayoutRoot.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- 选中状态指示条 -->
                            <Rectangle x:Name="SelectionIndicator"
                                       Width="3" Height="24"
                                       Fill="{ThemeResource AccentBrush}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                            <ContentPresenter x:Name="ContentPanel"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 二级导航项样式 (Sub Menu) -->
        <Style x:Key="SubMenuItemStyle" TargetType="ListViewItem">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="OuterBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="OuterBorder.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}"/>
                                            <Setter Target="OuterBorder.BorderBrush" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="SubMenuContentPresenter.Foreground" Value="{ThemeResource AccentBrush}"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter x:Name="SubMenuContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProjectGroupItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource SubMenuItemStyle}">
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="SessionSubMenuItemStyle" TargetType="ListViewItem" BasedOn="{StaticResource SubMenuItemStyle}">
            <!-- Keep the container full-width; indent via Padding instead of Margin -->
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="24,10"/>
        </Style>

        <Style x:Key="SubMenuResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Right"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightPanelResizerThumbStyle" TargetType="controls:ResizeGrip">
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ResizeGrip">
                        <Grid x:Name="Root" Background="Transparent">
                            <Rectangle x:Name="Grip"
                                       Width="1"
                                       HorizontalAlignment="Left"
                                       Fill="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Grip.Fill" Value="{ThemeResource AccentBrush}"/>
                                            <Setter Target="Grip.Width" Value="2"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid x:Name="LayoutRoot">
        <VisualStateManager.VisualStateGroups>
            <!-- Responsive shell layout (NavigationView + TitleBar). -->
            <VisualStateGroup x:Name="WindowWidthStates">
                <!-- Narrow: keep content usable; menu becomes an overlay (minimal). -->
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="LeftMinimal" />
                        <Setter Target="MainNavView.IsPaneOpen" Value="False" />
                        <Setter Target="TopSearchBox.Visibility" Value="Collapsed" />
                        <Setter Target="ChatNavRoot.IsExpanded" Value="False" />
                        <Setter Target="SettingsNavRoot.IsExpanded" Value="False" />
                    </VisualState.Setters>
                </VisualState>

                <!-- Medium: fixed compact rail + expanded pane (no dimming overlay). -->
                <VisualState x:Name="Medium">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="640" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="LeftCompact" />
                        <Setter Target="MainNavView.IsPaneOpen" Value="True" />
                        <Setter Target="TopSearchBox.Visibility" Value="Visible" />
                        <Setter Target="TopSearchBox.Width" Value="280" />
                        <Setter Target="ChatNavRoot.IsExpanded" Value="False" />
                        <Setter Target="SettingsNavRoot.IsExpanded" Value="False" />
                    </VisualState.Setters>
                </VisualState>

                <!-- Wide: fully expanded fixed pane; show hierarchy inline. -->
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1000" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MainNavView.PaneDisplayMode" Value="Left" />
                        <Setter Target="MainNavView.IsPaneOpen" Value="True" />
                        <Setter Target="TopSearchBox.Visibility" Value="Visible" />
                        <Setter Target="TopSearchBox.Width" Value="340" />
                        <Setter Target="ChatNavRoot.IsExpanded" Value="True" />
                        <Setter Target="SettingsNavRoot.IsExpanded" Value="True" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Native title bar (full customization) -->
        <Border x:Name="AppTitleBar"
                Grid.Row="0"
                Background="Transparent"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Height="48">
            <Grid>
                <!-- Dedicated draggable region (Windows title bar best practice). -->
                <Grid x:Name="TitleBarDragRegion"
                      Background="Transparent" />

                <!-- Interactive content sits above the drag region; keep Background unset so empty space is draggable. -->
                <Grid x:Name="AppTitleBarContent">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel x:Name="TitleBarLeftButtons"
                                Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="4"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                    <Button x:Name="TitleBarBackButton"
                            Style="{StaticResource TitleBarCommandButtonStyle}"
                            ToolTipService.ToolTip="返回"
                            Click="OnTitleBarBackClick">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72B;"/>
                    </Button>
                    <Button x:Name="TitleBarToggleLeftNavButton"
                            Style="{StaticResource TitleBarCommandButtonStyle}"
                            ToolTipService.ToolTip="折叠左侧边栏"
                            Click="OnToggleLeftNavClick">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE700;"/>
                    </Button>
                    </StackPanel>

                    <TextBox x:Name="TopSearchBox"
                             Grid.Column="1"
                             Width="340"
                             Height="32"
                             PlaceholderText="搜索"
                             CornerRadius="8"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <ToggleButton x:Name="DiffPanelButton"
                                      Tag="Diff"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      ToolTipService.ToolTip="Diff"
                                      Click="OnRightPanelButtonClick">
                            <SymbolIcon Symbol="Sync" />
                        </ToggleButton>
                        <ToggleButton x:Name="TodoPanelButton"
                                      Tag="Todo"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      ToolTipService.ToolTip="Todo"
                                      Click="OnRightPanelButtonClick">
                            <SymbolIcon Symbol="Accept" />
                        </ToggleButton>
                        <ToggleButton x:Name="FilesPanelButton"
                                      Tag="Files"
                                      Style="{StaticResource TitleBarToggleButtonStyle}"
                                      ToolTipService.ToolTip="Files"
                                      Click="OnRightPanelButtonClick">
                            <SymbolIcon Symbol="Folder" />
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

             <NavigationView x:Name="MainNavView"
                             Grid.Column="0"
                             Background="Transparent"
                             CompactPaneLength="72"
                             OpenPaneLength="240"
                             IsPaneOpen="True"
                             IsBackButtonVisible="Collapsed"
                             IsPaneToggleButtonVisible="False"
                             IsSettingsVisible="False"
                             AlwaysShowHeader="False"
                             SelectionChanged="OnMainNavSelectionChanged"
                             ItemInvoked="OnMainNavItemInvoked"
                             PaneOpened="OnMainNavPaneOpened"
                             PaneClosed="OnMainNavPaneClosed"
                             PaneClosing="OnMainNavPaneClosing">
                <NavigationView.MenuItems>
                     <NavigationViewItem x:Name="ChatNavRoot"
                                         Content="对话"
                                         Tag="Chat">
                         <NavigationViewItem.Icon>
                             <FontIcon Glyph="&#xE8BD;" />
                         </NavigationViewItem.Icon>
                     </NavigationViewItem>

                    <NavigationViewItemSeparator />

                     <NavigationViewItem x:Name="SettingsNavRoot"
                                         Content="设置"
                                         Tag="Settings">
                         <NavigationViewItem.Icon>
                             <FontIcon Glyph="&#xE713;" />
                         </NavigationViewItem.Icon>
                         <NavigationViewItem.MenuItems>
                            <NavigationViewItem x:Name="GeneralSettingsNavItem" Content="常规" Tag="General" />
                            <NavigationViewItem x:Name="AppearanceSettingsNavItem" Content="外观" Tag="Appearance" />
                            <NavigationViewItem x:Name="AgentAcpSettingsNavItem" Content="Agent (ACP)" Tag="AgentAcp" />
                            <NavigationViewItem x:Name="DataStorageSettingsNavItem" Content="数据与存储" Tag="DataStorage" />
                            <NavigationViewItem x:Name="ShortcutsSettingsNavItem" Content="快捷键" Tag="Shortcuts" />
                            <NavigationViewItem x:Name="DiagnosticsSettingsNavItem" Content="诊断与日志" Tag="Diagnostics" />
                            <NavigationViewItem x:Name="AboutSettingsNavItem" Content="关于" Tag="About" />
                         </NavigationViewItem.MenuItems>
                     </NavigationViewItem>
                </NavigationView.MenuItems>

                <NavigationView.Content>
                    <Frame x:Name="ContentFrame"
                           Background="Transparent" />
                </NavigationView.Content>
            </NavigationView>

            <!-- 右侧边栏：Diff / Todo / Files -->
            <Grid x:Name="RightPanelColumn"
                  Grid.Column="1"
                  Width="320"
                  Background="Transparent"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="1,0,0,0"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="RightPanelTitle"
                           Grid.Row="0"
                           Text=""
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="20,24,16,16" />

                <Grid Grid.Row="1">
                    <Grid x:Name="DiffPanel" Visibility="Collapsed">
                        <TextBlock Text="Diff 面板占位" Opacity="0.7" Margin="20,8" />
                    </Grid>
                    <Grid x:Name="TodoPanel" Visibility="Collapsed">
                        <TextBlock Text="Todo 面板占位" Opacity="0.7" Margin="20,8" />
                    </Grid>
                    <Grid x:Name="FilesPanel" Visibility="Collapsed">
                        <TextBlock Text="Files 面板占位" Opacity="0.7" Margin="20,8" />
                    </Grid>
                </Grid>

                <controls:ResizeGrip x:Name="RightPanelResizer"
                                     Grid.RowSpan="2"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Stretch"
                                     Width="6"
                                     Background="Transparent"
                                     Style="{StaticResource RightPanelResizerThumbStyle}"
                                     PointerPressed="OnRightPanelResizerPointerPressed"
                                     PointerMoved="OnRightPanelResizerPointerMoved"
                                     PointerReleased="OnRightPanelResizerPointerReleased"
                                     PointerCaptureLost="OnRightPanelResizerPointerCaptureLost" />
            </Grid>
        </Grid>
    </Grid>
</Page>
