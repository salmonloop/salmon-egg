<Page
    x:Class="SalmonEgg.Presentation.Views.Start.StartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:domain="using:SalmonEgg.Domain.Models"
    xmlns:local_vm="using:SalmonEgg.Presentation.ViewModels.Start"
    xmlns:chat_vm="using:SalmonEgg.Presentation.ViewModels.Chat"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="HeroSuggestionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="MinWidth" Value="216"/>
            <Setter Property="MinHeight" Value="112"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

    </Page.Resources>

    <Grid x:Name="StartRoot"
          RowDefinitions="*,Auto"
          Background="Transparent"
          Padding="24,20,24,24">

        <Grid x:Name="HeroLayer"
              Grid.Row="0"
              Margin="0,28,0,24"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="HeroScaleTransform" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="HeroTranslateTransform" Y="0" />
                </TransformGroup>
            </Grid.RenderTransform>
            <StackPanel MaxWidth="980"
                        HorizontalAlignment="Center"
                        Spacing="28">
                <StackPanel x:Name="HeroChromeHost"
                            HorizontalAlignment="Center"
                            Spacing="12">
                    <TextBlock x:Uid="Start_Title"
                               Text="Salmon Egg"
                               FontSize="64"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               AutomationProperties.AutomationId="StartView.Title">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{ThemeResource SystemAccentColor}" Offset="0" />
                                <GradientStop Color="{ThemeResource SystemAccentColorLight2}" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock x:Uid="Start_Subtitle"
                               Text="你的 AI 好鲑鲑"
                               FontSize="18"
                               Opacity="0.6"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ListView x:Name="HeroSuggestionsList"
                          AutomationProperties.AutomationId="StartView.Suggestions"
                          HorizontalAlignment="Center"
                          ItemsSource="{x:Bind ViewModel.Suggestions, Mode=OneWay}"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          XYFocusKeyboardNavigation="Enabled"
                          IsTabStop="False"
                          ContainerContentChanging="OnHeroSuggestionsContainerContentChanging"
                          ScrollViewer.HorizontalScrollMode="Enabled"
                          ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                          ScrollViewer.VerticalScrollMode="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Disabled"
                          ItemClick="OnHeroSuggestionItemClick">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsStackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Margin" Value="0,0,14,0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local_vm:QuickSuggestionViewModel">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="18,14"
                                    MinWidth="216"
                                    MinHeight="112">
                                <StackPanel Spacing="10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="{x:Bind Icon, Mode=OneWay}"
                                                  FontSize="18"
                                                  Foreground="{ThemeResource AccentBrush}" />
                                        <TextBlock x:Uid="Start_QuickLaunchLabel"
                                                   Text="Quick Launch"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}"
                                               FontSize="12"
                                               MaxLines="2"
                                               TextWrapping="WrapWholeWords"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1"
              RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <InfoBar Grid.Row="0"
                     Margin="24,0,24,0"
                     Severity="Error"
                     IsOpen="{x:Bind ViewModel.HasStartSessionDraftError, Mode=OneWay}"
                     Message="{x:Bind ViewModel.StartSessionDraftErrorMessage, Mode=OneWay}" />

            <controls:ChatInputArea x:Name="ComposerShell"
                                    Grid.Row="1"
                                    ViewModel="{x:Bind ViewModel.Chat, Mode=OneWay}"
                                    IsEnabled="{x:Bind ViewModel.IsInputEnabled, Mode=OneWay}"
                                    SubmitCommand="{x:Bind ViewModel.StartSessionAndSendCommand}"
                                    IsSubmitButtonEnabled="{x:Bind ViewModel.CanStartSessionAndSendUi, Mode=OneWay}"
                                    InputBoxAutomationId="StartView.PromptBox"
                                    ShowAgentSelector="True"
                                    AgentSelectorItemsSource="{x:Bind ViewModel.StartAgentSelectorItems, Mode=OneWay}"
                                    SelectedAgentSelectorItem="{x:Bind ViewModel.SelectedStartAgentSelectorItem, Mode=OneWay}"
                                    AgentSelectionCommand="{x:Bind ViewModel.SelectStartAgentDisplayCommand}"
                                    AgentSelectorAutomationId="StartView.AgentSelector"
                                    ShowModeSelector="True"
                                    ModeSelectorItemsSource="{x:Bind ViewModel.StartModeSelectorItems, Mode=OneWay}"
                                    SelectedModeSelectorItem="{x:Bind ViewModel.SelectedStartModeSelectorItem, Mode=OneWay}"
                                    ModeSelectionCommand="{x:Bind ViewModel.SelectStartModeDisplayCommand}"
                                    IsModeSelectorEnabled="{x:Bind ViewModel.IsStartModeSelectorEnabled, Mode=OneWay}"
                                    ModeSelectorAutomationId="StartView.ModeSelector"
                                    ShowProjectSelector="True"
                                    ProjectSelectorItemsSource="{x:Bind ViewModel.StartProjectSelectorItems, Mode=OneWay}"
                                    SelectedProjectSelectorItem="{x:Bind ViewModel.SelectedStartProjectSelectorItem, Mode=OneWay}"
                                    ProjectSelectionCommand="{x:Bind ViewModel.SelectStartProjectDisplayCommand}"
                                    ProjectSelectorAutomationId="StartView.ProjectSelector" />
        </Grid>

        <Grid Grid.RowSpan="2"
              Background="{ThemeResource AppOverlayScrimBrush}"
              Visibility="{x:Bind ViewModel.IsStarting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressRing IsActive="True" Width="48" Height="48"/>
        </Grid>
    </Grid>
</Page>
