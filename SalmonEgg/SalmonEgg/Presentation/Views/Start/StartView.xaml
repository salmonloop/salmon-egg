<Page
    x:Class="SalmonEgg.Presentation.Views.Start.StartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:domain="using:SalmonEgg.Domain.Models"
    xmlns:local_vm="using:SalmonEgg.Presentation.ViewModels.Start"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="HeroSuggestionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="MinWidth" Value="216"/>
            <Setter Property="MinHeight" Value="112"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
        </Style>

    </Page.Resources>

    <Grid x:Name="StartRoot"
          RowDefinitions="*,Auto"
          Background="Transparent"
          Padding="24,20,24,24"
          PointerPressed="OnRootPointerPressed"
          Transitions="{x:Bind Motion.PageTransitions, Mode=OneWay}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="ComposerLifecycleStates">
                <VisualState x:Name="StageCollapsed">
                    <VisualState.Setters>
                        <Setter Target="ComposerShell.Padding" Value="16,12" />
                        <Setter Target="StartPromptBox.MinHeight" Value="44" />
                    </VisualState.Setters>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="HeroLayer" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroTranslateTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerTranslateTransform" Storyboard.TargetProperty="Y" To="0" Duration="0:0:0.22" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="StagePrimed">
                    <VisualState.Setters>
                        <Setter Target="ComposerShell.Padding" Value="18,14" />
                        <Setter Target="StartPromptBox.MinHeight" Value="52" />
                    </VisualState.Setters>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="HeroLayer" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroTranslateTransform" Storyboard.TargetProperty="Y" To="-6" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerTranslateTransform" Storyboard.TargetProperty="Y" To="-6" Duration="0:0:0.22" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="StageInteracting">
                    <VisualState.Setters>
                        <Setter Target="ComposerShell.Padding" Value="20,16" />
                        <Setter Target="StartPromptBox.MinHeight" Value="60" />
                    </VisualState.Setters>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="HeroLayer" Storyboard.TargetProperty="Opacity" To="0.98" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleX" To="0.992" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleY" To="0.992" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroTranslateTransform" Storyboard.TargetProperty="Y" To="-12" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleX" To="1.045" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleY" To="1.045" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerTranslateTransform" Storyboard.TargetProperty="Y" To="-12" Duration="0:0:0.22" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="StagePopupEngaged">
                    <VisualState.Setters>
                        <Setter Target="ComposerShell.Padding" Value="20,16" />
                        <Setter Target="StartPromptBox.MinHeight" Value="60" />
                    </VisualState.Setters>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="HeroLayer" Storyboard.TargetProperty="Opacity" To="0.96" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleX" To="0.99" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleY" To="0.99" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroTranslateTransform" Storyboard.TargetProperty="Y" To="-14" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleX" To="1.05" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleY" To="1.05" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerTranslateTransform" Storyboard.TargetProperty="Y" To="-13" Duration="0:0:0.22" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="StageExpandedIdle">
                    <VisualState.Setters>
                        <Setter Target="ComposerShell.Padding" Value="20,16" />
                        <Setter Target="StartPromptBox.MinHeight" Value="60" />
                    </VisualState.Setters>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="HeroLayer" Storyboard.TargetProperty="Opacity" To="0.98" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleX" To="0.994" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleY" To="0.994" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroTranslateTransform" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleX" To="1.04" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerTranslateTransform" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.22" />
                    </Storyboard>
                </VisualState>
                <VisualState x:Name="StageSubmitting">
                    <VisualState.Setters>
                        <Setter Target="ComposerShell.Padding" Value="20,16" />
                        <Setter Target="StartPromptBox.MinHeight" Value="60" />
                    </VisualState.Setters>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="HeroLayer" Storyboard.TargetProperty="Opacity" To="0.94" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleX" To="0.99" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroScaleTransform" Storyboard.TargetProperty="ScaleY" To="0.99" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="HeroTranslateTransform" Storyboard.TargetProperty="Y" To="-10" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleX" To="1.035" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerScaleTransform" Storyboard.TargetProperty="ScaleY" To="1.035" Duration="0:0:0.22" />
                        <DoubleAnimation Storyboard.TargetName="ComposerTranslateTransform" Storyboard.TargetProperty="Y" To="-9" Duration="0:0:0.22" />
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid x:Name="HeroLayer"
              Grid.Row="0"
              Margin="0,28,0,24"
              VerticalAlignment="Center"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="HeroScaleTransform" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="HeroTranslateTransform" Y="0" />
                </TransformGroup>
            </Grid.RenderTransform>
            <StackPanel MaxWidth="980"
                        HorizontalAlignment="Center"
                        Spacing="28">
                <StackPanel x:Name="HeroChromeHost"
                            x:Load="{x:Bind ViewModel.ShowHeroChrome, Mode=OneWay}"
                            HorizontalAlignment="Center"
                            Spacing="12">
                    <TextBlock x:Uid="Start_Title"
                               Text="Salmon Egg"
                               FontSize="64"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               AutomationProperties.AutomationId="StartView.Title">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="{ThemeResource SystemAccentColor}" Offset="0" />
                                <GradientStop Color="{ThemeResource SystemAccentColorLight2}" Offset="1" />
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="你的 AI 好鲑鲑"
                               FontSize="18"
                               Opacity="0.6"
                               FontWeight="Medium"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ScrollViewer HorizontalScrollMode="Enabled"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Disabled"
                              XYFocusKeyboardNavigation="Enabled">
                    <ItemsControl x:Name="HeroSuggestionsHost"
                                  HorizontalAlignment="Center"
                                  ItemsSource="{x:Bind ViewModel.Suggestions, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="14"
                                            HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local_vm:QuickSuggestionViewModel">
                                <Button Style="{StaticResource HeroSuggestionButtonStyle}"
                                        Command="{x:Bind ActionCommand}"
                                        CommandParameter="{x:Bind}">
                                    <StackPanel Spacing="10">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="{x:Bind Icon, Mode=OneWay}"
                                                      FontSize="18"
                                                      Foreground="{ThemeResource AccentBrush}" />
                                            <TextBlock Text="Quick Launch"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                                        <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}"
                                                   FontSize="12"
                                                   MaxLines="2"
                                                   TextWrapping="WrapWholeWords"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Grid>

        <Border x:Name="ComposerShell"
                Grid.Row="1"
                MaxWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
                HorizontalAlignment="Center"
                BorderThickness="1"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                CornerRadius="20"
                Padding="16,12"
                PointerPressed="OnComposerShellPointerPressed"
                RenderTransformOrigin="0.5,1">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="ComposerScaleTransform" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="ComposerTranslateTransform" Y="0" />
                </TransformGroup>
            </Border.RenderTransform>
            <Grid RowDefinitions="Auto,Auto"
                  RowSpacing="12"
                  XYFocusKeyboardNavigation="Enabled">
                <Grid Grid.Row="0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="12"
                      XYFocusKeyboardNavigation="Enabled">
                    <TextBox x:Name="StartPromptBox"
                             x:Uid="ChatInputBox"
                             Text="{x:Bind ViewModel.StartPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="44"
                             MaxHeight="240"
                             MaxLength="4000"
                             BorderThickness="0"
                             Background="Transparent"
                             IsEnabled="{x:Bind ViewModel.IsInputEnabled, Mode=OneWay}"
                             GotFocus="OnComposerInteractiveElementGotFocus"
                             LostFocus="OnComposerInteractiveElementLostFocus">
                        <TextBox.Resources>
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                            <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                            <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                        </TextBox.Resources>
                    </TextBox>

                    <Button Grid.Column="1"
                            x:Uid="SendButton"
                            Content="&#xE724;"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            Width="44"
                            Height="44"
                            MinWidth="44"
                            MinHeight="44"
                            Padding="0"
                            CornerRadius="22"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.StartSessionAndSendCommand}"
                            GotFocus="OnComposerInteractiveElementGotFocus"
                            LostFocus="OnComposerInteractiveElementLostFocus" />
                </Grid>

                <Grid x:Name="ExpandedAgentRow"
                      Grid.Row="1"
                      x:Load="{x:Bind ViewModel.IsComposerExpanded, Mode=OneWay}"
                      ColumnDefinitions="*,*,Auto"
                      ColumnSpacing="10"
                      XYFocusKeyboardNavigation="Enabled">
                    <ComboBox x:Name="StartAgentSelector"
                              Grid.Column="0"
                              AutomationProperties.AutomationId="StartView.AgentSelector"
                              ItemsSource="{x:Bind ViewModel.Chat.AcpProfileList, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.Chat.SelectedAcpProfile, Mode=TwoWay}"
                              MinWidth="160"
                              MaxWidth="320"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              FontSize="12"
                              Background="Transparent"
                              BorderThickness="0"
                              DropDownOpened="OnComposerSelectorDropDownOpened"
                              DropDownClosed="OnComposerSelectorDropDownClosed"
                              GotFocus="OnComposerInteractiveElementGotFocus"
                              LostFocus="OnComposerInteractiveElementLostFocus">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="domain:ServerConfiguration">
                                <TextBlock Text="{x:Bind Name, Mode=OneTime}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox x:Name="StartProjectSelector"
                              Grid.Column="1"
                              AutomationProperties.AutomationId="StartView.ProjectSelector"
                              ItemsSource="{x:Bind ViewModel.StartProjectOptions, Mode=OneWay}"
                              SelectedValuePath="ProjectId"
                              SelectedValue="{x:Bind ViewModel.SelectedStartProjectId, Mode=TwoWay}"
                              DisplayMemberPath="DisplayName"
                              MinWidth="160"
                              MaxWidth="320"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              FontSize="12"
                              Background="Transparent"
                              BorderThickness="0"
                              DropDownOpened="OnComposerSelectorDropDownOpened"
                              DropDownClosed="OnComposerSelectorDropDownClosed"
                              GotFocus="OnComposerInteractiveElementGotFocus"
                              LostFocus="OnComposerInteractiveElementLostFocus" />

                    <Border Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            Background="{ThemeResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10,6"
                            Visibility="{x:Bind ViewModel.FreezeComposerInteractions, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <ProgressRing IsActive="True"
                                          Width="12"
                                          Height="12" />
                            <TextBlock Text="Launching"
                                       FontSize="11"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.RowSpan="2"
              Background="{ThemeResource AppOverlayScrimBrush}"
              Visibility="{x:Bind ViewModel.IsStarting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressRing IsActive="True" Width="48" Height="48"/>
        </Grid>
    </Grid>
</Page>
