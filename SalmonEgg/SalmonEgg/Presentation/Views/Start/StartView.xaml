<Page
    x:Class="SalmonEgg.Presentation.Views.Start.StartView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:start="using:SalmonEgg.Presentation.ViewModels.Start"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="QuickEntryCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="MinHeight" Value="92"/>
        </Style>
    </Page.Resources>

    <Grid RowDefinitions="*,Auto,Auto"
          Transitions="{x:Bind Motion.PageTransitions, Mode=OneWay}">
        <Grid Grid.Row="0"
              VerticalAlignment="Center"
              Margin="20,20,20,0">
            <StackPanel HorizontalAlignment="Center"
                        Spacing="12">
                <TextBlock Text="Salmon Egg"
                           x:Uid="Start_Title"
                           FontSize="56"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           AutomationProperties.Name="Salmon Egg 欢迎标题"/>
                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Center">
                    <TextBlock Text="项目"
                               FontSize="13"
                               Opacity="0.7"
                               VerticalAlignment="Center"/>
                    <ComboBox Width="240"
                              ItemsSource="{x:Bind ViewModel.ProjectOptions, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedProjectOption, Mode=TwoWay}"
                              PlaceholderText="选择项目">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="start:ProjectOptionViewModel">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- 智能推荐快速入口（占位符） -->
        <Grid Grid.Row="1"
              Margin="20,0,20,12"
              MaxWidth="{x:Bind models:UiLayout.ContentMaxWidth}"
              HorizontalAlignment="Center"
              ColumnSpacing="12"
              ColumnDefinitions="*,*,*">
            <Button Grid.Column="0"
                    x:Uid="Start_Quick1"
                    Style="{StaticResource QuickEntryCardButtonStyle}"
                    IsEnabled="False"
                    AutomationProperties.Name="智能推荐入口 1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <SymbolIcon Symbol="Home" />
                    <StackPanel>
                        <TextBlock x:Uid="Start_Quick1Title" Text="智能推荐 1" FontWeight="SemiBold"/>
                        <TextBlock x:Uid="Start_Quick1Subtitle" Text="占位符" Opacity="0.7" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Button>

            <Button Grid.Column="1"
                    x:Uid="Start_Quick2"
                    Style="{StaticResource QuickEntryCardButtonStyle}"
                    IsEnabled="False"
                    AutomationProperties.Name="智能推荐入口 2">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <SymbolIcon Symbol="Bullets" />
                    <StackPanel>
                        <TextBlock x:Uid="Start_Quick2Title" Text="智能推荐 2" FontWeight="SemiBold"/>
                        <TextBlock x:Uid="Start_Quick2Subtitle" Text="占位符" Opacity="0.7" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    x:Uid="Start_Quick3"
                    Style="{StaticResource QuickEntryCardButtonStyle}"
                    IsEnabled="False"
                    AutomationProperties.Name="智能推荐入口 3">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <SymbolIcon Symbol="Document" />
                    <StackPanel>
                        <TextBlock x:Uid="Start_Quick3Title" Text="智能推荐 3" FontWeight="SemiBold"/>
                        <TextBlock x:Uid="Start_Quick3Subtitle" Text="占位符" Opacity="0.7" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Button>
        </Grid>

        <!-- 底部输入区（复用对话页组件） -->
        <controls:ChatInputArea Grid.Row="2"
                                ViewModel="{x:Bind ViewModel.Chat, Mode=OneWay}"
                                SubmitCommand="{x:Bind ViewModel.StartSessionAndSendCommand}" />

        <!-- 启动/连接遮罩 -->
        <Grid Grid.RowSpan="3"
              Background="#40000000"
              Visibility="{x:Bind ViewModel.IsStarting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True"
                         Width="120"
                         Height="4"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>
