<ContentDialog
    x:Class="SalmonEgg.Presentation.Views.ConfigurationEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Uid="ConfigurationEditorDialog"
    PrimaryButtonClick="OnSaveClick"
    SecondaryButtonClick="OnCancelClick">

    <ContentDialog.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </ContentDialog.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="12" MinWidth="400" Padding="4">
            <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Severity="Error"
                     IsClosable="True"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"/>

            <TextBox x:Uid="ConfigurationEditorDialogName"
                     Text="{x:Bind ViewModel.Name, Mode=TwoWay}"/>

            <ComboBox x:Uid="ConfigurationEditorDialogTransport"
                      ItemsSource="{x:Bind ViewModel.TransportOptions, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedTransportOption, Mode=TwoWay}"
                      DisplayMemberPath="Name"/>

            <StackPanel Spacing="12"
                        Visibility="{x:Bind ViewModel.IsStdio, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBox x:Uid="ConfigurationEditorDialogCommand"
                         Text="{x:Bind ViewModel.StdioCommand, Mode=TwoWay}"/>
                <TextBox x:Uid="ConfigurationEditorDialogArgs"
                         Text="{x:Bind ViewModel.StdioArgs, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Spacing="12"
                        Visibility="{x:Bind ViewModel.IsRemote, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBox x:Uid="ConfigurationEditorDialogServerUrl"
                         Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay}"/>
            </StackPanel>

            <TextBlock x:Uid="ConfigurationEditorDialogHint"
                       Opacity="0.65"
                       FontSize="12"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>

