<Page x:Class="SalmonEgg.Presentation.Views.MiniWindow.MiniChatView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Chat"
      xmlns:converters="using:SalmonEgg.Presentation.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Background="Transparent"
      AllowDrop="False">

    <Page.Resources>
    </Page.Resources>

    <Grid x:Name="RootGrid"
          RowDefinitions="Auto,*,Auto,Auto"
          Background="Transparent">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WindowWidthStates">
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MiniTitleBar.Padding" Value="12,0" />
                        <Setter Target="MessagesList.Padding" Value="12" />
                        <Setter Target="InputBorder.Padding" Value="12,10,12,16" />
                    </VisualState.Setters>
                </VisualState>

                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="520" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="MiniTitleBar.Padding" Value="16,0" />
                        <Setter Target="MessagesList.Padding" Value="16" />
                        <Setter Target="InputBorder.Padding" Value="16,10,16,16" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- "Title bar" content (in-content; avoids platform-specific titlebar APIs) -->
        <Border x:Name="MiniTitleBar"
                Grid.Row="0"
                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0"
                Height="48"
                Padding="12,0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <ComboBox Grid.Column="0"
                          MinWidth="0"
                          ItemsSource="{x:Bind ViewModel.MiniWindowSessions, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedMiniWindowSession, Mode=TwoWay}"
                          PlaceholderText="选择会话"
                          BorderThickness="0"
                          Background="Transparent"
                          VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:MiniWindowConversationItemViewModel">
                            <TextBlock Text="{x:Bind DisplayName, Mode=OneTime}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Button Grid.Column="1"
                        Style="{StaticResource TitleBarCommandButtonStyle}"
                        ToolTipService.ToolTip="返回主窗口"
                        AutomationProperties.Name="ReturnToWindow"
                        VerticalAlignment="Center"
                        Command="{x:Bind ViewModel.ReturnToMainWindowCommand}">
                    <!-- "BackToWindow" glyph (Segoe Fluent Icons / MDL2-compatible on WinUI) -->
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE73F;" />
                </Button>
            </Grid>
        </Border>

        <!-- Messages -->
        <ListView x:Name="MessagesList"
                  Grid.Row="1"
                  ItemsSource="{x:Bind ViewModel.MessageHistory, Mode=OneWay}"
                  ItemTemplate="{StaticResource MessageTemplate}"
                  Padding="12"
                  SelectionMode="None"
                  HorizontalAlignment="Stretch"
                  MinWidth="0"
                  Loaded="OnMessagesListLoaded" />

        <!-- Unified Input Area -->
        <Border x:Name="InputBorder"
                Grid.Row="2"
                Grid.RowSpan="2"
                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                BorderThickness="0"
                Padding="12,10,12,16">
            <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                    CornerRadius="20"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="12,4,4,4">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0"
                             Text="{x:Bind ViewModel.CurrentPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="输入消息"
                             MinHeight="36"
                             BorderThickness="0"
                             Background="Transparent"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalAlignment="Center">
                        <TextBox.Resources>
                            <!-- Override lightweight styling brush and thickness to remove focus/hover background and border lines natively -->
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                            <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                        </TextBox.Resources>
                    </TextBox>
                    
                    <Button Grid.Column="1"
                            VerticalAlignment="Bottom"
                            Margin="8,0,0,0"
                            Width="36" Height="36"
                            CornerRadius="18"
                            Padding="0"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.SendPromptCommand}"
                            IsEnabled="{x:Bind ViewModel.CanSendPromptUi, Mode=OneWay}">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE724;" FontSize="14" />
                    </Button>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
