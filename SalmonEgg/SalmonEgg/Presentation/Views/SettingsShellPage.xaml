<Page
    x:Class="SalmonEgg.Presentation.Views.SettingsShellPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nav="using:SalmonEgg.Presentation.Models.Navigation"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <Style TargetType="NavigationView">
            <!-- Keep the secondary nav visually compact and consistent across Skia/MSIX -->
            <Setter Property="AlwaysShowHeader" Value="False" />
            <Setter Property="IsBackButtonVisible" Value="Collapsed" />
            <Setter Property="IsSettingsVisible" Value="False" />
            <Setter Property="PaneDisplayMode" Value="Top" />
        </Style>
    </Page.Resources>

    <Grid Padding="40,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <NavigationView x:Name="SettingsNavView"
                        Grid.Row="0"
                        SelectionChanged="OnSettingsNavSelectionChanged"
                        Margin="0,0,0,16">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Uid="SettingsNav_General"
                                    Content="常规"
                                    Tag="General"
                                    AutomationProperties.AutomationId="SettingsNav.General" />
                <NavigationViewItem x:Uid="SettingsNav_Appearance"
                                    Content="外观"
                                    Tag="Appearance"
                                    AutomationProperties.AutomationId="SettingsNav.Appearance" />
                <NavigationViewItem x:Uid="SettingsNav_AgentAcp"
                                    Content="Agent (ACP)"
                                    Tag="AgentAcp"
                                    AutomationProperties.AutomationId="SettingsNav.AgentAcp" />
                <NavigationViewItem x:Uid="SettingsNav_DataStorage"
                                    Content="数据与存储"
                                    Tag="DataStorage"
                                    AutomationProperties.AutomationId="SettingsNav.DataStorage" />
                <NavigationViewItem x:Uid="SettingsNav_Shortcuts"
                                    Content="快捷键"
                                    Tag="Shortcuts"
                                    AutomationProperties.AutomationId="SettingsNav.Shortcuts" />
                <NavigationViewItem x:Uid="SettingsNav_Diagnostics"
                                    Content="诊断与日志"
                                    Tag="Diagnostics"
                                    AutomationProperties.AutomationId="SettingsNav.Diagnostics" />
                <NavigationViewItem x:Uid="SettingsNav_About"
                                    Content="关于"
                                    Tag="About"
                                    AutomationProperties.AutomationId="SettingsNav.About" />
            </NavigationView.MenuItems>
        </NavigationView>

        <Frame x:Name="SettingsFrame"
               Grid.Row="1"
               Background="Transparent" />
    </Grid>
</Page>
