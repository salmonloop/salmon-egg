<Page
    x:Class="SalmonEgg.Presentation.Views.DisplaySettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SalmonEgg.Presentation.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <ScrollViewer Padding="40,24"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="24"
                    MaxWidth="800"
                    HorizontalAlignment="Center">
            <TextBlock Text="显示与外观" FontSize="28" FontWeight="Bold" Margin="0,0,0,12"/>

            <!-- 动画设置组 -->
            <StackPanel Spacing="12">
                <TextBlock Text="交互体验" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>

                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="全局过渡动画" FontWeight="Medium"/>
                            <TextBlock Text="开启后，页面切换和窗口缩放将使用平滑的过渡效果"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      IsOn="{x:Bind SettingsVM.IsAnimationEnabled, Mode=TwoWay}"
                                      OnContent="已开启"
                                      OffContent="已禁用"
                                      MinWidth="0"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- 视觉主题设置组 -->
            <StackPanel Spacing="12">
                <TextBlock Text="界面主题" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>

                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <TextBlock Text="选择您偏好的应用主题颜色" FontSize="14"/>
                        <ComboBox
                            SelectedValue="{x:Bind SettingsVM.Theme, Mode=TwoWay}"
                            SelectedValuePath="Tag"
                            MinWidth="240">
                            <ComboBoxItem Content="跟随系统" Tag="System" />
                            <ComboBoxItem Content="浅色" Tag="Light" />
                            <ComboBoxItem Content="深色" Tag="Dark" />
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Mica 效果说明 -->
            <InfoBar Title="Windows 11 特性"
                     Message="本应用已自动开启 Mica (云母) 材质效果。如果您的系统不支持或已关闭透明度效果，背景将显示为纯色。"
                     IsOpen="True"
                     IsClosable="False"
                     Severity="Informational" />
        </StackPanel>
    </ScrollViewer>
</Page>
