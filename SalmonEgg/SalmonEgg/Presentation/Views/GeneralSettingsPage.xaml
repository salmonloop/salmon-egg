<local:SettingsPageBase
    x:Class="SalmonEgg.Presentation.Views.GeneralSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SalmonEgg.Presentation.Views"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="using:SalmonEgg.Presentation.ViewModels.Settings"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <ScrollViewer Padding="40,24"
                  HorizontalScrollBarVisibility="Disabled">
            <controls:ResponsiveSettingsHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
            <controls:ResponsiveSettingsHost.Child>
                <StackPanel Spacing="32">
                    <controls:SettingsBreadcrumbBar ItemsSource="{x:Bind BreadcrumbItems, Mode=OneWay}"
                                                   Margin="0,0,0,10" />

            <!-- 基础选项组 -->
            <StackPanel Spacing="12">
                <TextBlock Text="启动与窗口" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>

                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="16">
                        <ToggleSwitch Header="开机自动启动"
                                      IsOn="{x:Bind Preferences.LaunchOnStartup, Mode=TwoWay}"
                                      OnContent="开启"
                                      OffContent="关闭"/>

                        <MenuFlyoutSeparator Margin="-16,0" Visibility="Visible"/>

                        <ToggleSwitch Header="最小化到系统托盘"
                                      IsOn="{x:Bind Preferences.MinimizeToTray, Mode=TwoWay}"
                                      OnContent="开启"
                                      OffContent="关闭"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 语言偏好组 -->
            <StackPanel Spacing="12">
                <TextBlock Text="语言与地区" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>

                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="选择界面语言" FontWeight="Medium" Margin="0,0,0,4"/>
                        <ComboBox Width="240"
                                  SelectedValue="{x:Bind Preferences.Language, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="跟随系统" Tag="System" />
                            <ComboBoxItem Content="简体中文" Tag="zh-CN" />
                            <ComboBoxItem Content="English" Tag="en-US" />
                        </ComboBox>
                        <TextBlock Text="部分设置在重新启动应用后生效"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 维护组 -->
            <StackPanel Spacing="12">
                <TextBlock Text="维护" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>

                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="清理本地缓存（占位）" FontWeight="Medium"/>
                            <TextBlock Text="后续将支持会话导出与缓存清理"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="暂不可用"
                                IsEnabled="False"
                                VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
                </StackPanel>
            </controls:ResponsiveSettingsHost.Child>
        </controls:ResponsiveSettingsHost>
    </ScrollViewer>
</local:SettingsPageBase>
