<Page
    x:Class="SalmonEgg.Presentation.Views.Discover.DiscoverSessionsPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SalmonEgg.Presentation.Views.Discover"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:SalmonEgg.Presentation.ViewModels.Discover"
    xmlns:models="using:SalmonEgg.Domain.Models"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <Storyboard x:Name="SkeletonPulse" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="RightSkeletonPanel" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.4" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="0.8" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0.4" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="LeftSkeletonPanel" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.4" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="0.8" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0.4" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <Grid x:Name="LayoutRoot"
          XYFocusKeyboardNavigation="Enabled">
        <Grid.ColumnDefinitions>
            <!-- Left Pane: Profiles -->
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="1" />
            <!-- Right Pane: Sessions -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="768" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ProfilesPane.(Grid.Column)" Value="0" />
                        <Setter Target="ProfilesPane.(Grid.ColumnSpan)" Value="1" />
                        <Setter Target="PaneDivider.Visibility" Value="Visible" />
                        <Setter Target="DetailsPane.(Grid.Column)" Value="2" />
                        <Setter Target="DetailsPane.(Grid.ColumnSpan)" Value="1" />
                        <Setter Target="DetailsContentContainer.Padding" Value="32,24,32,32" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ProfilesPane.(Grid.Column)" Value="0" />
                        <Setter Target="ProfilesPane.(Grid.ColumnSpan)" Value="3" />
                        <Setter Target="PaneDivider.Visibility" Value="Collapsed" />
                        <Setter Target="DetailsPane.(Grid.Column)" Value="0" />
                        <Setter Target="DetailsPane.(Grid.ColumnSpan)" Value="3" />
                        <Setter Target="DetailsContentContainer.Padding" Value="16,16,16,24" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <!-- Left Pane: Profiles Master List -->
        <Grid x:Name="ProfilesPane"
              Grid.Column="0"
              Background="Transparent"
              Visibility="{x:Bind ViewModel.ShowProfilesPane, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="24,32,24,16" Spacing="8">
                <TextBlock
                    x:Uid="DiscoverSessionsTitle"
                    AutomationProperties.AutomationId="DiscoverSessions.Title"
                    Style="{ThemeResource TitleLargeTextBlockStyle}"
                    FontWeight="SemiBold" />
                <TextBlock
                    x:Uid="DiscoverSessionsSubtitle"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Profiles List Area -->
            <Grid Grid.Row="1">
                <!-- Skeleton View for Profiles -->
                <StackPanel x:Name="LeftSkeletonPanel"
                    Visibility="{x:Bind ViewModel.ProfilesViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    Padding="12" Spacing="12">
                    <Border Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="{ThemeResource ButtonBackground}" Opacity="0.1" />
                            <Border Width="120" Height="14" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.1" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <Border Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="{ThemeResource ButtonBackground}" Opacity="0.1" />
                            <Border Width="150" Height="14" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.1" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <Border Padding="12" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="{ThemeResource ButtonBackground}" Opacity="0.1" />
                            <Border Width="80" Height="14" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.1" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>

                <ListView
                    x:Name="ProfilesList"
                    AutomationProperties.AutomationId="DiscoverSessions.ProfilesList"
                    ItemsSource="{x:Bind ViewModel.ProfilesViewModel.Profiles, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                    Visibility="{x:Bind ViewModel.ProfilesViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter='Invert'}"
                    SelectionMode="Single"
                    IsFocusEngagementEnabled="True"
                    IsItemClickEnabled="True"
                    ItemClick="OnProfileItemClick">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ServerConfiguration">
                        <Grid Padding="12,10" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <Border Grid.Column="0"
                                    Width="36" Height="36"
                                    CornerRadius="6"
                                    Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                                    Opacity="0.8">
                                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                          Glyph="{x:Bind TransportGlyph}"
                                          Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                          FontSize="16" />
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind TransportDisplayName}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="12,2,12,2" />
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
        </Grid>
    </Grid>

        <!-- Divider -->
        <Rectangle x:Name="PaneDivider" Grid.Column="1" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <!-- Right Pane: Sessions Details -->
        <Grid x:Name="DetailsPane"
              AutomationProperties.AutomationId="DiscoverSessions.DetailsPane"
              Grid.Column="2"
              Background="Transparent"
              CornerRadius="8"
              Visibility="{x:Bind ViewModel.ShowDetailsPane, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <!-- Empty State when no profile is selected -->
            <Grid Visibility="{x:Bind ViewModel.HasNoSelectedProfile, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="24">
                    <Grid Width="120" Height="120">
                        <Ellipse Fill="{ThemeResource CardBackgroundFillColorSecondaryBrush}" />
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE716;" FontSize="56" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="DiscoverSessionsNoSelectionTitle" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="SemiBold" HorizontalAlignment="Center" />
                        <TextBlock x:Uid="DiscoverSessionsNoSelectionDescription" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Sessions Content Area -->
            <Border x:Name="DetailsContentContainer"
                    Background="Transparent"
                    Padding="32,24,32,32"
                    Visibility="{x:Bind ViewModel.HasSelectedProfile, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid MaxWidth="960"
                      HorizontalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Header for Selected Profile -->
                    <Grid Grid.Row="0" Margin="0,0,0,24" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button x:Name="CompactBackButton"
                                x:Uid="DiscoverSessionsBackButton"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Style="{StaticResource SubtleButtonStyle}"
                                Command="{x:Bind ViewModel.BackToProfilesCommand}"
                                Visibility="{x:Bind ViewModel.ShowCompactBackButton, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72B;" />
                        </Button>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.SelectedProfile.Name, Mode=OneWay}" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="{x:Bind ViewModel.SelectedProfile.TransportDisplayName, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <TextBlock x:Uid="DiscoverSessionsImportableListLabel" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>

                        <Button
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Command="{x:Bind ViewModel.RefreshSessionsCommand}"
                            IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72C;" FontSize="14" />
                                <TextBlock x:Uid="DiscoverSessionsRefreshText" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Loading & Error States Overlay -->
                    <Grid Grid.Row="1" Canvas.ZIndex="10">
                    <InfoBar
                        x:Uid="DiscoverSessionsConnectionError"
                        Message="{x:Bind ViewModel.DisplayErrorMessage, Mode=OneWay}"
                        Severity="Error"
                        IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                        IsClosable="False"
                        VerticalAlignment="Top"
                        Margin="0,0,0,16" />

                    <Grid Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="16">
                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                      Glyph="&#xE8B7;"
                                      FontSize="48"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Uid="DiscoverSessionsEmptyTitle"
                                       Style="{ThemeResource TitleTextBlockStyle}"
                                       HorizontalAlignment="Center" />
                            <TextBlock x:Uid="DiscoverSessionsEmptyDescription"
                                       Style="{ThemeResource BodyTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="360" />
                        </StackPanel>
                    </Grid>

                    <!-- Native Skeleton View (Fishbone) -->
                    <StackPanel x:Name="RightSkeletonPanel"
                        Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Spacing="16"
                        Padding="0,0,0,40">
                        
                        <!-- Transparent Lifecycle Feedback -->
                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,24">
                            <ProgressRing IsActive="True" Width="20" Height="20" />
                            <TextBlock 
                                Text="{x:Bind ViewModel.LoadingStatus, Mode=OneWay}" 
                                Style="{ThemeResource BodyStrongTextBlockStyle}" 
                                VerticalAlignment="Center"
                                Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        </StackPanel>


                        <Border Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="6" Background="{ThemeResource ButtonBackground}" Opacity="0.1" />
                                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                    <Border Width="120" Height="14" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.1" HorizontalAlignment="Left" />
                                    <Border Width="280" Height="10" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.06" HorizontalAlignment="Left" />
                                </StackPanel>
                                <Border Grid.Column="2" Width="84" Height="32" CornerRadius="4" Background="{ThemeResource ButtonBackground}" Opacity="0.1" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="6" Background="{ThemeResource ButtonBackground}" Opacity="0.1" />
                                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                    <Border Width="150" Height="14" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.1" HorizontalAlignment="Left" />
                                    <Border Width="240" Height="10" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.06" HorizontalAlignment="Left" />
                                </StackPanel>
                                <Border Grid.Column="2" Width="84" Height="32" CornerRadius="4" Background="{ThemeResource ButtonBackground}" Opacity="0.1" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="6" Background="{ThemeResource ButtonBackground}" Opacity="0.1" />
                                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                    <Border Width="100" Height="14" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.1" HorizontalAlignment="Left" />
                                    <Border Width="200" Height="10" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.06" HorizontalAlignment="Left" />
                                </StackPanel>
                                <Border Grid.Column="2" Width="84" Height="32" CornerRadius="4" Background="{ThemeResource ButtonBackground}" Opacity="0.1" VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <Border Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="6" Background="{ThemeResource ButtonBackground}" Opacity="0.1" />
                                <StackPanel Grid.Column="1" Spacing="8" VerticalAlignment="Center">
                                    <Border Width="180" Height="14" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.1" HorizontalAlignment="Left" />
                                    <Border Width="160" Height="10" CornerRadius="2" Background="{ThemeResource ButtonBackground}" Opacity="0.06" HorizontalAlignment="Left" />
                                </StackPanel>
                                <Border Grid.Column="2" Width="84" Height="32" CornerRadius="4" Background="{ThemeResource ButtonBackground}" Opacity="0.1" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>
                    </Grid>

                    <!-- Sessions List (Only visible when no errors) -->
                    <ListView
                        x:Name="SessionsList"
                        AutomationProperties.AutomationId="DiscoverSessions.SessionsList"
                        Grid.Row="1"
                        Visibility="{x:Bind ViewModel.IsListVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        ItemsSource="{x:Bind ViewModel.AgentSessions, Mode=OneWay}"
                        IsFocusEngagementEnabled="True"
                        SelectionMode="None"
                        IsItemClickEnabled="False"
                        Padding="0,0,0,40">

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,16"/>
                                <Setter Property="Padding" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>

                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:DiscoverSessionItemViewModel">
                                <Border
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Grid.Column="0"
                                                Width="40" Height="40"
                                                CornerRadius="6"
                                                Background="{ThemeResource SystemControlBackgroundAccentBrush}"
                                                Margin="0,0,16,0"
                                                VerticalAlignment="Top">
                                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                      Glyph="&#xE8F2;"
                                                      Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                      FontSize="18" />
                                        </Border>

                                        <!-- Details -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <TextBlock
                                                Text="{x:Bind Title}"
                                                Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                TextWrapping="NoWrap"
                                                TextTrimming="CharacterEllipsis" />

                                            <TextBlock
                                                Text="{x:Bind Description}"
                                                Style="{ThemeResource BodyTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Margin="0,4,0,0"
                                                TextWrapping="Wrap"
                                                MaxLines="2"
                                                TextTrimming="CharacterEllipsis" />

                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                                <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE787;" FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                                <TextBlock
                                                    Text="{x:Bind FormattedDate}"
                                                    Style="{ThemeResource CaptionTextBlockStyle}"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                                <Border
                                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="6,2">
                                                    <TextBlock
                                                        Text="{x:Bind ProjectAffinityBadgeText, Mode=OneTime}"
                                                        Style="{ThemeResource CaptionTextBlockStyle}"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                </Border>
                                                <FontIcon
                                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                    Glyph="&#xE7BA;"
                                                    FontSize="12"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    VerticalAlignment="Center"
                                                    Visibility="{x:Bind NeedsUserAttention, Mode=OneTime, Converter={StaticResource BoolToVisibilityConverter}}" />
                                            </StackPanel>

                                            <TextBlock
                                                Text="{x:Bind AffinityStatusText, Mode=OneTime}"
                                                Style="{ThemeResource CaptionTextBlockStyle}"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                Margin="0,4,0,0"
                                                TextWrapping="WrapWholeWords"
                                                MaxLines="2" />
                                        </StackPanel>

                                        <!-- Action -->
                                        <Button
                                            x:Name="ActionBtn"
                                            AutomationProperties.AutomationId="DiscoverSessions.ImportButton"
                                            Grid.Column="2"
                                            x:Uid="DiscoverSessionsImportButton"
                                            Style="{StaticResource AccentButtonStyle}"
                                            VerticalAlignment="Center"
                                            Click="OnLoadSessionClick"
                                            CommandParameter="{x:Bind}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
