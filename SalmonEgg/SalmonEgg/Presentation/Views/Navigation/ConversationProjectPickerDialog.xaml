<ContentDialog
    x:Class="SalmonEgg.Presentation.Views.Navigation.ConversationProjectPickerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:chat="using:SalmonEgg.Presentation.Core.Services.Chat"
    mc:Ignorable="d"
    x:Uid="SessionProjectPickerDialog"
    AutomationProperties.AutomationId="SessionProjectPickerDialog"
    Style="{ThemeResource DefaultContentDialogStyle}"
    Title="{x:Bind DialogTitle, Mode=OneWay}"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind HasSelection, Mode=OneWay}">

    <StackPanel Spacing="14"
                MinWidth="400"
                MaxHeight="540">
        <Border Padding="16"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <StackPanel Spacing="4">
                <TextBlock x:Uid="SessionProjectPickerDialogSessionLabel"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock Text="{x:Bind SessionTitle, Mode=OneWay}"
                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                           TextWrapping="WrapWholeWords"
                           TextTrimming="CharacterEllipsis"
                           MaxLines="2" />
            </StackPanel>
        </Border>

        <TextBlock x:Uid="SessionProjectPickerDialogInstructionText"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="WrapWholeWords" />

        <ListView x:Name="OptionsList"
                  x:Uid="SessionProjectPickerDialogOptionsList"
                  AutomationProperties.AutomationId="SessionProjectPickerDialog.OptionsList"
                  ItemsSource="{x:Bind Options, Mode=OneWay}"
                  SelectedItem="{x:Bind SelectedOption, Mode=TwoWay}"
                  SelectionMode="Single"
                  MaxHeight="320"
                  IsItemClickEnabled="False">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="MinHeight" Value="48" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="chat:ConversationProjectTargetOption">
                    <Grid Padding="6,4"
                          AutomationProperties.Name="{x:Bind DisplayName, Mode=OneTime}">
                        <StackPanel Spacing="2">
                            <TextBlock Text="{x:Bind DisplayName, Mode=OneTime}"
                                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                                       TextWrapping="WrapWholeWords"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="2" />
                            <TextBlock Text="{x:Bind ProjectId, Mode=OneTime}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       MaxLines="1" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</ContentDialog>
