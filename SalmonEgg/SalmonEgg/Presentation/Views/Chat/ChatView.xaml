<Page x:Class="SalmonEgg.Presentation.Views.Chat.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:chatVm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Required"
    AllowDrop="False">

    <Page.Resources>
    </Page.Resources>

    <Grid>
        <TextBox x:Name="TranscriptViewportStateProbe"
                 AutomationProperties.AutomationId="ChatView.TranscriptViewportState"
                 AutomationProperties.Name="inactive"
                 Text="inactive"
                 Width="1"
                 Height="1"
                 Opacity="0.01"
                 IsHitTestVisible="False"
                 IsTabStop="False"
                 IsReadOnly="True"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"/>
        <TextBox x:Name="TranscriptViewportDebugProbe"
                 AutomationProperties.AutomationId="ChatView.TranscriptViewportDebug"
                 AutomationProperties.Name="boot"
                 Text="boot"
                 Width="1"
                 Height="1"
                 Opacity="0.01"
                 IsHitTestVisible="False"
                 IsTabStop="False"
                 IsReadOnly="True"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"/>

        <!-- 已激活会话状态：对话界面 -->
        <Grid x:Name="ActiveConversationRoot"
              AutomationProperties.AutomationId="ChatView.ActiveRoot"
              Transitions="{x:Bind Motion.PageTransitions, Mode=OneWay}"
              x:Load="{x:Bind ViewModel.ShouldLoadActiveConversationRoot, Mode=OneWay}"
              Visibility="{x:Bind ViewModel.ShouldShowActiveConversationRoot, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 顶部状态条 -->
            <Border Grid.Row="0"
                    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,8"
                    Visibility="{x:Bind ViewModel.ShouldShowSessionHeader, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid x:Name="SessionHeaderRoot"
                      Loaded="OnSessionHeaderRootLoaded"
                      Unloaded="OnSessionHeaderRootUnloaded">
                    <Grid x:Name="SessionHeaderMetaGrid" ColumnSpacing="12" RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition x:Name="SessionHeaderAgentRow" Height="0" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="SessionHeaderAgentColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Grid x:Name="SessionHeaderTitleHost"
                              Grid.Row="0"
                              Grid.Column="0"
                              MinWidth="0"
                              ColumnDefinitions="Auto,*"
                              ColumnSpacing="12">
                            <FontIcon Grid.Column="0"
                                      Glyph="&#xE8BD;"
                                      FontSize="16"
                                      Foreground="{ThemeResource AccentBrush}"
                                      VerticalAlignment="Center" />

                            <Grid Grid.Column="1"
                                  MinWidth="0"
                                  VerticalAlignment="Center">
                                <Button AutomationProperties.AutomationId="ChatView.CurrentSessionNameButton"
                                        AutomationProperties.Name="{x:Bind ViewModel.PresentedSessionHeaderDisplayName, Mode=OneWay}"
                                        ToolTipService.ToolTip="{x:Bind ViewModel.PresentedSessionHeaderDisplayName, Mode=OneWay}"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        MinWidth="0"
                                        Padding="6,2"
                                        Visibility="{x:Bind ViewModel.IsEditingSessionName, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                        Click="OnSessionNameClick">
                                    <TextBlock Text="{x:Bind ViewModel.PresentedSessionHeaderDisplayName, Mode=OneWay}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                </Button>

                                <TextBox x:Name="SessionNameEditor"
                                         AutomationProperties.AutomationId="ChatView.CurrentSessionNameEditor"
                                         Text="{x:Bind ViewModel.EditingSessionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontWeight="SemiBold"
                                         FontSize="14"
                                         MinWidth="0"
                                         HorizontalAlignment="Stretch"
                                         Padding="6,2"
                                         BorderThickness="1"
                                         CornerRadius="6"
                                         KeyDown="OnSessionNameEditorKeyDown"
                                         LostFocus="OnSessionNameEditorLostFocus"
                                         Visibility="{x:Bind ViewModel.IsEditingSessionName, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </Grid>

                        <TextBlock x:Name="SessionHeaderAgentDisplay"
                                   Grid.Row="0"
                                   Grid.Column="1"
                                   AutomationProperties.AutomationId="ChatView.CurrentAgentDisplay"
                                   Text="{x:Bind ViewModel.CurrentAgentDisplayText, Mode=OneWay}"
                                   ToolTipService.ToolTip="{x:Bind ViewModel.CurrentAgentDisplayText, Mode=OneWay}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Opacity="0.72"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   MaxWidth="180" />
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Row="1" RowDefinitions="*,Auto,Auto,Auto">
                <!-- 消息列表 -->
                <controls:ResponsiveContentHost x:Name="TranscriptHost"
                                                Grid.Row="0"
                                                MaxContentWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
                                                x:Load="{x:Bind ViewModel.ShouldLoadTranscriptSurface, Mode=OneWay}"
                                                Visibility="{x:Bind ViewModel.ShouldShowTranscriptSurface, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:ResponsiveContentHost.Child>
                        <ListView x:Name="MessagesList"
                                  AutomationProperties.AutomationId="ChatView.MessagesList"
                                  ItemsSource="{x:Bind ViewModel.MessageHistory, Mode=OneWay}"
                                  ItemTemplateSelector="{StaticResource MessageTemplateSelector}"
                                  Padding="20"
                                  SelectionMode="None"
                                  HorizontalAlignment="Stretch"
                                  MinWidth="0"
                                  Loaded="OnMessagesListLoaded"
                                  Unloaded="OnMessagesListUnloaded"
                                  PointerReleased="OnMessagesListPointerReleased">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="IsTabStop" Value="False" />
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </controls:ResponsiveContentHost.Child>
                </controls:ResponsiveContentHost>

                <!-- Turn Status Bar -->
                <controls:ResponsiveContentHost Grid.Row="1"
                                                MaxContentWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
                                                Visibility="{x:Bind ViewModel.IsTurnStatusVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:ResponsiveContentHost.Child>
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="24,0,24,8">
                            <ProgressRing IsActive="{x:Bind ViewModel.IsTurnStatusRunning, Mode=OneWay}"
                                          Width="16" Height="16"
                                          Visibility="{x:Bind ViewModel.IsTurnStatusRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <FontIcon Glyph="&#xE783;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                      Visibility="{x:Bind ViewModel.IsTurnStatusRunning, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            <TextBlock Text="{x:Bind ViewModel.TurnStatusText, Mode=OneWay}"
                                       FontSize="12"
                                       Opacity="0.7"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </controls:ResponsiveContentHost.Child>
                </controls:ResponsiveContentHost>

                <controls:ResponsiveContentHost Grid.Row="2"
                                                MaxContentWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
                                                Visibility="{x:Bind ViewModel.HasPendingAskUserRequest, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:ResponsiveContentHost.Child>
                        <Border Margin="24,0,24,12"
                                Padding="16"
                                CornerRadius="12"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="ChatViewAskUserTitle"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.AskUserPrompt, Mode=OneWay}"
                                               TextWrapping="WrapWholeWords"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{x:Bind ViewModel.AskUserQuestions, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="chatVm:AskUserQuestionViewModel">
                                            <StackPanel Spacing="8" Margin="0,0,0,12">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind Header}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                    <TextBlock Text="{x:Bind SelectionHint}"
                                                               FontSize="12"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>

                                                <TextBlock Text="{x:Bind QuestionText}"
                                                           TextWrapping="WrapWholeWords"
                                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                                <ItemsControl ItemsSource="{x:Bind Options, Mode=OneWay}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="chatVm:AskUserOptionViewModel">
                                                            <CheckBox IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                                                                      Command="{x:Bind ToggleSelectedCommand}"
                                                                      Margin="0,0,0,8">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Text="{x:Bind Label}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                                    <TextBlock Text="{x:Bind Description}"
                                                                               TextWrapping="WrapWholeWords"
                                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{x:Bind ViewModel.AskUserErrorMessage, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.AskUserHasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                           TextWrapping="WrapWholeWords"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Uid="ChatViewAskUserSubmitButton"
                                            Command="{x:Bind ViewModel.AskUserSubmitCommand, Mode=OneWay}"
                                            Style="{StaticResource AccentButtonStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </controls:ResponsiveContentHost.Child>
                </controls:ResponsiveContentHost>

                <!-- 输入区域 -->
                <controls:ResponsiveContentHost Grid.Row="3"
                                                MaxContentWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
                                                Visibility="{x:Bind ViewModel.ShouldShowConversationInputSurface, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:ResponsiveContentHost.Child>
                        <controls:ChatInputArea ViewModel="{x:Bind ViewModel, Mode=OneWay}"
                                                SubmitCommand="{x:Bind ViewModel.SendPromptCommand}"
                                                HorizontalAlignment="Stretch" />
                        </controls:ResponsiveContentHost.Child>
                </controls:ResponsiveContentHost>
            </Grid>
        </Grid>
    </Grid>
</Page>
