<Page x:Class="SalmonEgg.Presentation.Views.Chat.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SalmonEgg.Presentation.Views.Chat"
    xmlns:chatVm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:behaviors="using:SalmonEgg.Presentation.Behaviors"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="Transparent"
    NavigationCacheMode="Required"
    AllowDrop="False">

    <Page.Resources>
        <converters:GridLengthConverter x:Key="GridLengthConverter" />

        <Style x:Key="InlineHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                                            <Setter Target="Root.BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                            <Setter Target="Root.BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Opacity" Value="0.45" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <TextBlock x:Name="TranscriptViewportStateProbe"
                   AutomationProperties.AutomationId="ChatView.TranscriptViewportState"
                   Width="1"
                   Height="1"
                   Opacity="0.01"
                   IsHitTestVisible="False"
                   IsTabStop="False"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <!-- 已激活会话状态：对话界面 -->
        <Grid x:Name="ActiveConversationRoot"
              AutomationProperties.AutomationId="ChatView.ActiveRoot"
              Transitions="{x:Bind Motion.PageTransitions, Mode=OneWay}"
              x:Load="{x:Bind ViewModel.ShouldLoadActiveConversationRoot, Mode=OneWay}"
              Visibility="{x:Bind ViewModel.ShouldShowActiveConversationRoot, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="{x:Bind LayoutVM.BottomPanelHeight, Mode=OneWay, Converter={StaticResource GridLengthConverter}}" />
            </Grid.RowDefinitions>

            <!-- 顶部状态条 -->
            <Border Grid.Row="0"
                    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,8"
                    Visibility="{x:Bind ViewModel.ShouldShowSessionHeader, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="8">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE8BD;" FontSize="16" Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center"/>
                            <StackPanel VerticalAlignment="Center">
                                <Grid>
                                    <Button Style="{StaticResource InlineHeaderButtonStyle}"
                                            AutomationProperties.AutomationId="ChatView.CurrentSessionNameButton"
                                            HorizontalAlignment="Left"
                                            Visibility="{x:Bind ViewModel.IsEditingSessionName, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                            Click="OnSessionNameClick">
                                        <TextBlock Text="{x:Bind ViewModel.CurrentSessionDisplayName, Mode=OneWay}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"/>
                                    </Button>

                                    <TextBox x:Name="SessionNameEditor"
                                             AutomationProperties.AutomationId="ChatView.CurrentSessionNameEditor"
                                             Text="{x:Bind ViewModel.EditingSessionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             FontWeight="SemiBold"
                                             FontSize="14"
                                             MinWidth="160"
                                             Padding="6,2"
                                             BorderThickness="1"
                                             CornerRadius="6"
                                             KeyDown="OnSessionNameEditorKeyDown"
                                             LostFocus="OnSessionNameEditorLostFocus"
                                             Visibility="{x:Bind ViewModel.IsEditingSessionName, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Grid.Column="1"
                                   AutomationProperties.AutomationId="ChatView.CurrentAgentDisplay"
                                   Text="{x:Bind ViewModel.CurrentAgentDisplayText, Mode=OneWay}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Opacity="0.72"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   MaxLines="1"
                                   MaxWidth="220"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid Grid.Row="1" RowDefinitions="*,Auto,Auto,Auto">
                <!-- 消息列表 -->
                <controls:ResponsiveContentHost x:Name="TranscriptHost"
                                                Grid.Row="0"
                                                MaxContentWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
                                                x:Load="{x:Bind ViewModel.ShouldLoadTranscriptSurface, Mode=OneWay}"
                                                Visibility="{x:Bind ViewModel.ShouldShowTranscriptSurface, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:ResponsiveContentHost.Child>
                        <ListView x:Name="MessagesList"
                                  AutomationProperties.AutomationId="ChatView.MessagesList"
                                  ItemsSource="{x:Bind ViewModel.MessageHistory, Mode=OneWay}"
                                  ItemTemplate="{StaticResource MessageTemplate}"
                                  Padding="20"
                                  SelectionMode="None"
                                  HorizontalAlignment="Stretch"
                                  MinWidth="0"
                                  Loaded="OnMessagesListLoaded"
                                  Unloaded="OnMessagesListUnloaded"
                                  LayoutUpdated="OnMessagesListLayoutUpdated">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </controls:ResponsiveContentHost.Child>
                </controls:ResponsiveContentHost>

                <!-- Turn Status Bar -->
                <controls:ResponsiveContentHost Grid.Row="1"
                                                MaxContentWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
                                                Visibility="{x:Bind ViewModel.IsTurnStatusVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:ResponsiveContentHost.Child>
                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="24,0,24,8">
                            <ProgressRing IsActive="{x:Bind ViewModel.IsTurnStatusRunning, Mode=OneWay}"
                                          Width="16" Height="16"
                                          Visibility="{x:Bind ViewModel.IsTurnStatusRunning, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <FontIcon Glyph="&#xE783;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                      Visibility="{x:Bind ViewModel.IsTurnStatusRunning, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                            <TextBlock Text="{x:Bind ViewModel.TurnStatusText, Mode=OneWay}"
                                       FontSize="12"
                                       Opacity="0.7"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </controls:ResponsiveContentHost.Child>
                </controls:ResponsiveContentHost>

                <controls:ResponsiveContentHost Grid.Row="2"
                                                MaxContentWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
                                                Visibility="{x:Bind ViewModel.HasPendingAskUserRequest, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:ResponsiveContentHost.Child>
                        <Border Margin="24,0,24,12"
                                Padding="16"
                                CornerRadius="12"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock x:Uid="ChatViewAskUserTitle"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind ViewModel.AskUserPrompt, Mode=OneWay}"
                                               TextWrapping="WrapWholeWords"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>

                                <ItemsControl ItemsSource="{x:Bind ViewModel.AskUserQuestions, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="chatVm:AskUserQuestionViewModel">
                                            <StackPanel Spacing="8" Margin="0,0,0,12">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind Header}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                    <TextBlock Text="{x:Bind SelectionHint}"
                                                               FontSize="12"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>

                                                <TextBlock Text="{x:Bind QuestionText}"
                                                           TextWrapping="WrapWholeWords"
                                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                                                <ItemsControl ItemsSource="{x:Bind Options, Mode=OneWay}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="chatVm:AskUserOptionViewModel">
                                                            <CheckBox IsChecked="{x:Bind IsSelected, Mode=OneWay}"
                                                                      Command="{x:Bind ToggleSelectedCommand}"
                                                                      Margin="0,0,0,8">
                                                                <StackPanel Spacing="2">
                                                                    <TextBlock Text="{x:Bind Label}"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                                                    <TextBlock Text="{x:Bind Description}"
                                                                               TextWrapping="WrapWholeWords"
                                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                                </StackPanel>
                                                            </CheckBox>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="{x:Bind ViewModel.AskUserErrorMessage, Mode=OneWay}"
                                           Visibility="{x:Bind ViewModel.AskUserHasError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                           TextWrapping="WrapWholeWords"/>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Uid="ChatViewAskUserSubmitButton"
                                            Command="{x:Bind ViewModel.AskUserSubmitCommand, Mode=OneWay}"
                                            Style="{StaticResource AccentButtonStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </controls:ResponsiveContentHost.Child>
                </controls:ResponsiveContentHost>

                <!-- 输入区域 -->
                <controls:ResponsiveContentHost Grid.Row="3"
                                                MaxContentWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
                                                Visibility="{x:Bind ViewModel.ShouldShowConversationInputSurface, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <controls:ResponsiveContentHost.Child>
                        <controls:ChatInputArea ViewModel="{x:Bind ViewModel, Mode=OneWay}"
                                                SubmitCommand="{x:Bind ViewModel.SendPromptCommand}"
                                                HorizontalAlignment="Stretch" />
                    </controls:ResponsiveContentHost.Child>
                </controls:ResponsiveContentHost>
            </Grid>

            <local:BottomPanelHost Grid.Row="2"
                                   Visibility="{x:Bind LayoutVM.BottomPanelVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                   TabsSource="{x:Bind ViewModel.BottomPanelTabs, Mode=OneWay}"
                                   SelectedTab="{x:Bind ViewModel.SelectedBottomPanelTab, Mode=TwoWay}" />

        </Grid>
    </Grid>
</Page>
