<Page x:Class="SalmonEgg.Presentation.Views.Chat.ChatView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SalmonEgg.Presentation.Views.Chat"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:domain="using:SalmonEgg.Domain.Models"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:MessageDirectionToAlignmentConverter x:Key="HorizontalAlignmentConverter"/>
        <converters:TimeFormatConverter x:Key="TimeFormatConverter"/>

        <Style x:Key="InlineHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                                            <Setter Target="Root.BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Background" Value="{ThemeResource ControlFillColorTertiaryBrush}" />
                                            <Setter Target="Root.BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Opacity" Value="0.45" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 消息气泡模板 -->
        <DataTemplate x:Key="MessageTemplate" x:DataType="vm:ChatMessageViewModel">
            <Grid Margin="0,8" HorizontalAlignment="{x:Bind IsOutgoing, Converter={StaticResource HorizontalAlignmentConverter}, Mode=OneWay}">
                <Border CornerRadius="12"
                        Padding="12,8"
                        MaxWidth="500"
                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel>
                        <!-- 只有当有标题时显示 (例如工具调用) -->
                        <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                   FontWeight="Bold"
                                   FontSize="12"
                                   Visibility="{x:Bind HasTitle, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                   Margin="0,0,0,4"/>

                        <TextBlock Text="{x:Bind TextContent, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   Visibility="{x:Bind HasTextContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <TextBlock Text="{x:Bind Timestamp, Converter={StaticResource TimeFormatConverter}, Mode=OneWay}"
                                   FontSize="10"
                                   Opacity="0.6"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <!-- 未激活会话状态：空状态设计 -->
        <Grid Visibility="{x:Bind ViewModel.IsSessionActive, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="24">
                <Viewbox Width="80" Height="80" Opacity="0.2">
                    <SymbolIcon Symbol="Message" Foreground="{ThemeResource AccentBrush}"/>
                </Viewbox>
                <StackPanel Spacing="8">
                    <TextBlock Text="准备好开始了吗？"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="请前往“设置 > Agent (ACP)”配置并连接到您的 Agent"
                               FontSize="14"
                               Opacity="0.7"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                </StackPanel>
                <Button Content="去配置 Agent"
                        HorizontalAlignment="Center"
                        Style="{StaticResource AccentButtonStyle}"
                        Padding="24,8"
                        Click="OnGoToSettingsClick"/>
            </StackPanel>
        </Grid>

        <!-- 已激活会话状态：对话界面 -->
        <Grid RowDefinitions="Auto,*,Auto"
              Visibility="{x:Bind ViewModel.IsSessionActive, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

            <!-- 顶部状态条 -->
            <Border Grid.Row="0"
                    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE8BD;" FontSize="16" Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center" Spacing="2">
                            <Grid>
                                <Button Style="{StaticResource InlineHeaderButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Visibility="{x:Bind ViewModel.IsEditingSessionName, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                        Click="OnSessionNameClick">
                                    <TextBlock Text="{x:Bind ViewModel.CurrentSessionDisplayName, Mode=OneWay}"
                                               FontWeight="SemiBold"
                                               FontSize="14"/>
                                </Button>

                                <TextBox x:Name="SessionNameEditor"
                                         Text="{x:Bind ViewModel.EditingSessionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontWeight="SemiBold"
                                         FontSize="14"
                                         MinWidth="160"
                                         Padding="6,2"
                                         BorderThickness="1"
                                         CornerRadius="6"
                                         KeyDown="OnSessionNameEditorKeyDown"
                                         LostFocus="OnSessionNameEditorLostFocus"
                                         Visibility="{x:Bind ViewModel.IsEditingSessionName, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </Grid>

                            <TextBlock Text="在线"
                                       FontSize="11"
                                       Foreground="Green"
                                       Opacity="0.8"/>
                        </StackPanel>
                    </StackPanel>

                    <ComboBox Grid.Column="1"
                              Width="140"
                              FontSize="12"
                              MinWidth="0"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              ItemsSource="{x:Bind ViewModel.AcpProfileList, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedAcpProfile, Mode=TwoWay}"
                              PlaceholderText="选择 ACP">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="domain:ServerConfiguration">
                                <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </Border>

            <!-- 消息列表 -->
            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.MessageHistory, Mode=OneWay}"
                      ItemTemplate="{StaticResource MessageTemplate}"
                      Padding="20"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <!-- 输入区域 -->
            <Border Grid.Row="2"
                    Padding="20,0,20,20"
                    Background="Transparent">
                <Grid MaxWidth="800">
                    <Grid RowDefinitions="Auto,Auto,Auto">
                        <!-- Slash commands menu -->
                        <Border Grid.Row="0"
                                Margin="0,0,0,8"
                                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Visibility="{x:Bind ViewModel.ShowSlashCommands, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Padding="8" Spacing="6">
                                <ListView ItemsSource="{x:Bind ViewModel.FilteredSlashCommands, Mode=OneWay}"
                                          SelectedItem="{x:Bind ViewModel.SelectedSlashCommand, Mode=TwoWay}"
                                          SelectionMode="Single"
                                          MaxHeight="220">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SlashCommandViewModel">
                                            <Grid ColumnDefinitions="Auto,*" Padding="8,6">
                                                <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"
                                                           FontFamily="Consolas"
                                                           FontSize="13"
                                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                           Margin="0,0,12,0"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Description, Mode=OneWay}"
                                                           TextWrapping="Wrap"
                                                           Opacity="0.7"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                                <TextBlock Text="{x:Bind ViewModel.SelectedSlashCommand.InputHint, Mode=OneWay}"
                                           Opacity="0.6"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <Grid Grid.Column="0">
                                <!-- Ghost completion overlay -->
                                <TextBlock IsHitTestVisible="False"
                                           Margin="12,10,12,10"
                                           TextWrapping="Wrap"
                                           Opacity="0.65"
                                           Visibility="{x:Bind ViewModel.ShowSlashCommands, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Run Text="{x:Bind ViewModel.CurrentPrompt, Mode=OneWay}" Foreground="Transparent"/>
                                    <Run Text="{x:Bind ViewModel.SlashGhostSuffix, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </TextBlock>

                                <TextBox x:Name="InputBox"
                                         PlaceholderText="向 Agent 发送消息... (Ctrl+Enter 发送)"
                                         Text="{x:Bind ViewModel.CurrentPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="44"
                                         MaxHeight="120"
                                         KeyDown="OnInputKeyDown"/>
                            </Grid>

                            <Button Grid.Column="1"
                                    Content="&#xE724;"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Background="{ThemeResource AccentBrush}"
                                    Foreground="White"
                                    Command="{x:Bind ViewModel.SendPromptCommand}"
                                    VerticalAlignment="Bottom"/>
                        </Grid>

                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="0,10,0,0">
                            <ComboBox Width="140"
                                      FontSize="12"
                                      MinWidth="0"
                                      ItemsSource="{x:Bind ViewModel.AvailableModes, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}"
                                      PlaceholderText="选择模式">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SessionModeViewModel">
                                        <TextBlock Text="{x:Bind ModeName, Mode=OneWay}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="1"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- 加载遮罩 -->
            <Grid Grid.RowSpan="3"
                  Background="#40000000"
                  Visibility="{x:Bind ViewModel.IsConnecting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <ProgressRing IsActive="True" Width="48" Height="48"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
