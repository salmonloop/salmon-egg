<UserControl
    x:Class="SalmonEgg.Presentation.Views.Chat.BottomPanelHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:SalmonEgg.Controls"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}"
          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
          BorderThickness="0,1,0,0">
        <TabView HorizontalAlignment="Stretch"
                 VerticalAlignment="Stretch"
                 IsAddTabButtonVisible="False"
                 SelectedIndex="0"
                 CanReorderTabs="False"
                 CanDragTabs="False"
                 AllowDropTabs="False"
                 TabWidthMode="SizeToContent"
                 MinHeight="48">
            <TabView.TabItems>
                <TabViewItem Header="{x:Bind TerminalTabTitle, Mode=OneWay}"
                             IsClosable="False"
                             HorizontalContentAlignment="Stretch"
                             VerticalContentAlignment="Stretch"
                             AutomationProperties.AutomationId="BottomPanelTab.terminal"
                             AutomationProperties.Name="{x:Bind TerminalTabTitle, Mode=OneWay}">
                    <TabViewItem.Content>
                        <Border Margin="12,0,12,12"
                                CornerRadius="12"
                                Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <controls:XtermTerminalView HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Stretch"
                                                        Session="{x:Bind EffectiveLocalTerminalSession, Mode=OneWay}"
                                                        ContentText="{x:Bind LocalTerminalContentText, Mode=OneWay}" />
                        </Border>
                    </TabViewItem.Content>
                </TabViewItem>
            </TabView.TabItems>
        </TabView>
    </Grid>
</UserControl>
