<views:SettingsPageBase
    x:Class="SalmonEgg.Presentation.Views.Settings.AppearanceSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:views="using:SalmonEgg.Presentation.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:settings="using:SalmonEgg.Presentation.ViewModels.Settings"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <ScrollViewer Padding="0"
                  HorizontalScrollBarVisibility="Disabled">
        <controls:ResponsiveContentHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
            <controls:ResponsiveContentHost.Child>
                <StackPanel Spacing="28">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="Appearance_PageTitle"
                                   Style="{StaticResource SettingsPageTitleTextStyle}"/>
                        <TextBlock x:Uid="Appearance_PageSummary"
                                   Style="{StaticResource SettingsPageSummaryTextStyle}"/>
                    </StackPanel>

                    <InfoBar x:Uid="Appearance_Notice"
                             IsOpen="True"
                             IsClosable="False"
                             Severity="Informational" />

                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="Appearance_ThemeTitle"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}"/>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <Grid Style="{StaticResource SettingsRowGridStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock x:Uid="Appearance_ThemeLabel"
                                               Style="{StaticResource SettingsRowTitleTextStyle}"/>
                                    <TextBlock x:Uid="Appearance_ThemeDescription"
                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          x:Name="AppearanceThemeComboBox"
                                          AutomationProperties.AutomationId="Appearance.Theme"
                                          SelectedValue="{x:Bind Preferences.Theme, Mode=TwoWay}"
                                          SelectedValuePath="Tag"
                                          MinWidth="{StaticResource SettingsRowControlMinWidth}"
                                          HorizontalAlignment="Stretch"
                                          IsFocusEngagementEnabled="True"
                                          VerticalAlignment="Center">
                                    <ComboBoxItem x:Uid="Appearance_ThemeSystem" Tag="System" />
                                    <ComboBoxItem x:Uid="Appearance_ThemeLight" Tag="Light" />
                                    <ComboBoxItem x:Uid="Appearance_ThemeDark" Tag="Dark" />
                                </ComboBox>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="Appearance_MotionTitle"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}"/>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <Grid Style="{StaticResource SettingsRowGridStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock x:Uid="Appearance_MotionToggleTitle"
                                               Style="{StaticResource SettingsRowTitleTextStyle}"/>
                                    <TextBlock x:Uid="Appearance_MotionToggleDescription"
                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                </StackPanel>

                                <ToggleSwitch Grid.Column="1"
                                              x:Name="AppearanceAnimationToggle"
                                              AutomationProperties.AutomationId="Appearance.Animation"
                                              IsOn="{x:Bind Preferences.IsAnimationEnabled, Mode=TwoWay}"
                                              x:Uid="Appearance_MotionToggle"
                                              MinWidth="0"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="Appearance_BackdropTitle"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}"/>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <Grid Style="{StaticResource SettingsRowGridStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock x:Uid="Appearance_BackdropLabel"
                                               Style="{StaticResource SettingsRowTitleTextStyle}"/>
                                    <TextBlock x:Uid="Appearance_BackdropDescription"
                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                </StackPanel>

                                <ComboBox Grid.Column="1"
                                          x:Name="AppearanceBackdropComboBox"
                                          AutomationProperties.AutomationId="Appearance.Backdrop"
                                          SelectedValue="{x:Bind Preferences.Backdrop, Mode=TwoWay}"
                                          SelectedValuePath="Tag"
                                          MinWidth="{StaticResource SettingsRowControlMinWidth}"
                                          HorizontalAlignment="Stretch"
                                          IsFocusEngagementEnabled="True"
                                          VerticalAlignment="Center">
                                    <ComboBoxItem x:Uid="Appearance_BackdropSystem" Tag="System" />
                                    <ComboBoxItem x:Uid="Appearance_BackdropMica" Content="Mica" Tag="Mica" />
                                    <ComboBoxItem x:Uid="Appearance_BackdropAcrylic" Content="Acrylic" Tag="Acrylic" />
                                    <ComboBoxItem x:Uid="Appearance_BackdropSolid" Tag="Solid" />
                                </ComboBox>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </controls:ResponsiveContentHost.Child>
        </controls:ResponsiveContentHost>
    </ScrollViewer>
</views:SettingsPageBase>
