<Page
    x:Class="SalmonEgg.Presentation.Views.Settings.AcpConnectionSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Settings"
    xmlns:models="using:SalmonEgg.Domain.Models"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

        <Style x:Key="AgentListItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="64"/>
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="40,24"
                  HorizontalScrollBarVisibility="Disabled">
        <controls:ResponsiveSettingsHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
            <controls:ResponsiveSettingsHost.Child>
                <StackPanel Spacing="28">
                    <TextBlock Text="Agent (ACP)"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <!-- Overview -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="当前连接状态"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"/>

                        <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="14"
                                      VerticalAlignment="Center">
                                    <Viewbox Width="56" Height="56" VerticalAlignment="Center">
                                        <SymbolIcon Symbol="World" Foreground="{ThemeResource AccentBrush}"/>
                                    </Viewbox>

                                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind ViewModel.AgentDisplayName, Mode=OneWay}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind ViewModel.ConnectionStatusText, Mode=OneWay}"
                                                   Opacity="0.7"
                                                   FontSize="12"/>
                                    </StackPanel>

                                    <ToggleSwitch Grid.Column="2"
                                                  Header="连接"
                                                  OnContent="开"
                                                  OffContent="关"
                                                  IsOn="{x:Bind ViewModel.Chat.IsConnected, Mode=OneWay}"
                                                  IsEnabled="{x:Bind ViewModel.Chat.IsConnecting, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                                                  Toggled="OnConnectionToggleToggled"/>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*"
                                      ColumnSpacing="12"
                                      RowSpacing="6">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="传输协议"
                                               Opacity="0.7"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{x:Bind ViewModel.SelectedTransportName, Mode=OneWay}"
                                               Opacity="0.9"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="端点"
                                               Opacity="0.7"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{x:Bind ViewModel.CurrentEndpointDisplay, Mode=OneWay}"
                                               Opacity="0.9"
                                               TextWrapping="Wrap"/>
                                </Grid>

                                <TextBlock Text="{x:Bind ViewModel.Chat.ConnectionErrorMessage, Mode=OneWay}"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                           Visibility="{x:Bind ViewModel.Chat.HasConnectionError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Transport settings -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="配置"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"/>

                        <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel Spacing="14">
                                <TextBlock Text="修改配置后需要重新连接才能生效。"
                                           Opacity="0.65"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>

                                <StackPanel Spacing="8">
                                    <TextBlock Text="传输协议" FontWeight="Medium"/>
                                    <ComboBox ItemsSource="{x:Bind ViewModel.TransportOptions, Mode=OneWay}"
                                              SelectedItem="{x:Bind ViewModel.SelectedTransport, Mode=TwoWay}"
                                              DisplayMemberPath="Name"
                                              MinWidth="240"/>
                                </StackPanel>

                                <StackPanel Spacing="12"
                                            Visibility="{x:Bind ViewModel.Chat.TransportConfig.IsStdio, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBox Header="执行命令"
                                             PlaceholderText="例如：python / node / agent.exe"
                                             Text="{x:Bind ViewModel.Chat.TransportConfig.StdioCommand, Mode=TwoWay}"/>
                                    <TextBox Header="参数"
                                             PlaceholderText="例如：server.py --port 8080"
                                             Text="{x:Bind ViewModel.Chat.TransportConfig.StdioArgs, Mode=TwoWay}"/>
                                </StackPanel>

                                <StackPanel Spacing="12"
                                            Visibility="{x:Bind ViewModel.Chat.TransportConfig.IsStdio, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}">
                                    <TextBox Header="服务器地址"
                                             PlaceholderText="wss://example.com 或 http://localhost:8080/sse"
                                             Text="{x:Bind ViewModel.Chat.TransportConfig.RemoteUrl, Mode=TwoWay}"/>
                                </StackPanel>

                                <InfoBar IsOpen="{x:Bind ViewModel.HasSelectedProfile, Mode=OneWay}"
                                         Severity="Informational"
                                         Title="当前预设"
                                         Message="{x:Bind ViewModel.SelectedProfileName, Mode=OneWay}"
                                         IsClosable="False"/>

                                <InfoBar IsOpen="{x:Bind ViewModel.IsProfileDirty, Mode=OneWay}"
                                         Severity="Warning"
                                         Title="未保存的更改"
                                         Message="当前配置已偏离所选预设。"
                                         IsClosable="False">
                                    <InfoBar.ActionButton>
                                        <Button Content="更新预设"
                                                Command="{x:Bind ViewModel.UpdateSelectedProfileFromCurrentCommand}"/>
                                    </InfoBar.ActionButton>
                                </InfoBar>

                                <InfoBar IsOpen="{x:Bind ViewModel.HasSelectedProfile, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"
                                         Severity="Informational"
                                         Title="未选择预设"
                                         Message="你可以把当前配置保存为预设，方便下次一键切换。"
                                         IsClosable="False">
                                    <InfoBar.ActionButton>
                                        <Button Content="保存为预设"
                                                Command="{x:Bind ViewModel.SaveCurrentAsNewProfileCommand}"/>
                                    </InfoBar.ActionButton>
                                </InfoBar>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Right"
                                            Visibility="{x:Bind ViewModel.IsProfileDirty, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button Content="另存为新预设"
                                            Style="{StaticResource SubtleButtonStyle}"
                                            Command="{x:Bind ViewModel.SaveCurrentAsCopyCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Profiles -->
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="我的 Agent"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <Button Content="刷新"
                                        Command="{x:Bind ViewModel.Profiles.RefreshCommand}"
                                        IsEnabled="{x:Bind ViewModel.Profiles.IsLoading, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"/>
                                <Button Content="新建"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="OnAddProfileClick"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ListView ItemsSource="{x:Bind ViewModel.Profiles.Profiles, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.Profiles.SelectedProfile, Mode=TwoWay}"
                                      SelectionMode="Single"
                                      MinHeight="140"
                                      Background="Transparent"
                                      ItemContainerStyle="{StaticResource AgentListItemStyle}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ServerConfiguration">
                                        <Grid Padding="14,10"
                                              ColumnDefinitions="Auto,*,Auto"
                                              ColumnSpacing="12">
                                            <Border Width="36"
                                                    Height="36"
                                                    CornerRadius="8"
                                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                    Opacity="0.18"
                                                    VerticalAlignment="Center">
                                                <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                              Glyph="{x:Bind TransportGlyph}"
                                                              Foreground="{ThemeResource AccentBrush}"/>
                                                </Viewbox>
                                            </Border>

                                            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Name}"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{x:Bind SubtitleDisplay}"
                                                           FontSize="12"
                                                           Opacity="0.65"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Style="{StaticResource SubtleButtonStyle}"
                                                    VerticalAlignment="Center"
                                                    ToolTipService.ToolTip="更多">
                                                <Button.Content>
                                                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE712;"/>
                                                </Button.Content>
                                                <Button.Flyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="编辑"
                                                                        Tag="{x:Bind}"
                                                                        Click="OnEditProfileMenuClick"/>
                                                        <MenuFlyoutItem Text="删除"
                                                                        Tag="{x:Bind}"
                                                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                                        Click="OnDeleteProfileMenuClick"/>
                                                    </MenuFlyout>
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </StackPanel>

                    <!-- Diagnostics -->
                    <StackPanel Spacing="12">
                        <TextBlock Text="诊断"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AccentBrush}"/>

                        <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="连接相关信息"
                                           FontWeight="Medium"/>
                                <Grid ColumnDefinitions="Auto,*"
                                      RowDefinitions="Auto,Auto"
                                      ColumnSpacing="12"
                                      RowSpacing="6">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Agent" Opacity="0.7"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.Chat.AgentName, Mode=OneWay}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="版本" Opacity="0.7"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.Chat.AgentVersion, Mode=OneWay}" Opacity="0.85"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </controls:ResponsiveSettingsHost.Child>
        </controls:ResponsiveSettingsHost>
    </ScrollViewer>
</Page>
