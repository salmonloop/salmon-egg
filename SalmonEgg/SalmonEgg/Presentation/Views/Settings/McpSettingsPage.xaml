<views:SettingsPageBase
    x:Class="SalmonEgg.Presentation.Views.Settings.McpSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:views="using:SalmonEgg.Presentation.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Settings"
    xmlns:mcp="using:SalmonEgg.Domain.Models.Mcp"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

    </Page.Resources>

    <ScrollViewer Padding="0"
                  HorizontalScrollBarVisibility="Disabled">
        <controls:ResponsiveContentHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
            <controls:ResponsiveContentHost.Child>
                <StackPanel Spacing="28">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="Mcp_PageTitle"
                                   Text="MCP"
                                   Style="{StaticResource SettingsPageTitleTextStyle}"/>
                        <TextBlock x:Uid="Mcp_PageSummary"
                                   Text="集中管理可随会话提供给智能体的 MCP 服务。开启后，新建、恢复和加载会话都会使用这里的配置。"
                                   Style="{StaticResource SettingsPageSummaryTextStyle}"/>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="Mcp_GlobalTitle"
                                   Text="全局 MCP 配置"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}"/>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <Grid Style="{StaticResource SettingsRowGridStyle}"
                                  ColumnDefinitions="*,Auto">
                                <StackPanel VerticalAlignment="Center" Spacing="4">
                                    <TextBlock x:Uid="Mcp_EnableTitle"
                                               Text="随 ACP 会话提供 MCP 服务"
                                               Style="{StaticResource SettingsRowTitleTextStyle}"/>
                                    <TextBlock x:Uid="Mcp_EnableDescription"
                                               Text="开启后，Salmon Egg 会在会话启动或恢复时带上当前 MCP 服务列表。"
                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                </StackPanel>

                                <ToggleSwitch Grid.Column="1"
                                              x:Uid="Mcp_EnableSwitch"
                                              AutomationProperties.AutomationId="Mcp.Global.Enabled"
                                              IsOn="{x:Bind ViewModel.IsEnabled, Mode=TwoWay}"
                                              OnContent="开启"
                                              OffContent="关闭"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto"
                              AutomationProperties.AutomationId="Mcp.Servers.Header">
                            <TextBlock x:Uid="Mcp_ServersTitle"
                                       Text="MCP 服务"
                                       Style="{StaticResource SettingsSectionTitleTextStyle}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        VerticalAlignment="Center">
                                <Button x:Uid="Mcp_Reload"
                                        Content="刷新"
                                        Command="{x:Bind ViewModel.LoadCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"/>
                                <Button x:Uid="Mcp_ImportFromJson"
                                        Content="从 JSON 导入"
                                        Command="{x:Bind ViewModel.OpenImportPanelCommand}"/>
                                <Button x:Uid="Mcp_AddServer"
                                        Content="新建"
                                        Command="{x:Bind ViewModel.AddServerCommand}"
                                        AutomationProperties.AutomationId="Mcp.AddServer"
                                        Style="{StaticResource AccentButtonStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <StackPanel>
                                <Grid Style="{StaticResource SettingsRowGridStyle}"
                                      ColumnDefinitions="*,Auto">
                                    <StackPanel VerticalAlignment="Center"
                                                Spacing="4">
                                        <TextBlock x:Uid="Mcp_ServerCatalogDescription"
                                                   Text="本地服务通常使用 stdio；远程服务优先使用 HTTP；SSE 仅用于兼容仍未迁移的旧服务。"
                                                   Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                                   Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                   TextWrapping="Wrap"
                                                   AutomationProperties.AutomationId="Mcp.Status"/>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            x:Uid="Mcp_Save"
                                            Content="保存"
                                            Command="{x:Bind ViewModel.SaveCommand}"
                                            VerticalAlignment="Center"/>
                                </Grid>

                                <MenuFlyoutSeparator Margin="16,0"/>

                                <Border Margin="16,16,16,0"
                                        Padding="0,0,0,16"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Visibility="{x:Bind ViewModel.IsImportPanelOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        AutomationProperties.AutomationId="Mcp.Import.Panel">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock x:Uid="Mcp_ImportTitle"
                                                           Text="从 JSON 导入 MCP 服务"
                                                           Style="{StaticResource SettingsRowTitleTextStyle}"/>
                                                <TextBlock x:Uid="Mcp_ImportDescription"
                                                           Text="粘贴包含 mcpServers 的配置。导入后会变成可编辑服务项，仍需手动保存。"
                                                           Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                            </StackPanel>

                                            <Button Grid.Column="1"
                                                    x:Uid="Mcp_ImportJsonCollapse"
                                                    Content="收起"
                                                    Command="{x:Bind ViewModel.CollapseImportPanelCommand}"
                                                    VerticalAlignment="Top"/>
                                        </Grid>

                                        <TextBox x:Uid="Mcp_ImportJson"
                                                 Header="MCP JSON"
                                                 Text="{x:Bind ViewModel.ImportJsonText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="NoWrap"
                                                 MinHeight="132"
                                                 FontFamily="Consolas"
                                                 PlaceholderText="Paste mcpServers JSON here"/>

                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock x:Uid="Mcp_ImportHint"
                                                           Text="支持 stdio、HTTP 和 SSE。无法识别的字段会被忽略。"
                                                           Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                                <TextBlock Text="{x:Bind ViewModel.ImportStatusMessage, Mode=OneWay}"
                                                           Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                           TextWrapping="Wrap"
                                                           AutomationProperties.AutomationId="Mcp.Import.Status"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <Button x:Uid="Mcp_ImportJsonClear"
                                                        Content="清空"
                                                        Command="{x:Bind ViewModel.ClearImportJsonCommand}"/>
                                                <Button x:Uid="Mcp_ImportJsonApply"
                                                        Content="导入"
                                                        Command="{x:Bind ViewModel.ImportJsonCommand}"
                                                        Style="{StaticResource AccentButtonStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <ItemsControl ItemsSource="{x:Bind ViewModel.Servers, Mode=OneWay}"
                                              MinHeight="160"
                                              AutomationProperties.AutomationId="Mcp.Servers.List">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:McpServerRowViewModel">
                                            <Grid Padding="16"
                                                  ColumnDefinitions="*,Auto"
                                                  RowDefinitions="Auto,Auto,Auto"
                                                  RowSpacing="12"
                                                  ColumnSpacing="12">
                                                <Grid ColumnDefinitions="*,180"
                                                      ColumnSpacing="12">
                                                    <TextBox x:Uid="Mcp_ServerName"
                                                             Header="服务名称"
                                                             Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="filesystem"/>
                                                    <ComboBox Grid.Column="1"
                                                              x:Uid="Mcp_ServerTransport"
                                                              Header="连接方式"
                                                              ItemsSource="{x:Bind TransportOptions, Mode=OneWay}"
                                                              SelectedItem="{x:Bind Transport, Mode=TwoWay}">
                                                    </ComboBox>
                                                </Grid>

                                                <Button Grid.Column="1"
                                                        x:Uid="Mcp_RemoveServer"
                                                        Command="{x:Bind RemoveCommand, Mode=OneWay}"
                                                        AutomationProperties.AutomationId="Mcp.RemoveServer"
                                                        VerticalAlignment="Bottom"
                                                        ToolTipService.ToolTip="删除">
                                                    <Button.Content>
                                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                  Glyph="&#xE74D;"/>
                                                    </Button.Content>
                                                </Button>

                                                <StackPanel Grid.Row="1"
                                                            Grid.ColumnSpan="2"
                                                            Spacing="8"
                                                            Visibility="{x:Bind IsStdio, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBox x:Uid="Mcp_ServerCommand"
                                                             Header="启动命令"
                                                             Text="{x:Bind Command, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="C:\tools\mcp-filesystem.exe"/>
                                                    <TextBox x:Uid="Mcp_ServerArguments"
                                                             Header="启动参数"
                                                             Text="{x:Bind ArgumentsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="--root C:\repo"/>
                                                    <TextBox x:Uid="Mcp_ServerEnvironment"
                                                             Header="环境变量"
                                                             Text="{x:Bind EnvironmentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="API_KEY=value"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="72"/>
                                                </StackPanel>

                                                <StackPanel Grid.Row="2"
                                                            Grid.ColumnSpan="2"
                                                            Spacing="8"
                                                            Visibility="{x:Bind IsHttpLike, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBox x:Uid="Mcp_ServerUrl"
                                                             Header="服务地址"
                                                             Text="{x:Bind Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="https://example.com/mcp"/>
                                                    <TextBox x:Uid="Mcp_ServerHeaders"
                                                             Header="请求头"
                                                             Text="{x:Bind HeadersText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="Authorization: Bearer token"
                                                             AcceptsReturn="True"
                                                             TextWrapping="Wrap"
                                                             MinHeight="72"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </StackPanel>
            </controls:ResponsiveContentHost.Child>
        </controls:ResponsiveContentHost>
    </ScrollViewer>
</views:SettingsPageBase>
