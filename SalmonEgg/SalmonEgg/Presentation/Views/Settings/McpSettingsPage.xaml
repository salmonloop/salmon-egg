<views:SettingsPageBase
    x:Class="SalmonEgg.Presentation.Views.Settings.McpSettingsPage"
    x:Name="PageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:views="using:SalmonEgg.Presentation.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Settings"
    xmlns:mcp="using:SalmonEgg.Domain.Models.Mcp"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

    </Page.Resources>

    <ScrollViewer Padding="0"
                  HorizontalScrollBarVisibility="Disabled">
        <controls:ResponsiveContentHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
            <controls:ResponsiveContentHost.Child>
                <StackPanel Spacing="28">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="Mcp_PageTitle"
                                   Text="MCP"
                                   Style="{StaticResource SettingsPageTitleTextStyle}"/>
                        <TextBlock x:Uid="Mcp_PageSummary"
                                   Text="按需启用 MCP 服务。已启用且配置完整的服务会随 ACP 会话一起提供。"
                                   Style="{StaticResource SettingsPageSummaryTextStyle}"/>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <StackPanel Spacing="10"
                                    AutomationProperties.AutomationId="Mcp.Servers.Header">
                            <TextBlock x:Uid="Mcp_ServersTitle"
                                       Text="服务配置"
                                       Style="{StaticResource SettingsSectionTitleTextStyle}"/>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Left">
                                <Button x:Uid="Mcp_Reload"
                                        Content="刷新"
                                        Command="{x:Bind ViewModel.LoadCommand}"
                                        IsEnabled="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"/>
                                <Button x:Uid="Mcp_AddServer"
                                        Content="新建"
                                        Command="{x:Bind ViewModel.AddServerCommand}"
                                        AutomationProperties.AutomationId="Mcp.AddServer"
                                        Style="{StaticResource AccentButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <StackPanel>
                                <Grid Style="{StaticResource SettingsRowGridStyle}"
                                      ColumnDefinitions="*">
                                    <StackPanel VerticalAlignment="Center"
                                                Spacing="4">
                                        <TextBlock x:Uid="Mcp_ServerCatalogDescription"
                                                   Text="本地服务使用 stdio；远程服务支持 Streamable HTTP 与 SSE。"
                                                   Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                                   Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                   TextWrapping="Wrap"
                                                   AutomationProperties.AutomationId="Mcp.Status"/>
                                    </StackPanel>
                                </Grid>

                                <MenuFlyoutSeparator Margin="16,0"/>

                                <Border Margin="16,16,16,0"
                                        Padding="0,16,0,0"
                                        BorderThickness="0,1,0,0"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Visibility="{x:Bind ViewModel.IsEditorOpen, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                        AutomationProperties.AutomationId="Mcp.Editor.Panel">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock x:Uid="Mcp_EditorTitle"
                                                           Text="编辑 MCP 服务"
                                                           Style="{StaticResource SettingsRowTitleTextStyle}"/>
                                                <TextBlock x:Uid="Mcp_EditorDescription"
                                                           Text="编辑连接信息，保存后应用到该服务。"
                                                           Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    x:Uid="Mcp_EditorClose"
                                                    Content="关闭"
                                                    Command="{x:Bind ViewModel.CloseEditorCommand}"
                                                    AutomationProperties.AutomationId="Mcp.Editor.Close"
                                                    VerticalAlignment="Top"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="12"
                                              HorizontalAlignment="Stretch">
                                            <TextBlock Text="{x:Bind ViewModel.ImportStatusMessage, Mode=OneWay}"
                                                       Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                       TextWrapping="Wrap"
                                                       VerticalAlignment="Center"
                                                       AutomationProperties.AutomationId="Mcp.Import.Status"/>
                                            <Button Grid.Column="1"
                                                    x:Uid="Mcp_FillFromClipboardJson"
                                                    Content="从剪贴板填入"
                                                    Command="{x:Bind ViewModel.FillEditorFromClipboardCommand}"
                                                    AutomationProperties.AutomationId="Mcp.FillFromClipboardJson"/>
                                        </Grid>

                                        <ContentControl Content="{x:Bind ViewModel.EditingServer, Mode=OneWay}"
                                                        HorizontalContentAlignment="Stretch">
                                            <ContentControl.ContentTemplate>
                                                <DataTemplate x:DataType="vm:McpServerRowViewModel">
                                                    <StackPanel Spacing="12"
                                                                HorizontalAlignment="Stretch">
                                                        <StackPanel Spacing="12"
                                                                    HorizontalAlignment="Stretch">
                                                            <TextBox x:Uid="Mcp_ServerName"
                                                                     Header="名称"
                                                                     Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     PlaceholderText="filesystem"
                                                                     HorizontalAlignment="Stretch"/>
                                                            <ComboBox x:Uid="Mcp_ServerTransport"
                                                                      Header="连接方式"
                                                                      ItemsSource="{x:Bind TransportOptions, Mode=OneWay}"
                                                                      DisplayMemberPath="Name"
                                                                      SelectedValuePath="Transport"
                                                                      SelectedValue="{x:Bind Transport, Mode=TwoWay}"
                                                                      HorizontalAlignment="Stretch"/>
                                                        </StackPanel>

                                                        <StackPanel Spacing="8"
                                                                    HorizontalAlignment="Stretch"
                                                                    Visibility="{x:Bind IsStdio, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBox x:Uid="Mcp_ServerCommand"
                                                                     Header="启动命令"
                                                                     Text="{x:Bind Command, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     PlaceholderText="C:\tools\mcp-filesystem.exe"
                                                                     HorizontalAlignment="Stretch"/>
                                                            <StackPanel Spacing="4">
                                                                <TextBox x:Uid="Mcp_ServerArguments"
                                                                         Header="启动参数"
                                                                         Text="{x:Bind ArgumentsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         PlaceholderText="--root C:\repo"
                                                                         HorizontalAlignment="Stretch"/>
                                                                <TextBlock x:Uid="Mcp_ServerArgumentsHelp"
                                                                           Text="用空格分隔参数；带空格的值请使用引号。"
                                                                           Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                            <Expander x:Uid="Mcp_ServerAdvanced"
                                                                      Header="高级设置"
                                                                      HorizontalAlignment="Stretch"
                                                                      HorizontalContentAlignment="Stretch">
                                                                <StackPanel Spacing="4">
                                                                    <TextBox x:Uid="Mcp_ServerEnvironment"
                                                                             Header="环境变量"
                                                                             Text="{x:Bind EnvironmentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             PlaceholderText="API_KEY=value"
                                                                             AcceptsReturn="True"
                                                                             TextWrapping="Wrap"
                                                                             MinHeight="72"/>
                                                                    <TextBlock x:Uid="Mcp_ServerEnvironmentHelp"
                                                                               Text="每行一个变量，格式 KEY=value。"
                                                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Expander>
                                                        </StackPanel>

                                                        <StackPanel Spacing="8"
                                                                    HorizontalAlignment="Stretch"
                                                                    Visibility="{x:Bind IsHttpLike, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <TextBox x:Uid="Mcp_ServerUrl"
                                                                     Header="服务地址"
                                                                     Text="{x:Bind Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     PlaceholderText="https://example.com/mcp"
                                                                     HorizontalAlignment="Stretch"/>
                                                            <Expander x:Uid="Mcp_ServerAdvanced"
                                                                      Header="高级设置"
                                                                      HorizontalAlignment="Stretch"
                                                                      HorizontalContentAlignment="Stretch">
                                                                <StackPanel Spacing="4">
                                                                    <TextBox x:Uid="Mcp_ServerHeaders"
                                                                             Header="请求头"
                                                                             Text="{x:Bind HeadersText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             PlaceholderText="Authorization: Bearer token"
                                                                             AcceptsReturn="True"
                                                                             TextWrapping="Wrap"
                                                                             MinHeight="72"/>
                                                                    <TextBlock x:Uid="Mcp_ServerHeadersHelp"
                                                                               Text="每行一个请求头，格式 Header: value。"
                                                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                                               TextWrapping="Wrap"/>
                                                                </StackPanel>
                                                            </Expander>
                                                        </StackPanel>

                                                        <Grid ColumnDefinitions="*,Auto"
                                                              ColumnSpacing="12"
                                                              HorizontalAlignment="Stretch">
                                                            <TextBlock Text="{x:Bind StatusMessage, Mode=OneWay}"
                                                                       Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center"/>
                                                            <Button Grid.Column="1"
                                                                    x:Uid="Mcp_EditorSave"
                                                                    Content="保存"
                                                                    Command="{x:Bind SaveCommand, Mode=OneWay}"
                                                                    AutomationProperties.AutomationId="Mcp.SaveServer"
                                                                    Style="{StaticResource AccentButtonStyle}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ContentControl.ContentTemplate>
                                        </ContentControl>
                                    </StackPanel>
                                </Border>

                                <ItemsControl ItemsSource="{x:Bind ViewModel.Servers, Mode=OneWay}"
                                              MinHeight="160"
                                              AutomationProperties.AutomationId="Mcp.Servers.List">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:McpServerRowViewModel">
                                            <Grid Padding="16"
                                                  ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="16">
                                                <StackPanel Spacing="4"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                               Style="{StaticResource SettingsRowTitleTextStyle}"/>
                                                    <TextBlock Text="{x:Bind StatusMessage, Mode=OneWay}"
                                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                               TextWrapping="Wrap"
                                                               AutomationProperties.AutomationId="Mcp.Server.Status"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <ToggleSwitch x:Uid="Mcp_ServerEnabled"
                                                                  AutomationProperties.AutomationId="Mcp.Server.Enabled"
                                                                  IsOn="{x:Bind Enabled, Mode=TwoWay}"
                                                                  OnContent="启用"
                                                                  OffContent="停用"/>
                                                    <Button x:Uid="Mcp_EditServer"
                                                            Content="编辑"
                                                            Command="{x:Bind EditCommand, Mode=OneWay}"
                                                            AutomationProperties.AutomationId="Mcp.EditServer"/>
                                                    <Button x:Uid="Mcp_RemoveServer"
                                                            AutomationProperties.AutomationId="Mcp.RemoveServer"
                                                            ToolTipService.ToolTip="删除">
                                                        <Button.Content>
                                                            <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                                      Glyph="&#xE74D;"/>
                                                        </Button.Content>
                                                        <Button.Flyout>
                                                            <Flyout>
                                                                <StackPanel Spacing="12"
                                                                            MinWidth="240">
                                                                    <StackPanel Spacing="4">
                                                                        <TextBlock x:Uid="Mcp_RemoveServerConfirmTitle"
                                                                                   Text="删除此服务？"
                                                                                   Style="{StaticResource SettingsRowTitleTextStyle}"/>
                                                                        <TextBlock x:Uid="Mcp_RemoveServerConfirmDescription"
                                                                                   Text="删除后会立即从 MCP 配置中移除。"
                                                                                   Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                                                                   TextWrapping="Wrap"/>
                                                                    </StackPanel>
                                                                    <Button x:Uid="Mcp_RemoveServerConfirm"
                                                                            Content="删除"
                                                                            Command="{x:Bind RemoveCommand, Mode=OneWay}"
                                                                            AutomationProperties.AutomationId="Mcp.RemoveServer.Confirm"
                                                                            HorizontalAlignment="Right"
                                                                            Style="{StaticResource AccentButtonStyle}"/>
                                                                </StackPanel>
                                                            </Flyout>
                                                        </Button.Flyout>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </StackPanel>
            </controls:ResponsiveContentHost.Child>
        </controls:ResponsiveContentHost>
    </ScrollViewer>
</views:SettingsPageBase>
