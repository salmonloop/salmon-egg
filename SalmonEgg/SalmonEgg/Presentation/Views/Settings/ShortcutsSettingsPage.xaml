<views:SettingsPageBase
    x:Class="SalmonEgg.Presentation.Views.Settings.ShortcutsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:views="using:SalmonEgg.Presentation.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Settings"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <ScrollViewer Padding="0"
                  HorizontalScrollBarVisibility="Disabled">
        <controls:ResponsiveContentHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
            <controls:ResponsiveContentHost.Child>
                <StackPanel Spacing="24"
                            Padding="{StaticResource SettingsPageVerticalPadding}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="Shortcuts_PageTitle"
                                   Style="{StaticResource SettingsPageTitleTextStyle}"/>
                        <TextBlock x:Uid="Shortcuts_PageSummary"
                                   Style="{StaticResource SettingsPageSummaryTextStyle}"/>
                    </StackPanel>

                    <InfoBar x:Uid="Shortcuts_ConflictInfo"
                             IsOpen="{x:Bind ViewModel.HasConflicts, Mode=OneWay}"
                             Message="{x:Bind ViewModel.ConflictMessage, Mode=OneWay}"
                             Severity="Warning"
                             IsClosable="False"/>

                    <InfoBar x:Uid="Shortcuts_InvalidInfo"
                             IsOpen="{x:Bind ViewModel.HasInvalid, Mode=OneWay}"
                             Severity="Error"
                             IsClosable="False"/>

                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="Shortcuts_CustomTitle"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}"/>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <StackPanel XYFocusKeyboardNavigation="Enabled">
                                <Grid Style="{StaticResource SettingsRowGridStyle}">
                                    <TextBlock x:Uid="Shortcuts_AppOnlyHint"
                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                </Grid>

                                <Border Height="1"
                                        Margin="16,0"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                                <ItemsControl x:Name="ShortcutsItemsHost"
                                              ItemsSource="{x:Bind ViewModel.Shortcuts, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ShortcutEntryViewModel">
                                            <controls:ResponsiveFormRow>
                                                <controls:ResponsiveFormRow.Label>
                                                    <StackPanel VerticalAlignment="Center" Spacing="4">
                                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                                   Style="{StaticResource SettingsRowTitleTextStyle}"/>
                                                        <TextBlock Text="{x:Bind DefaultGesture, Mode=OneWay}"
                                                                   Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                                    </StackPanel>
                                                </controls:ResponsiveFormRow.Label>
                                                <controls:ResponsiveFormRow.Value>
                                                    <Grid ColumnDefinitions="*,Auto"
                                                          ColumnSpacing="8">
                                                        <controls:ShortcutRecorder Grid.Column="0"
                                                                                   x:Uid="Shortcuts_GestureRecorder"
                                                                                   Gesture="{x:Bind Gesture, Mode=TwoWay}"
                                                                                   RecorderAutomationId="{x:Bind RecorderAutomationId, Mode=OneWay}"
                                                                                   HorizontalAlignment="Stretch"
                                                                                   VerticalAlignment="Center"/>

                                                        <Button Grid.Column="1"
                                                                x:Uid="Shortcuts_RestoreSingle"
                                                                AutomationProperties.AutomationId="{x:Bind RestoreAutomationId, Mode=OneWay}"
                                                                Command="{x:Bind RestoreDefaultCommand}"
                                                                VerticalAlignment="Center"/>
                                                    </Grid>
                                                </controls:ResponsiveFormRow.Value>
                                            </controls:ResponsiveFormRow>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Border Height="1"
                                        Margin="16,0"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                                <Grid Style="{StaticResource SettingsRowGridStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock x:Uid="Shortcuts_RestoreAllDescription"
                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"
                                               VerticalAlignment="Center"/>

                                    <Button x:Name="RestoreAllButton"
                                            Grid.Column="1"
                                            x:Uid="Shortcuts_RestoreAll"
                                            AutomationProperties.AutomationId="Shortcuts.RestoreAll"
                                            Command="{x:Bind ViewModel.RestoreDefaultsCommand}"
                                            VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </controls:ResponsiveContentHost.Child>
        </controls:ResponsiveContentHost>
    </ScrollViewer>
</views:SettingsPageBase>
