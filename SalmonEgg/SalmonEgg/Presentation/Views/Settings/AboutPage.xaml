<views:SettingsPageBase
    x:Class="SalmonEgg.Presentation.Views.Settings.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:views="using:SalmonEgg.Presentation.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <ScrollViewer Padding="0"
                  HorizontalScrollBarVisibility="Disabled">
        <controls:ResponsiveSettingsHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
            <controls:ResponsiveSettingsHost.Child>
                <StackPanel Spacing="24">
            <StackPanel Spacing="12">
                <TextBlock Text="应用信息" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{x:Bind ViewModel.AppName, Mode=OneWay}" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="版本：" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}" Opacity="0.7"/>
                        <TextBlock Text="协议版本：" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.ProtocolVersion, Mode=OneWay}" Opacity="0.7"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="支持" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <Button Content="打开应用数据目录" Command="{x:Bind ViewModel.OpenAppDataFolderCommand}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="打开更新日志" Command="{x:Bind ViewModel.OpenReleaseNotesCommand}" />
                            <Button Content="打开隐私政策" Command="{x:Bind ViewModel.OpenPrivacyPolicyCommand}" />
                            <Button Content="复制版本信息" Command="{x:Bind ViewModel.CopyVersionInfoCommand}" />
                        </StackPanel>
                        <TextBlock Text="文档目录：" FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind ViewModel.DocsRootPath, Mode=OneWay}" Opacity="0.7" TextWrapping="Wrap"/>
                        <TextBlock Text="将 release-notes.md 与 privacy-policy.md 放入该目录后即可一键打开。"
                                   Opacity="0.7"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
                </StackPanel>
            </controls:ResponsiveSettingsHost.Child>
        </controls:ResponsiveSettingsHost>
    </ScrollViewer>
</views:SettingsPageBase>
