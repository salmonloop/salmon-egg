<views:SettingsPageBase
    x:Class="SalmonEgg.Presentation.Views.Settings.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:settings="using:SalmonEgg.Presentation.ViewModels.Settings"
    xmlns:views="using:SalmonEgg.Presentation.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <ScrollViewer Padding="0"
                  HorizontalScrollBarVisibility="Disabled">
        <controls:ResponsiveContentHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
            <controls:ResponsiveContentHost.Child>
                <StackPanel Spacing="24"
                            Padding="{StaticResource SettingsPageVerticalPadding}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="About_PageTitle"
                                   Style="{StaticResource SettingsPageTitleTextStyle}"/>
                        <TextBlock x:Uid="About_PageSummary"
                                   Style="{StaticResource SettingsPageSummaryTextStyle}"/>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="About_AppInfoTitle"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}"/>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <StackPanel>
                                <controls:ResponsiveFormRow>
                                    <controls:ResponsiveFormRow.Label>
                                        <TextBlock x:Uid="About_AppNameLabel"
                                                   Style="{StaticResource SettingsRowTitleTextStyle}"
                                                   VerticalAlignment="Center"/>
                                    </controls:ResponsiveFormRow.Label>
                                    <controls:ResponsiveFormRow.Value>
                                        <TextBlock Text="{x:Bind ViewModel.AppName, Mode=OneWay}"
                                                   Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                    </controls:ResponsiveFormRow.Value>
                                </controls:ResponsiveFormRow>

                                <Border Height="1"
                                        Margin="16,0"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                                <controls:ResponsiveFormRow>
                                    <controls:ResponsiveFormRow.Label>
                                        <TextBlock x:Uid="About_VersionLabel"
                                                   Style="{StaticResource SettingsRowTitleTextStyle}"
                                                   VerticalAlignment="Center"/>
                                    </controls:ResponsiveFormRow.Label>
                                    <controls:ResponsiveFormRow.Value>
                                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}"
                                                   Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                    </controls:ResponsiveFormRow.Value>
                                </controls:ResponsiveFormRow>

                                <Border Height="1"
                                        Margin="16,0"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                                <controls:ResponsiveFormRow>
                                    <controls:ResponsiveFormRow.Label>
                                        <TextBlock x:Uid="About_ProtocolLabel"
                                                   Style="{StaticResource SettingsRowTitleTextStyle}"
                                                   VerticalAlignment="Center"/>
                                    </controls:ResponsiveFormRow.Label>
                                    <controls:ResponsiveFormRow.Value>
                                        <TextBlock Text="{x:Bind ViewModel.ProtocolVersion, Mode=OneWay}"
                                                   Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                    </controls:ResponsiveFormRow.Value>
                                </controls:ResponsiveFormRow>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="About_SupportTitle"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}"/>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <StackPanel>
                                <Grid Style="{StaticResource SettingsRowGridStyle}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock x:Uid="About_SupportActionsTitle"
                                               Style="{StaticResource SettingsRowTitleTextStyle}"/>

                                    <StackPanel Grid.Row="1"
                                                Spacing="8"
                                                Margin="0,12,0,0"
                                                HorizontalAlignment="Stretch">
                                        <Button x:Name="AboutOpenAppDataButton"
                                                x:Uid="About_OpenAppData"
                                                AutomationProperties.AutomationId="About.Support.OpenAppData"
                                                Command="{x:Bind ViewModel.OpenAppDataFolderCommand}"
                                                IsEnabled="{x:Bind ViewModel.CanOpenExternalFiles, Mode=OneWay}"
                                                HorizontalAlignment="Stretch"/>
                                        <Button x:Name="AboutReportInappropriateAiContentButton"
                                                x:Uid="About_ReportInappropriateAiContent"
                                                AutomationProperties.AutomationId="About.Support.ReportAiContent"
                                                Command="{x:Bind ViewModel.ReportInappropriateAiContentCommand}"
                                                IsEnabled="{x:Bind ViewModel.CanReportInappropriateAiContent, Mode=OneWay}"
                                                HorizontalAlignment="Stretch"/>
                                        <Button x:Name="AboutOpenReleaseNotesButton"
                                                x:Uid="About_OpenReleaseNotes"
                                                AutomationProperties.AutomationId="About.Support.OpenReleaseNotes"
                                                Command="{x:Bind ViewModel.OpenReleaseNotesCommand}"
                                                IsEnabled="{x:Bind ViewModel.CanOpenExternalFiles, Mode=OneWay}"
                                                HorizontalAlignment="Stretch"/>
                                        <Button x:Name="AboutOpenPrivacyPolicyButton"
                                                x:Uid="About_OpenPrivacyPolicy"
                                                AutomationProperties.AutomationId="About.Support.OpenPrivacyPolicy"
                                                Command="{x:Bind ViewModel.OpenPrivacyPolicyCommand}"
                                                IsEnabled="{x:Bind ViewModel.CanOpenExternalFiles, Mode=OneWay}"
                                                HorizontalAlignment="Stretch"/>
                                        <Button x:Name="AboutCopyVersionInfoButton"
                                                x:Uid="About_CopyVersionInfo"
                                                AutomationProperties.AutomationId="About.Support.CopyVersionInfo"
                                                Command="{x:Bind ViewModel.CopyVersionInfoCommand}"
                                                HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1"
                                        Margin="16,0"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                                <controls:ResponsiveFormRow>
                                    <controls:ResponsiveFormRow.Label>
                                        <TextBlock x:Uid="About_DocsFolderLabel"
                                                   Style="{StaticResource SettingsRowTitleTextStyle}"
                                                   VerticalAlignment="Center"/>
                                    </controls:ResponsiveFormRow.Label>
                                    <controls:ResponsiveFormRow.Value>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{x:Bind ViewModel.DocsRootPath, Mode=OneWay}"
                                                       Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                            <TextBlock x:Uid="About_DocsHint"
                                                       Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                        </StackPanel>
                                    </controls:ResponsiveFormRow.Value>
                                </controls:ResponsiveFormRow>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="About_OpenSourceTitle"
                                   Style="{StaticResource SettingsSectionTitleTextStyle}"/>

                        <Border Style="{StaticResource SettingsSectionContainerStyle}">
                            <StackPanel>
                                <Grid Style="{StaticResource SettingsRowGridStyle}">
                                    <TextBlock x:Uid="About_OpenSourceDescription"
                                               Style="{StaticResource SettingsRowDescriptionTextStyle}"/>
                                </Grid>

                                <Border Height="1"
                                        Margin="16,0"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"/>

                        <ListView ItemsSource="{x:Bind ViewModel.OpenSourceAcknowledgements, Mode=OneWay}"
                                  SelectionMode="None"
                                  MaxHeight="360"
                                  AutomationProperties.AutomationId="About.OpenSourceAcknowledgements">
                            <ListView.Header>
                                <Grid Padding="0,0,0,8"
                                      ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="2*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Uid="About_OpenSourcePackageHeader" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="1" x:Uid="About_OpenSourceVersionHeader" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="2" x:Uid="About_OpenSourceLicenseHeader" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Column="3" x:Uid="About_OpenSourceSourceHeader" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Grid>
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="settings:OpenSourceAcknowledgementViewModel">
                                    <Grid Padding="0,8"
                                          ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="2*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Version, Mode=OneWay}" Opacity="0.72" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind License, Mode=OneWay}" Opacity="0.72" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind SourceUrl, Mode=OneWay}" Opacity="0.72" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </controls:ResponsiveContentHost.Child>
        </controls:ResponsiveContentHost>
    </ScrollViewer>
</views:SettingsPageBase>
