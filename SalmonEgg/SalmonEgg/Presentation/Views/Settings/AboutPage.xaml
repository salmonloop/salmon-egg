<Page
    x:Class="SalmonEgg.Presentation.Views.Settings.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <ScrollViewer Padding="40,24"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="GutterLeft" Width="0"/>
                <ColumnDefinition x:Name="ContentColumn" Width="*"/>
                <ColumnDefinition x:Name="GutterRight" Width="0"/>
            </Grid.ColumnDefinitions>

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="LayoutStates">
                    <VisualState x:Name="Narrow"/>
                    <VisualState x:Name="Wide">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1000"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="GutterLeft.Width" Value="*"/>
                            <Setter Target="GutterRight.Width" Value="*"/>
                            <Setter Target="ContentColumn.Width" Value="900"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <StackPanel Grid.Column="1" Spacing="24" HorizontalAlignment="Stretch">
            <TextBlock Text="关于" FontSize="28" FontWeight="Bold" Margin="0,0,0,12"/>

            <StackPanel Spacing="12">
                <TextBlock Text="应用信息" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{x:Bind ViewModel.AppName, Mode=OneWay}" FontWeight="SemiBold" FontSize="16"/>
                        <TextBlock Text="版本：" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}" Opacity="0.7"/>
                        <TextBlock Text="协议版本：" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.ProtocolVersion, Mode=OneWay}" Opacity="0.7"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="支持" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <Button Content="打开应用数据目录" Command="{x:Bind ViewModel.OpenAppDataFolderCommand}" />
                        <TextBlock Text="更新与隐私政策入口可在此页扩展（当前占位）。" Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
