<Page
    x:Class="SalmonEgg.Presentation.Views.Settings.DataStorageSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <Page.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Page.Resources>

    <ScrollViewer Padding="40,24"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="GutterLeft" Width="0"/>
                <ColumnDefinition x:Name="ContentColumn" Width="*"/>
                <ColumnDefinition x:Name="GutterRight" Width="0"/>
            </Grid.ColumnDefinitions>

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="LayoutStates">
                    <VisualState x:Name="Narrow"/>
                    <VisualState x:Name="Wide">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="1000"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="GutterLeft.Width" Value="*"/>
                            <Setter Target="GutterRight.Width" Value="*"/>
                            <Setter Target="ContentColumn.Width" Value="900"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

            <StackPanel Grid.Column="1" Spacing="28" HorizontalAlignment="Stretch">
            <TextBlock Text="数据与存储" FontSize="28" FontWeight="Bold" Margin="0,0,0,12"/>

            <StackPanel Spacing="12">
                <TextBlock Text="隐私" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <ToggleSwitch Header="保存本地历史"
                                      IsOn="{x:Bind ViewModel.Preferences.SaveLocalHistory, Mode=TwoWay}"
                                      OnContent="开启"
                                      OffContent="关闭" />

                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="历史保留天数" VerticalAlignment="Center" />
                            <NumberBox Value="{x:Bind ViewModel.Preferences.HistoryRetentionDays, Mode=TwoWay}"
                                       Minimum="1"
                                       Maximum="365"
                                       SmallChange="1"
                                       SpinButtonPlacementMode="Inline"
                                       Width="140" />
                        </StackPanel>

                        <ToggleSwitch Header="记住最近项目路径"
                                      IsOn="{x:Bind ViewModel.Preferences.RememberRecentProjectPaths, Mode=TwoWay}"
                                      OnContent="开启"
                                      OffContent="关闭" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="缓存" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="缓存保留天数" VerticalAlignment="Center" />
                            <NumberBox Value="{x:Bind ViewModel.Preferences.CacheRetentionDays, Mode=TwoWay}"
                                       Minimum="1"
                                       Maximum="60"
                                       SmallChange="1"
                                       SpinButtonPlacementMode="Inline"
                                       Width="140" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="清理缓存"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    Click="OnClearCacheClick" />
                            <Button Content="打开缓存目录"
                                    Command="{x:Bind ViewModel.OpenCacheFolderCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="导出" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="导出会话（当前会话/当前消息列表）与诊断包到 exports 目录" Opacity="0.7" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="导出会话（Markdown）" Command="{x:Bind ViewModel.ExportCurrentSessionMarkdownCommand}" />
                            <Button Content="导出会话（JSON）" Command="{x:Bind ViewModel.ExportCurrentSessionJsonCommand}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="导出诊断包（ZIP）" Command="{x:Bind ViewModel.CreateDiagnosticsBundleCommand}" />
                            <Button Content="打开导出目录" Command="{x:Bind ViewModel.OpenExportsFolderCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="重置" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="恢复默认设置"
                                    Click="OnResetPreferencesClick" />
                            <Button Content="清空所有本地数据"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    Click="OnClearAllLocalDataClick" />
                        </StackPanel>
                        <TextBlock Text="清空本地数据会删除配置、日志、缓存等文件。此操作不可撤销。"
                                   FontSize="12"
                                   Opacity="0.7"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
