<views:SettingsPageBase
    x:Class="SalmonEgg.Presentation.Views.Settings.DiagnosticsSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:views="using:SalmonEgg.Presentation.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    AllowDrop="False">

    <views:SettingsPageBase.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </views:SettingsPageBase.Resources>

    <ScrollViewer Padding="0"
                  HorizontalScrollBarVisibility="Disabled">
            <controls:ResponsiveSettingsHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
            <controls:ResponsiveSettingsHost.Child>
                <StackPanel Spacing="28">
            <StackPanel Spacing="12">
                <TextBlock x:Uid="Diagnostics_EnvironmentTitle" Text="运行环境" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="{x:Bind ViewModel.OsDescription, Mode=OneWay}" />
                        <TextBlock Text="{x:Bind ViewModel.FrameworkDescription, Mode=OneWay}" Opacity="0.7"/>
                        <TextBlock x:Uid="Diagnostics_AppVersionLabel" Text="应用版本：" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.AppVersion, Mode=OneWay}" Opacity="0.7"/>
                        <TextBlock x:Uid="Diagnostics_ProtocolVersionLabel" Text="协议版本：" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.ProtocolVersion, Mode=OneWay}" Opacity="0.7"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock x:Uid="Diagnostics_LogsTitle" Text="日志" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="Diagnostics_LogsFolderLabel" Text="日志目录：" FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind ViewModel.LogsDirectoryPath, Mode=OneWay}" Opacity="0.7" TextWrapping="Wrap"/>
                        <TextBlock x:Uid="Diagnostics_LatestLogLabel" Text="最新日志文件：" FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind ViewModel.LatestLogFilePath, Mode=OneWay}" Opacity="0.7" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Uid="Diagnostics_OpenLogs" Content="打开日志目录" Command="{x:Bind ViewModel.OpenLogsFolderCommand}" />
                            <Button x:Uid="Diagnostics_CopyLogSnippet" Content="复制最近日志片段" Command="{x:Bind ViewModel.CopyRecentLogSnippetCommand}" />
                            <Button x:Uid="Diagnostics_RefreshLogs" Content="刷新" Command="{x:Bind ViewModel.RefreshLatestLogFileCommand}" />
                        </StackPanel>

                        <Expander IsExpanded="{x:Bind ViewModel.LiveLogViewer.IsExpanded, Mode=TwoWay}"
                                  Background="Transparent"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Padding="0">
                            <Expander.Header>
                                <Grid Padding="12,8" HorizontalAlignment="Stretch">
                                    <TextBlock x:Uid="Diagnostics_LiveLogHeader" Text="实时日志" FontWeight="SemiBold" />
                                </Grid>
                            </Expander.Header>

                            <StackPanel Padding="12,0,0,0"
                                        Spacing="12"
                                        HorizontalAlignment="Stretch">
                                <TextBlock Text="{x:Bind ViewModel.LiveLogViewer.StatusText, Mode=OneWay}"
                                           FontWeight="Medium" />
                                <TextBlock Text="{x:Bind ViewModel.LiveLogViewer.CurrentLogFilePath, Mode=OneWay}"
                                           Opacity="0.7"
                                           TextWrapping="Wrap" />

                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Uid="Diagnostics_LiveLogStart"
                                            Content="启动"
                                            Command="{x:Bind ViewModel.LiveLogViewer.OpenViewerCommand}"
                                            Visibility="{x:Bind ViewModel.LiveLogViewer.CanStartStreaming, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button x:Uid="Diagnostics_LiveLogPause"
                                            Content="暂停"
                                            Command="{x:Bind ViewModel.LiveLogViewer.TogglePauseCommand}"
                                            Visibility="{x:Bind ViewModel.LiveLogViewer.CanPauseStreaming, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button x:Uid="Diagnostics_LiveLogResume"
                                            Content="继续"
                                            Command="{x:Bind ViewModel.LiveLogViewer.TogglePauseCommand}"
                                            Visibility="{x:Bind ViewModel.LiveLogViewer.CanResumeStreaming, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <Button x:Uid="Diagnostics_LiveLogClear"
                                            Content="清空视图"
                                            Command="{x:Bind ViewModel.LiveLogViewer.ClearVisibleLogCommand}" />
                                </StackPanel>

                                <TextBox x:Name="LiveLogTextBox"
                                         Text="{x:Bind ViewModel.LiveLogViewer.VisibleLogText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextChanged="OnLiveLogTextChanged"
                                         TextWrapping="Wrap"
                                         Height="320" />

                                <TextBlock x:Uid="Diagnostics_LiveLogHint"
                                           Text="离开页面后会自动停止实时打印。"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock x:Uid="Diagnostics_ConnectionTitle" Text="连接诊断" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="Diagnostics_ConnectionStatusLabel" Text="当前状态：" FontWeight="SemiBold"/>
                        <TextBlock Text="{x:Bind ViewModel.Chat.IsConnected, Mode=OneWay}" Opacity="0.7"/>
                        <TextBlock x:Uid="Diagnostics_AgentLabel" Text="Agent：" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.Chat.AgentName, Mode=OneWay}" Opacity="0.7"/>
                        <TextBlock Text="{x:Bind ViewModel.Chat.AgentVersion, Mode=OneWay}" Opacity="0.7"/>
                        <TextBlock x:Uid="Diagnostics_SessionLabel" Text="会话：" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.Chat.CurrentSessionId, Mode=OneWay}" Opacity="0.7"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock x:Uid="Diagnostics_BundleTitle" Text="诊断包" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock x:Uid="Diagnostics_BundleDescription" Text="生成 ZIP 包，包含配置（不含密钥）、日志与环境快照。" Opacity="0.7" TextWrapping="Wrap"/>
                        <Button x:Uid="Diagnostics_CreateBundle" Content="生成诊断包（ZIP）" Command="{x:Bind ViewModel.CreateDiagnosticsBundleCommand}" />
                    </StackPanel>
                </Border>
            </StackPanel>
                </StackPanel>
            </controls:ResponsiveSettingsHost.Child>
        </controls:ResponsiveSettingsHost>
    </ScrollViewer>
</views:SettingsPageBase>
