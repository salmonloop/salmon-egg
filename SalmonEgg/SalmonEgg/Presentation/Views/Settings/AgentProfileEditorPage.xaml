<views:SettingsPageBase
    x:Class="SalmonEgg.Presentation.Views.Settings.AgentProfileEditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:views="using:SalmonEgg.Presentation.Views"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Disabled"
    Background="Transparent">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Page.Resources>

    <ScrollViewer Padding="40,24"
                  HorizontalScrollBarVisibility="Disabled">
            <controls:ResponsiveSettingsHost MaxContentWidth="{StaticResource SettingsContentMaxWidth}">
                <controls:ResponsiveSettingsHost.Child>
                <StackPanel Spacing="18">
                    <controls:SettingsBreadcrumbBar ItemsSource="{x:Bind BreadcrumbItems, Mode=OneWay}"
                                                   Margin="0,0,0,10" />

                    <InfoBar IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                             Severity="Error"
                             Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                             IsClosable="True"/>

                    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="16">
                        <StackPanel Spacing="14">
                            <TextBox Header="名称"
                                     PlaceholderText="例如：本地 Agent / 远程测试环境"
                                     Text="{x:Bind ViewModel.Name, Mode=TwoWay}"/>

                            <ComboBox Header="传输协议"
                                      ItemsSource="{x:Bind ViewModel.TransportOptions, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedTransportOption, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      MinWidth="240"/>

                            <StackPanel Spacing="12"
                                        Visibility="{x:Bind ViewModel.IsStdio, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBox Header="执行命令"
                                         PlaceholderText="例如：python / node / agent.exe"
                                         Text="{x:Bind ViewModel.StdioCommand, Mode=TwoWay}"/>
                                <TextBox Header="参数"
                                         PlaceholderText="例如：server.py --port 8080"
                                         Text="{x:Bind ViewModel.StdioArgs, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Spacing="12"
                                        Visibility="{x:Bind ViewModel.IsRemote, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBox Header="服务器地址"
                                         PlaceholderText="wss://example.com 或 http://localhost:8080/sse"
                                         Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch">
                        <Expander IsExpanded="False"
                                  Background="Transparent"
                                  HorizontalAlignment="Stretch"
                                  HorizontalContentAlignment="Stretch"
                                  Padding="0">
                            <Expander.Header>
                                <Grid Padding="16,12" HorizontalAlignment="Stretch">
                                    <TextBlock Text="高级选项" FontWeight="SemiBold"/>
                                </Grid>
                            </Expander.Header>

                            <StackPanel Padding="16" Spacing="12" HorizontalAlignment="Stretch">
                                <TextBlock Text="认证" FontWeight="SemiBold"/>
                                <PasswordBox x:Name="TokenBox"
                                             Header="Token（可选）"
                                             HorizontalAlignment="Stretch"
                                             PasswordChanged="OnTokenPasswordChanged"/>
                                <PasswordBox x:Name="ApiKeyBox"
                                             Header="API Key（可选）"
                                             HorizontalAlignment="Stretch"
                                             PasswordChanged="OnApiKeyPasswordChanged"/>

                                <TextBlock Text="代理" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <ToggleSwitch Header="启用代理"
                                              HorizontalAlignment="Stretch"
                                              IsOn="{x:Bind ViewModel.ProxyEnabled, Mode=TwoWay}"/>
                                <TextBox Header="代理 URL"
                                         PlaceholderText="http://proxy:8080"
                                         HorizontalAlignment="Stretch"
                                         IsEnabled="{x:Bind ViewModel.ProxyEnabled, Mode=OneWay}"
                                         Text="{x:Bind ViewModel.ProxyUrl, Mode=TwoWay}"/>

                                <TextBlock Text="连接" FontWeight="SemiBold" Margin="0,8,0,0"/>
                                <NumberBox x:Name="HeartbeatBox"
                                           Header="心跳间隔（秒）"
                                           HorizontalAlignment="Stretch"
                                           Minimum="5"
                                           Maximum="300"
                                           SpinButtonPlacementMode="Inline"
                                           ValueChanged="OnHeartbeatValueChanged"/>
                                <NumberBox x:Name="TimeoutBox"
                                           Header="连接超时（秒）"
                                           HorizontalAlignment="Stretch"
                                           Minimum="5"
                                           Maximum="60"
                                           SpinButtonPlacementMode="Inline"
                                           ValueChanged="OnTimeoutValueChanged"/>
                            </StackPanel>
                        </Expander>
                    </Border>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="取消"
                                Style="{StaticResource SubtleButtonStyle}"
                                Click="OnCancelClick"/>
                        <Button Content="保存"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="OnSaveClick"
                                IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InverseBooleanConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </controls:ResponsiveSettingsHost.Child>
        </controls:ResponsiveSettingsHost>
    </ScrollViewer>
</views:SettingsPageBase>
