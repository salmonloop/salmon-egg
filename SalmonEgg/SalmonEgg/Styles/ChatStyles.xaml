<ResourceDictionary
    x:Class="SalmonEgg.Styles.ChatStyles"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:converters="using:SalmonEgg.Presentation.Converters">

    <!-- SSOT Common Chat Converters -->
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:InverseBoolConverter x:Key="InverseBoolToVisibilityConverter"/>
    <converters:TimeFormatConverter x:Key="TimeFormatConverter"/>
    <converters:MessageDirectionToAlignmentConverter x:Key="HorizontalAlignmentConverter"/>

    <!-- Shared Style for AI left-reference line -->
    <Style x:Key="IncomingMessageBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="2,0,0,0" />
        <Setter Property="Padding" Value="16,0,0,8" />
    </Style>

    <DataTemplate x:Key="IncomingMessageTemplate" x:DataType="vm:ChatMessageViewModel">
        <Grid Margin="0,8"
              HorizontalAlignment="{x:Bind IsOutgoing, Mode=OneWay, Converter={StaticResource HorizontalAlignmentConverter}}">
            <Border Style="{StaticResource IncomingMessageBorderStyle}">
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="ChatMessageCopyMenu"
                                        Command="{x:Bind CopyTextCommand}"
                                        CommandParameter="{x:Bind TextContent, Mode=OneWay}" />
                    </MenuFlyout>
                </Border.ContextFlyout>
                <StackPanel>
                    <!-- Header Metadata -->
                    <TextBlock Text="{x:Bind Timestamp, Mode=OneWay, Converter={StaticResource TimeFormatConverter}}"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorDisabledBrush}"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,8"/>

                    <Grid x:Name="IncomingTextContentHost"
                          Visibility="{x:Bind HasTextContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock x:Name="IncomingPlainTextBlock"
                                   x:Load="{x:Bind MarkdownPresentation.ShouldRenderPlainText, Mode=OneWay}"
                                   Text="{x:Bind TextContent, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   LineHeight="22"
                                   LineStackingStrategy="BlockLineHeight"
                                   IsTextSelectionEnabled="True"/>

                        <controls:MarkdownTextPresenter x:Name="IncomingMarkdownPresenter"
                                                        x:Load="{x:Bind MarkdownPresentation.ShouldRenderMarkdown, Mode=OneWay}"
                                                        Text="{x:Bind TextContent, Mode=OneWay}"
                                                        ShouldRenderMarkdown="{x:Bind MarkdownPresentation.ShouldRenderMarkdown, Mode=OneWay}"
                                                        RenderFailureSink="{x:Bind}"
                                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                        LinkForeground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                                        CodeBlockBackground="{ThemeResource ControlFillColorSecondaryBrush}"
                                                        CodeBlockForeground="{ThemeResource TextFillColorPrimaryBrush}"
                                                        CodeBlockBorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                        InlineCodeBackground="{ThemeResource ControlFillColorTertiaryBrush}"
                                                        InlineCodeForeground="{ThemeResource TextFillColorPrimaryBrush}"
                                                        InlineCodeBorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                        QuoteBackground="{ThemeResource ControlFillColorSecondaryBrush}"
                                                        QuoteForeground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        QuoteBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                                        TableBorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                        LinkCommand="{x:Bind OpenMarkdownLinkCommand}"
                                                        IsTextSelectionEnabled="{x:Bind MarkdownPresentation.AllowsNativeSelection, Mode=OneWay}"/>

                        <Button x:Name="IncomingMarkdownCopyCodeButton"
                                x:Uid="ChatMarkdownCopyCodeButton"
                                x:Load="{x:Bind MarkdownPresentation.HasCopyableCodeBlock, Mode=OneWay}"
                                Command="{x:Bind CopyTextCommand}"
                                CommandParameter="{x:Bind MarkdownPresentation.CopyableCodeBlockText, Mode=OneWay}"
                                AutomationProperties.AutomationId="ChatMessage.CopyCodeButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Width="32"
                                Height="32"
                                MinWidth="32"
                                Padding="0"
                                Margin="8,0,0,0"
                                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                            <SymbolIcon Symbol="Copy" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="OutgoingMessageTemplate" x:DataType="vm:ChatMessageViewModel">
        <Grid Margin="0,8"
              HorizontalAlignment="{x:Bind IsOutgoing, Mode=OneWay, Converter={StaticResource HorizontalAlignmentConverter}}">
            <Border CornerRadius="12,12,0,12"
                    Padding="16,10"
                    BorderThickness="0">
                <Border.Background>
                    <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.15" />
                </Border.Background>
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="ChatMessageCopyMenu"
                                        Command="{x:Bind CopyTextCommand}"
                                        CommandParameter="{x:Bind TextContent, Mode=OneWay}" />
                    </MenuFlyout>
                </Border.ContextFlyout>
                <StackPanel x:Name="OutgoingMessageContentRoot">
                    <!-- Header Metadata -->
                    <TextBlock Text="{x:Bind Timestamp, Mode=OneWay, Converter={StaticResource TimeFormatConverter}}"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Right"
                               Margin="0,0,0,4"/>

                    <TextBlock x:Name="OutgoingPlainTextBlock"
                               x:Load="{x:Bind HasTextContent, Mode=OneWay}"
                               Text="{x:Bind TextContent, Mode=OneWay}"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               IsTextSelectionEnabled="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="ToolCallMessageTemplate" x:DataType="vm:ChatMessageViewModel">
        <Grid Margin="0,8"
              HorizontalAlignment="{x:Bind IsOutgoing, Mode=OneWay, Converter={StaticResource HorizontalAlignmentConverter}}">
            <Border Style="{StaticResource IncomingMessageBorderStyle}">
                <StackPanel>
                    <!-- Header Metadata -->
                    <TextBlock Text="{x:Bind Timestamp, Mode=OneWay, Converter={StaticResource TimeFormatConverter}}"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorDisabledBrush}"
                               HorizontalAlignment="Left"
                               Margin="0,0,0,8"/>

                    <controls:ToolCallPill x:Name="ToolCallMessagePill"
                                           x:Load="{x:Bind ShouldShowToolCallPill, Mode=OneWay}"
                                           Visibility="{x:Bind ShouldShowToolCallPill, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                           ToolTitle="{x:Bind Title, Mode=OneWay}"
                                           ToolKind="{x:Bind ToolCallKind, Mode=OneWay}"
                                           Status="{x:Bind ToolCallStatus, Mode=OneWay}"
                                           IsInProgress="{x:Bind IsToolCallInProgress, Mode=OneWay}"
                                           IsCompleted="{x:Bind IsToolCallCompleted, Mode=OneWay}"
                                           IsFailed="{x:Bind IsToolCallFailed, Mode=OneWay}"
                                           IsCancelled="{x:Bind IsToolCallCancelled, Mode=OneWay}"
                                           RawPayload="{x:Bind ToolCallJson, Mode=OneWay}"
                                           DetailItems="{x:Bind ToolCallDetailItems, Mode=OneWay}"
                                           PendingPermissionRequest="{x:Bind PendingPermissionRequest, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <converters:MessageTemplateSelector x:Key="MessageTemplateSelector"
                                        IncomingTemplate="{StaticResource IncomingMessageTemplate}"
                                        OutgoingTemplate="{StaticResource OutgoingMessageTemplate}"
                                        ToolCallTemplate="{StaticResource ToolCallMessageTemplate}" />
</ResourceDictionary>
