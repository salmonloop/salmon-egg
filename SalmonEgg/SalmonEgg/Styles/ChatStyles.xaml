<ResourceDictionary
    x:Class="SalmonEgg.Styles.ChatStyles"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:converters="using:SalmonEgg.Presentation.Converters">

    <!-- SSOT Common Chat Converters -->
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:InverseBoolConverter x:Key="InverseBoolToVisibilityConverter"/>
    <converters:TimeFormatConverter x:Key="TimeFormatConverter"/>
    <converters:MessageDirectionToAlignmentConverter x:Key="HorizontalAlignmentConverter"/>

    <DataTemplate x:Key="IncomingMessageTemplate" x:DataType="vm:ChatMessageViewModel">
        <Grid Margin="0,8"
              HorizontalAlignment="{x:Bind IsOutgoing, Mode=OneWay, Converter={StaticResource HorizontalAlignmentConverter}}">
            <Border CornerRadius="12,12,12,0"
                    Padding="16,10"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="ChatMessageCopyMenu"
                                        Click="OnCopyMessageClick"
                                        CommandParameter="{x:Bind TextContent, Mode=OneWay}"
                                        IsEnabled="{x:Bind HasTextContent, Mode=OneWay}" />
                    </MenuFlyout>
                </Border.ContextFlyout>
                <StackPanel>
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               FontWeight="Bold"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Visibility="{x:Bind HasTitle, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                               Margin="0,0,0,4"/>

                    <Grid Visibility="{x:Bind HasTextContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock x:Name="IncomingPlainTextBlock"
                                   x:Load="{x:Bind ShouldRenderPlainText, Mode=OneWay}"
                                   Text="{x:Bind TextContent, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   IsTextSelectionEnabled="True"/>

                        <controls:MarkdownTextPresenter x:Name="IncomingMarkdownPresenter"
                                                        x:Load="{x:Bind ShouldRenderMarkdown, Mode=OneWay}"
                                                        Text="{x:Bind TextContent, Mode=OneWay}"
                                                        MessageViewModel="{x:Bind}"
                                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                        IsTextSelectionEnabled="True"/>
                    </Grid>

                    <controls:ToolCallPill x:Name="IncomingToolCallPill"
                                           x:Load="{x:Bind ShouldShowToolCallPill, Mode=OneWay}"
                                           Margin="0,4,0,0"
                                           ToolTitle="{x:Bind Title, Mode=OneWay}"
                                           ToolKind="{x:Bind ToolCallKind, Mode=OneWay}"
                                           Status="{x:Bind ToolCallStatus, Mode=OneWay}"
                                           IsInProgress="{x:Bind IsToolCallInProgress, Mode=OneWay}"
                                           IsCompleted="{x:Bind IsToolCallCompleted, Mode=OneWay}"
                                           IsFailed="{x:Bind IsToolCallFailed, Mode=OneWay}"
                                           IsCancelled="{x:Bind IsToolCallCancelled, Mode=OneWay}"
                                           RawPayload="{x:Bind ToolCallJson, Mode=OneWay}" />

                    <TextBlock Text="{x:Bind Timestamp, Mode=OneWay, Converter={StaticResource TimeFormatConverter}}"
                               FontSize="10"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Opacity="0.6"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="OutgoingMessageTemplate" x:DataType="vm:ChatMessageViewModel">
        <Grid Margin="0,8"
              HorizontalAlignment="{x:Bind IsOutgoing, Mode=OneWay, Converter={StaticResource HorizontalAlignmentConverter}}">
            <Border CornerRadius="12,12,0,12"
                    Padding="16,10"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="0">
                <Border.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="ChatMessageCopyMenu"
                                        Click="OnCopyMessageClick"
                                        CommandParameter="{x:Bind TextContent, Mode=OneWay}"
                                        IsEnabled="{x:Bind HasTextContent, Mode=OneWay}" />
                    </MenuFlyout>
                </Border.ContextFlyout>
                <StackPanel>
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               FontWeight="Bold"
                               FontSize="12"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Visibility="{x:Bind HasTitle, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                               Margin="0,0,0,4"/>

                    <TextBlock x:Name="OutgoingPlainTextBlock"
                               x:Load="{x:Bind HasTextContent, Mode=OneWay}"
                               Text="{x:Bind TextContent, Mode=OneWay}"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               IsTextSelectionEnabled="True"/>

                    <TextBlock Text="{x:Bind Timestamp, Mode=OneWay, Converter={StaticResource TimeFormatConverter}}"
                               FontSize="10"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Opacity="0.7"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>

    <converters:MessageTemplateSelector x:Key="MessageTemplateSelector"
                                        IncomingTemplate="{StaticResource IncomingMessageTemplate}"
                                        OutgoingTemplate="{StaticResource OutgoingMessageTemplate}" />
</ResourceDictionary>
