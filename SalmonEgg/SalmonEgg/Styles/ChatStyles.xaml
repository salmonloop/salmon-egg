<ResourceDictionary
    x:Class="SalmonEgg.Styles.ChatStyles"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:controls="using:SalmonEgg.Controls"
    xmlns:converters="using:SalmonEgg.Presentation.Converters">

    <!-- SSOT Common Chat Converters -->
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:InverseBoolConverter x:Key="InverseBoolToVisibilityConverter"/>
    <converters:TimeFormatConverter x:Key="TimeFormatConverter"/>
    <converters:MessageDirectionToAlignmentConverter x:Key="HorizontalAlignmentConverter"/>

    <!-- 全局统一聊天气泡模板 -->
    <DataTemplate x:Key="MessageTemplate" x:DataType="vm:ChatMessageViewModel">
        <Grid Margin="0,8"
              HorizontalAlignment="{x:Bind IsOutgoing, Mode=OneWay, Converter={StaticResource HorizontalAlignmentConverter}}">
            
            <!-- AI 接收的消息 (Assistant / Incoming) -->
            <Border Visibility="{x:Bind IsOutgoing, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                    CornerRadius="12,12,12,0"
                    Padding="16,10"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <!-- 消息标题 (如有) -->
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               FontWeight="Bold"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Visibility="{x:Bind HasTitle, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                               Margin="0,0,0,4"/>


                    <!-- 正文 -->
                    <Grid Visibility="{x:Bind HasTextContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="{x:Bind TextContent, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                   Visibility="{x:Bind ShouldRenderPlainText, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <controls:MarkdownTextPresenter Text="{x:Bind TextContent, Mode=OneWay}"
                                                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                        IsTextSelectionEnabled="True"
                                                        Visibility="{x:Bind ShouldRenderMarkdown, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </Grid>

                    <!-- 渐进式揭示的 ToolCall 胶囊 -->
                    <controls:ToolCallPill 
                        Visibility="{x:Bind HasToolCallJson, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,4,0,0"
                        ToolTitle="{x:Bind Title, Mode=OneWay}"
                        ToolKind="{x:Bind ToolCallKind, Mode=OneWay}"
                        Status="{x:Bind ToolCallStatus, Mode=OneWay}"
                        IsInProgress="{x:Bind IsToolCallInProgress, Mode=OneWay}"
                        IsCompleted="{x:Bind IsToolCallCompleted, Mode=OneWay}"
                        IsFailed="{x:Bind IsToolCallFailed, Mode=OneWay}"
                        RawPayload="{x:Bind ToolCallJson, Mode=OneWay}">
                    </controls:ToolCallPill>

                    <!-- 时间戳 -->
                    <TextBlock Text="{x:Bind Timestamp, Mode=OneWay, Converter={StaticResource TimeFormatConverter}}"
                               FontSize="10"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               Opacity="0.6"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- 用户发出的消息 (User / Outgoing) -->
            <Border Visibility="{x:Bind IsOutgoing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                    CornerRadius="12,12,0,12"
                    Padding="16,10"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="0">
                <StackPanel>
                    <!-- 消息标题 (如有) -->
                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                               FontWeight="Bold"
                               FontSize="12"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Visibility="{x:Bind HasTitle, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                               Margin="0,0,0,4"/>

                    <!-- 正文 -->
                    <TextBlock Text="{x:Bind TextContent, Mode=OneWay}"
                               TextWrapping="Wrap"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Visibility="{x:Bind HasTextContent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <!-- 时间戳 -->
                    <TextBlock Text="{x:Bind Timestamp, Mode=OneWay, Converter={StaticResource TimeFormatConverter}}"
                               FontSize="10"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               Opacity="0.7"
                               HorizontalAlignment="Right"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
