<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:skia="http://uno.ui/skia"
    mc:Ignorable="skia">

    <!--
      WinUI's default is `-1,3` (horizontal -1, vertical 3) to account for border pixel snapping.
      On Skia, negative horizontal margins can be clipped more aggressively, producing the "overflow:hidden" look.
      Normalize the horizontal margin to 0 while keeping the vertical spacing identical.
    -->
    <skia:Thickness x:Key="NavigationViewPaneContentGridMargin">0,3</skia:Thickness>

</ResourceDictionary>
