{
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:8080",
      "sslPort": 0
    }
  },
  "profiles": {
    "SalmonEgg (WebAssembly)": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": true,
      "applicationUrl": "http://localhost:5000",
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "SalmonEgg (WebAssembly IIS Express)": {
      "commandName": "IISExpress",
      "launchBrowser": true,
      "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    "SalmonEgg (Desktop)": {
      "commandName": "Project",
      "compatibleTargetFramework": "desktop"
    },
    "SalmonEgg (Desktop WSL2)": {
      "commandName": "WSL2",
      "commandLineArgs": "{ProjectDir}/bin/Debug/net10.0-desktop/SalmonEgg.dll",
      "distributionName": "",
      "compatibleTargetFramework": "desktop"
    },
    "SalmonEgg (MSIX Script Run)": {
      "commandName": "Executable",
      "executablePath": "cmd.exe",
      "commandLineArgs": "/c \"..\\\\..\\\\run.bat msix\"",
      "workingDirectory": "..\\\\.."
    },
    "SalmonEgg (MSIX Script Debug Attach)": {
      "commandName": "Executable",
      "executablePath": "powershell.exe",
      "commandLineArgs": "-NoLogo -NoProfile -ExecutionPolicy Bypass -File \"..\\\\..\\\\.tools\\\\debug-winui3-msix.ps1\" -Configuration Debug",
      "workingDirectory": "..\\\\.."
    },
    "SalmonEgg (Package)": {
      "commandName": "MsixPackage"
    }
  }
}
