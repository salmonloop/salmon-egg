<Application x:Class="SalmonEgg.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Microsoft.UI.Xaml.Controls">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WinUI 3 default control resources (provides TextFillColorPrimaryBrush, etc.) -->
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <!-- 兼容性资源定义：确保在所有平台上都有回退项 -->
            <ResourceDictionary.ThemeDictionaries>
                <!--
                  Card/surface fill that still lets the window backdrop (Mica/DesktopAcrylic/AppBackdropBrush) show through.
                  Using AcrylicBrush keeps the "material" feel instead of a flat solid fill.
                -->
                <ResourceDictionary x:Key="Light">
                    <AcrylicBrush x:Key="LayerOnAcrylicFillColorDefaultBrush"
                                  BackgroundSource="HostBackdrop"
                                  TintColor="#FFFFFF"
                                  TintOpacity="0.55"
                                  FallbackColor="#F7F7F7" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <AcrylicBrush x:Key="LayerOnAcrylicFillColorDefaultBrush"
                                  BackgroundSource="HostBackdrop"
                                  TintColor="#1F1F1F"
                                  TintOpacity="0.45"
                                  FallbackColor="#1F1F1F" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <SolidColorBrush x:Key="AccentBrush" Color="{ThemeResource SystemAccentColor}" />

            <!-- Settings layout (Win11-like): fixed content column on wide windows, fluid on narrow ones -->
            <x:Double x:Key="SettingsContentMaxWidth">780</x:Double>

            <!-- 定义 SubtleButtonStyle 兼容样式 -->
            <!-- 解决 "Couldn't statically resolve resource SubtleButtonStyle" 警告 -->
            <Style x:Key="SubtleButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter x:Name="SubtleStyleContentPresenter"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              Content="{TemplateBinding Content}"
                                              ContentTransitions="{TemplateBinding ContentTransitions}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- App backdrop (Mica-like) fallback usable across platforms -->
            <AcrylicBrush x:Key="AppBackdropBrush"
                          TintColor="{ThemeResource SystemAltHighColor}"
                          TintOpacity="0.85"
                          FallbackColor="{ThemeResource SystemAltHighColor}" />

        </ResourceDictionary>
    </Application.Resources>

</Application>
