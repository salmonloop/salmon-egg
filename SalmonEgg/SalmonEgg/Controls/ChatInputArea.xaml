<UserControl
    x:Class="SalmonEgg.Controls.ChatInputArea"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:startVm="using:SalmonEgg.Presentation.ViewModels.Start"
    xmlns:selectors="using:SalmonEgg.Presentation.Core.ViewModels.Chat.Selectors"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    xmlns:domain="using:SalmonEgg.Domain.Models"
    XYFocusKeyboardNavigation="Enabled"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <x:Double x:Key="ComposerProfileSelectorMinWidth">160</x:Double>
        <x:Double x:Key="ComposerProfileSelectorMaxWidth">320</x:Double>
        <x:Double x:Key="ComposerModeSelectorMinWidth">120</x:Double>
        <x:Double x:Key="ComposerModeSelectorMaxWidth">240</x:Double>
        <!-- Binding is required here because ComboBoxItem containers are generated by the native ComboBox, outside the x:Bind item template. -->
        <Style x:Key="ComposerSelectorComboBoxItemStyle"
               TargetType="ComboBoxItem"
               BasedOn="{StaticResource DefaultComboBoxItemStyle}">
            <Setter Property="IsEnabled" Value="{Binding IsSelectable}" />
        </Style>
    </UserControl.Resources>

    <Border Padding="20,0,20,20"
            Background="Transparent">
        <Grid x:Name="ComposerLayoutRoot"
              MaxWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}"
              XYFocusKeyboardNavigation="Enabled">
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="ComposerWidthStates">
                    <VisualState x:Name="Narrow">
                        <VisualState.Setters>
                            <Setter Target="BottomToolsStrip.ColumnSpacing" Value="0" />
                            <Setter Target="BottomToolsStrip.RowSpacing" Value="8" />
                            <Setter Target="ToolSelectorsPanel.(Grid.Row)" Value="0" />
                            <Setter Target="ToolSelectorsPanel.(Grid.Column)" Value="0" />
                            <Setter Target="ToolSelectorsPanel.Orientation" Value="Vertical" />
                            <Setter Target="ToolSelectorsPanel.HorizontalAlignment" Value="Stretch" />
                            <Setter Target="ActionButtonsPanel.(Grid.Row)" Value="1" />
                            <Setter Target="ActionButtonsPanel.(Grid.Column)" Value="0" />
                            <Setter Target="ActionButtonsPanel.HorizontalAlignment" Value="Right" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Wide">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="640" />
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="BottomToolsStrip.ColumnSpacing" Value="12" />
                            <Setter Target="BottomToolsStrip.RowSpacing" Value="0" />
                            <Setter Target="ToolSelectorsPanel.(Grid.Row)" Value="0" />
                            <Setter Target="ToolSelectorsPanel.(Grid.Column)" Value="0" />
                            <Setter Target="ToolSelectorsPanel.Orientation" Value="Horizontal" />
                            <Setter Target="ToolSelectorsPanel.HorizontalAlignment" Value="Left" />
                            <Setter Target="ActionButtonsPanel.(Grid.Row)" Value="0" />
                            <Setter Target="ActionButtonsPanel.(Grid.Column)" Value="1" />
                            <Setter Target="ActionButtonsPanel.HorizontalAlignment" Value="Right" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                <!-- Slash commands menu -->
                <Border Grid.Row="0"
                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="{x:Bind ViewModel.ShouldShowSlashCommandsUi, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Padding="8" Spacing="6">
                        <ListView x:Name="SlashCommandsList"
                                  ItemsSource="{x:Bind ViewModel.FilteredSlashCommands, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedSlashCommand, Mode=TwoWay}"
                                  SelectionChanged="OnSlashCommandsListSelectionChanged"
                                  SelectionMode="Single"
                                  IsEnabled="{x:Bind ViewModel.AreComposerToolsEnabled, Mode=OneWay}"
                                  MaxHeight="220">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:SlashCommandViewModel">
                                    <Grid ColumnDefinitions="Auto,*" Padding="8,6">
                                        <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"
                                                   FontFamily="Consolas"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Description, Mode=OneWay}"
                                                   TextWrapping="Wrap"
                                                   Opacity="0.7"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock Text="{x:Bind ViewModel.SelectedSlashCommand.InputHint, Mode=OneWay}"
                                   Opacity="0.6"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Transient Notification -->
                <InfoBar Grid.Row="1"
                         Severity="Error"
                         IsClosable="True"
                         IsOpen="{x:Bind ViewModel.ShowTransientNotification, Mode=TwoWay}"
                         Message="{x:Bind ViewModel.TransientNotificationMessage, Mode=OneWay}"
                         Visibility="{x:Bind ViewModel.ShowTransientNotification, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <!-- Unified Input Area -->
                <Border Grid.Row="2"
                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="16,12">
                    <Grid RowDefinitions="*,Auto" RowSpacing="12">
                        <!-- TextBox Area -->
                        <Grid Grid.Row="0">
                            <!-- Ghost completion overlay -->
                            <TextBlock IsHitTestVisible="False"
                                       Margin="{x:Bind InputBox.Padding, Mode=OneWay}"
                                       FontFamily="{x:Bind InputBox.FontFamily, Mode=OneWay}"
                                       FontSize="{x:Bind InputBox.FontSize, Mode=OneWay}"
                                       TextWrapping="Wrap"
                                       Opacity="0.65"
                                       Visibility="{x:Bind ViewModel.ShouldShowSlashCommandsUi, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Run Text="{x:Bind ViewModel.CurrentPrompt, Mode=OneWay}" Foreground="Transparent"/>
                                <Run Text="{x:Bind ViewModel.SlashGhostSuffix, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </TextBlock>

                            <TextBox x:Name="InputBox"
                                     x:Uid="ChatInputBox"
                                     AutomationProperties.AutomationId="{x:Bind InputBoxAutomationId, Mode=OneWay}"
                                     Text="{x:Bind ViewModel.CurrentPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="44"
                                     MaxHeight="240"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     IsEnabled="{x:Bind ViewModel.IsTextInputEnabled, Mode=OneWay}"
                                     KeyboardAcceleratorPlacementMode="Hidden"
                                     KeyDown="OnInputKeyDown">
                                <!-- SSOT Lightweight styling for TextBox focus states -->
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                                    <Thickness x:Key="TextControlBorderThemeThicknessFocused">0</Thickness>
                                    <Thickness x:Key="TextControlBorderThemeThickness">0</Thickness>
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                                </TextBox.Resources>
                                <TextBox.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="Enter" Invoked="OnSendAcceleratorInvoked"/>
                                    <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="OnNewLineAcceleratorInvoked"/>
                                </TextBox.KeyboardAccelerators>
                            </TextBox>
                        </Grid>

                        <!-- Bottom Tools Strip -->
                        <Grid x:Name="BottomToolsStrip"
                              Grid.Row="1"
                              ColumnDefinitions="*,Auto"
                              RowDefinitions="Auto,Auto"
                              XYFocusKeyboardNavigation="Enabled">
                            <StackPanel x:Name="ToolSelectorsPanel"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                <ComboBox x:Name="AgentSelectorHost"
                                          Visibility="{x:Bind SelectorSlots.Agent.IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                          AutomationProperties.AutomationId="{x:Bind AgentSelectorAutomationId, Mode=OneWay}"
                                          MinWidth="{StaticResource ComposerProfileSelectorMinWidth}"
                                          MaxWidth="{StaticResource ComposerProfileSelectorMaxWidth}"
                                          FontSize="12"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="{x:Bind SelectorSlots.Agent.IsEnabled, Mode=OneWay}"
                                          ItemsSource="{x:Bind SelectorSlots.Agent.Items, Mode=OneWay}"
                                          ItemContainerStyle="{StaticResource ComposerSelectorComboBoxItemStyle}"
                                          SelectedItem="{x:Bind SelectorSlots.Agent.SelectedItem, Mode=OneWay}"
                                          SelectionChanged="OnAgentSelectorSelectionChanged"
                                          IsFocusEngagementEnabled="True"
                                          DropDownOpened="OnSelectorDropDownOpened"
                                          DropDownClosed="OnSelectorDropDownClosed">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="selectors:ComposerSelectorItemViewModel">
                                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                       AutomationProperties.AutomationId="{x:Bind AutomationId, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"
                                                       Opacity="{x:Bind IsSelectable, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <ComboBox x:Name="ModeSelectorHost"
                                          x:Uid="ChatModeSelector"
                                          Visibility="{x:Bind SelectorSlots.Mode.IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                          AutomationProperties.AutomationId="{x:Bind ModeSelectorAutomationId, Mode=OneWay}"
                                          MinWidth="{StaticResource ComposerModeSelectorMinWidth}"
                                          MaxWidth="{StaticResource ComposerModeSelectorMaxWidth}"
                                          FontSize="12"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="{x:Bind SelectorSlots.Mode.IsEnabled, Mode=OneWay}"
                                          ItemsSource="{x:Bind SelectorSlots.Mode.Items, Mode=OneWay}"
                                          ItemContainerStyle="{StaticResource ComposerSelectorComboBoxItemStyle}"
                                          SelectedItem="{x:Bind SelectorSlots.Mode.SelectedItem, Mode=OneWay}"
                                          SelectionChanged="OnModeSelectorSelectionChanged"
                                          IsFocusEngagementEnabled="True"
                                          DropDownOpened="OnSelectorDropDownOpened"
                                          DropDownClosed="OnSelectorDropDownClosed">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="selectors:ComposerSelectorItemViewModel">
                                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                       AutomationProperties.AutomationId="{x:Bind AutomationId, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"
                                                       Opacity="{x:Bind IsSelectable, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <ComboBox x:Name="ModelSelectorHost"
                                          x:Uid="ChatModelSelector"
                                          Visibility="{x:Bind SelectorSlots.Model.IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                          AutomationProperties.AutomationId="{x:Bind ModelSelectorAutomationId, Mode=OneWay}"
                                          MinWidth="{StaticResource ComposerProfileSelectorMinWidth}"
                                          MaxWidth="{StaticResource ComposerProfileSelectorMaxWidth}"
                                          FontSize="12"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="{x:Bind SelectorSlots.Model.IsEnabled, Mode=OneWay}"
                                          ItemsSource="{x:Bind SelectorSlots.Model.Items, Mode=OneWay}"
                                          ItemContainerStyle="{StaticResource ComposerSelectorComboBoxItemStyle}"
                                          SelectedItem="{x:Bind SelectorSlots.Model.SelectedItem, Mode=OneWay}"
                                          SelectionChanged="OnModelSelectorSelectionChanged"
                                          IsFocusEngagementEnabled="True"
                                          DropDownOpened="OnSelectorDropDownOpened"
                                          DropDownClosed="OnSelectorDropDownClosed">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="selectors:ComposerSelectorItemViewModel">
                                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                       AutomationProperties.AutomationId="{x:Bind AutomationId, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"
                                                       Opacity="{x:Bind IsSelectable, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <ComboBox x:Name="ProjectSelectorHost"
                                          Visibility="{x:Bind SelectorSlots.Project.IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                          AutomationProperties.AutomationId="{x:Bind ProjectSelectorAutomationId, Mode=OneWay}"
                                          ItemsSource="{x:Bind SelectorSlots.Project.Items, Mode=OneWay}"
                                          ItemContainerStyle="{StaticResource ComposerSelectorComboBoxItemStyle}"
                                          SelectedItem="{x:Bind SelectorSlots.Project.SelectedItem, Mode=OneWay}"
                                          SelectionChanged="OnProjectSelectorSelectionChanged"
                                          MinWidth="{StaticResource ComposerProfileSelectorMinWidth}"
                                          MaxWidth="{StaticResource ComposerProfileSelectorMaxWidth}"
                                          FontSize="12"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="{x:Bind SelectorSlots.Project.IsEnabled, Mode=OneWay}"
                                          IsFocusEngagementEnabled="True"
                                          DropDownOpened="OnSelectorDropDownOpened"
                                          DropDownClosed="OnSelectorDropDownClosed">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="selectors:ComposerSelectorItemViewModel">
                                            <TextBlock Text="{x:Bind DisplayName, Mode=OneWay}"
                                                       AutomationProperties.AutomationId="{x:Bind AutomationId, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxLines="1"
                                                       Opacity="{x:Bind IsSelectable, Mode=OneWay, Converter={StaticResource BoolToOpacityConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel x:Name="ActionButtonsPanel"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button x:Name="VoiceInputStartButton"
                                        x:Uid="VoiceInputStartButton"
                                        Content="&#xE720;"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        Width="44"
                                        Height="44"
                                        MinWidth="44"
                                        MinHeight="44"
                                        Padding="0"
                                        CornerRadius="22"
                                        IsEnabled="{x:Bind ViewModel.CanStartVoiceInput, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.StartVoiceInputCommand}"
                                        Visibility="{x:Bind ViewModel.VoiceInputUiState.ShowStartButton, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <Button x:Name="VoiceInputStopButton"
                                        x:Uid="VoiceInputStopButton"
                                        Content="&#xE71A;"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        Width="44"
                                        Height="44"
                                        MinWidth="44"
                                        MinHeight="44"
                                        Padding="0"
                                        CornerRadius="22"
                                        IsEnabled="{x:Bind ViewModel.CanStopVoiceInput, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.StopVoiceInputCommand}"
                                        Visibility="{x:Bind ViewModel.VoiceInputUiState.ShowStopButton, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <Grid Width="44"
                                      Height="44"
                                      Visibility="{x:Bind ViewModel.VoiceInputUiState.ShowProgressRing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ProgressRing Width="20"
                                                  Height="20"
                                                  IsActive="{x:Bind ViewModel.VoiceInputUiState.ShowProgressRing, Mode=OneWay}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                </Grid>

                                <Button x:Name="SendButton"
                                        x:Uid="SendButton"
                                        Content="&#xE724;"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        Width="44"
                                        Height="44"
                                        MinWidth="44"
                                        MinHeight="44"
                                        Padding="0"
                                        CornerRadius="22"
                                        Style="{StaticResource AccentButtonStyle}"
                                        IsEnabled="{x:Bind IsSubmitButtonEnabled, Mode=OneWay}"
                                        Command="{x:Bind SubmitCommand}"/>

                                <Button x:Name="CancelButton"
                                        x:Uid="CancelButton"
                                        Content="&#xE711;"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        Width="44"
                                        Height="44"
                                        MinWidth="44"
                                        MinHeight="44"
                                        Padding="0"
                                        CornerRadius="22"
                                        IsEnabled="{x:Bind ViewModel.CanCancelPromptUi, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.CancelPromptCommand}"
                                        Visibility="{x:Bind ViewModel.ShowCancelPromptButton, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
