<UserControl
    x:Class="SalmonEgg.Controls.ChatInputArea"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:vm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolConverter x:Key="InverseBoolToVisibilityConverter"/>
        <Thickness x:Key="ChatInputPadding">14,12,14,12</Thickness>
    </UserControl.Resources>

    <Border Padding="20,0,20,20"
            Background="Transparent">
        <Grid MaxWidth="{x:Bind models:UiLayout.ContentMaxWidth, Mode=OneTime}">
            <Grid RowDefinitions="Auto,Auto,Auto">
                <!-- Slash commands menu -->
                <Border Grid.Row="0"
                        Margin="0,0,0,8"
                        Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="{x:Bind ViewModel.ShowSlashCommands, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Padding="8" Spacing="6">
                        <ListView x:Name="SlashCommandsList"
                                  ItemsSource="{x:Bind ViewModel.FilteredSlashCommands, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedSlashCommand, Mode=TwoWay}"
                                  SelectionMode="Single"
                                  MaxHeight="220">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:SlashCommandViewModel">
                                    <Grid ColumnDefinitions="Auto,*" Padding="8,6">
                                        <TextBlock Text="{x:Bind DisplayText, Mode=OneWay}"
                                                   FontFamily="Consolas"
                                                   FontSize="13"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   Margin="0,0,12,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind Description, Mode=OneWay}"
                                                   TextWrapping="Wrap"
                                                   Opacity="0.7"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock Text="{x:Bind ViewModel.SelectedSlashCommand.InputHint, Mode=OneWay}"
                                   Opacity="0.6"
                                   FontSize="12"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="1" Spacing="8">
                    <InfoBar Severity="Error"
                             IsClosable="True"
                             IsOpen="{x:Bind ViewModel.ShowTransientNotification, Mode=TwoWay}"
                             Message="{x:Bind ViewModel.TransientNotificationMessage, Mode=OneWay}"
                             Visibility="{x:Bind ViewModel.ShowTransientNotification, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <Grid Grid.Column="0">
                            <!-- Ghost completion overlay -->
                            <TextBlock IsHitTestVisible="False"
                                       Margin="{StaticResource ChatInputPadding}"
                                       TextWrapping="Wrap"
                                       Opacity="0.65"
                                       Visibility="{x:Bind ViewModel.ShowSlashCommands, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Run Text="{x:Bind ViewModel.CurrentPrompt, Mode=OneWay}" Foreground="Transparent"/>
                                <Run Text="{x:Bind ViewModel.SlashGhostSuffix, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </TextBlock>

                            <TextBox x:Name="InputBox"
                                     PlaceholderText="向 Agent 发送消息... (Enter 发送，Ctrl+Enter 换行)"
                                     Text="{x:Bind ViewModel.CurrentPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="64"
                                     MaxHeight="160"
                                     Padding="{StaticResource ChatInputPadding}"
                                     IsEnabled="{x:Bind ViewModel.IsInputEnabled, Mode=OneWay}"
                                     KeyboardAcceleratorPlacementMode="Hidden"
                                     KeyDown="OnInputKeyDown">
                                <TextBox.KeyboardAccelerators>
                                    <KeyboardAccelerator Key="Enter" Invoked="OnSendAcceleratorInvoked"/>
                                    <KeyboardAccelerator Key="Enter" Modifiers="Control" Invoked="OnNewLineAcceleratorInvoked"/>
                                </TextBox.KeyboardAccelerators>
                            </TextBox>
                        </Grid>

                        <Grid Grid.Column="1" VerticalAlignment="Bottom">
                            <Button Content="&#xE724;"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Background="{ThemeResource AccentBrush}"
                                    Foreground="White"
                                    IsEnabled="{x:Bind CanSubmitUi, Mode=OneWay}"
                                    Click="OnSendClick"
                                    Visibility="{x:Bind ViewModel.IsPromptInFlight, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                            <Button Content="&#xE711;"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Background="{ThemeResource AccentBrush}"
                                    Foreground="White"
                                    Command="{x:Bind ViewModel.CancelPromptCommand}"
                                    Visibility="{x:Bind ViewModel.IsPromptInFlight, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        </Grid>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="0,10,0,0">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <ComboBox Grid.Column="0"
                                  Width="140"
                                  FontSize="12"
                                  MinWidth="0"
                                  ItemsSource="{x:Bind ViewModel.AvailableModes, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedMode, Mode=TwoWay}"
                                  PlaceholderText="选择模式">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:SessionModeViewModel">
                                    <TextBlock Text="{x:Bind ModeName, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <ComboBox Grid.Column="2"
                                  Width="140"
                                  FontSize="12"
                                  MinWidth="0"
                                  Visibility="{x:Bind ViewModel.ShowThinkingLevelSelector, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                  ItemsSource="{x:Bind ViewModel.AvailableThinkingLevels, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedThinkingLevel, Mode=TwoWay}"
                                  PlaceholderText="思考深度">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ThinkingLevelViewModel">
                                    <TextBlock Text="{x:Bind LevelName, Mode=OneWay}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </Grid>

                    <!-- "娶她"功能占位：后续启用时复用同一输入区域组件 -->
                    <Button Content="娶她"
                            FontSize="12"
                            MinHeight="28"
                            Padding="12,0"
                            CornerRadius="8"
                            ToolTipService.ToolTip="娶她功能占位"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Visibility="{x:Bind models:UiFeatures.MarryHerEnabled, Mode=OneTime, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
