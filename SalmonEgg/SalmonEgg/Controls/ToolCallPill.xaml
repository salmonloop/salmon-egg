<UserControl
    x:Class="SalmonEgg.Controls.ToolCallPill"
    x:Name="RootControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:SalmonEgg.Presentation.Converters"
    xmlns:chatVm="using:SalmonEgg.Presentation.ViewModels.Chat"
    xmlns:models="using:SalmonEgg.Presentation.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DataTemplate x:Key="ToolCallDetailItemTemplate" x:DataType="chatVm:ToolCallDetailItem">
            <TextBlock
                Text="{x:Bind DisplayText, Mode=OneWay}"
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                TextWrapping="Wrap"
                IsTextSelectionEnabled="True" />
        </DataTemplate>

    </UserControl.Resources>

    <Border
        x:Name="RootFrame"
        Background="Transparent"
        Padding="0"
        HorizontalAlignment="Left"
        AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="AdaptiveStates">
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.HorizontalAlignment" Value="Stretch" />
                        <Setter Target="RootFrame.MaxWidth" Value="10000" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="MediumState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="640" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.HorizontalAlignment" Value="Left" />
                        <Setter Target="RootFrame.MaxWidth" Value="500" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1008" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.HorizontalAlignment" Value="Left" />
                        <Setter Target="RootFrame.MaxWidth" Value="640" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>

            <VisualStateGroup x:Name="LifecycleStates">
                <VisualState x:Name="CompletedState">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind IsCompleted, Mode=OneWay}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.Opacity" Value="0.65" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="CancelledState">
                    <VisualState.StateTriggers>
                        <StateTrigger IsActive="{x:Bind IsCancelled, Mode=OneWay}" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="RootFrame.Opacity" Value="0.5" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Expander
            x:Name="RootExpander"
            Padding="0"
            IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
            Expanding="RootExpander_Expanding"
            Collapsed="RootExpander_Collapsed"
            AutomationProperties.AutomationId="ToolCallPill.RootButton"
            AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}">
            <Expander.Resources>
                <ResourceDictionary>
                    <ResourceDictionary.ThemeDictionaries>
                        <ResourceDictionary x:Key="Default">
                            <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderHeaderBorderPointerOverBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderHeaderBorderPressedBrush" Color="Transparent" />
                            <Thickness x:Key="ExpanderHeaderBorderThickness">0</Thickness>
                            <Thickness x:Key="ExpanderHeaderPadding">0</Thickness>
                            <x:Double x:Key="ExpanderChevronButtonSize">0</x:Double>
                            <x:Double x:Key="ExpanderChevronGlyphSize">0</x:Double>
                            <Thickness x:Key="ExpanderChevronMargin">0</Thickness>
                            <SolidColorBrush x:Key="ExpanderChevronBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderChevronForeground" Color="Transparent" />
                            <Thickness x:Key="ExpanderChevronBorderThickness">0</Thickness>
                            <SolidColorBrush x:Key="ExpanderContentBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="Transparent" />
                        </ResourceDictionary>
                        <ResourceDictionary x:Key="Dark">
                            <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderHeaderBorderPointerOverBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderHeaderBorderPressedBrush" Color="Transparent" />
                            <Thickness x:Key="ExpanderHeaderBorderThickness">0</Thickness>
                            <Thickness x:Key="ExpanderHeaderPadding">0</Thickness>
                            <x:Double x:Key="ExpanderChevronButtonSize">0</x:Double>
                            <x:Double x:Key="ExpanderChevronGlyphSize">0</x:Double>
                            <Thickness x:Key="ExpanderChevronMargin">0</Thickness>
                            <SolidColorBrush x:Key="ExpanderChevronBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderChevronForeground" Color="Transparent" />
                            <Thickness x:Key="ExpanderChevronBorderThickness">0</Thickness>
                            <SolidColorBrush x:Key="ExpanderContentBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="Transparent" />
                        </ResourceDictionary>
                        <ResourceDictionary x:Key="HighContrast">
                            <StaticResource x:Key="ExpanderHeaderBackground" ResourceKey="SystemColorButtonFaceColorBrush" />
                            <StaticResource x:Key="ExpanderHeaderBorderBrush" ResourceKey="SystemColorButtonTextColorBrush" />
                            <StaticResource x:Key="ExpanderHeaderBorderPointerOverBrush" ResourceKey="SystemColorHighlightColorBrush" />
                            <StaticResource x:Key="ExpanderHeaderBorderPressedBrush" ResourceKey="SystemColorHighlightColorBrush" />
                            <Thickness x:Key="ExpanderHeaderBorderThickness">2</Thickness>
                            <StaticResource x:Key="ExpanderContentBackground" ResourceKey="SystemColorWindowColorBrush" />
                            <StaticResource x:Key="ExpanderContentBorderBrush" ResourceKey="SystemColorWindowTextColorBrush" />
                        </ResourceDictionary>
                    </ResourceDictionary.ThemeDictionaries>
                </ResourceDictionary>
            </Expander.Resources>
            <Expander.Header>
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid
                        Grid.Column="0"
                        Width="20"
                        Height="20"
                        VerticalAlignment="Top"
                        ChildrenTransitions="{x:Bind models:UiMotionController.Current.StatusIconTransitions, Mode=OneWay}">
                        <ProgressRing
                            IsActive="{x:Bind IsInProgress, Mode=OneWay}"
                            Width="14"
                            Height="14"
                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                            Visibility="{x:Bind IsInProgress, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <FontIcon
                            Glyph="&#xE10B;"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                            Visibility="{x:Bind IsCompleted, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <FontIcon
                            Glyph="&#xE10A;"
                            FontSize="12"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Visibility="{x:Bind IsFailed, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <FontIcon
                            Glyph="&#xE711;"
                            FontSize="12"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Visibility="{x:Bind IsCancelled, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </Grid>

                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock
                            x:Name="ToolNameTextBlock"
                            Text="{x:Bind DisplayToolName, Mode=OneWay}"
                            Style="{StaticResource BodyTextBlockStyle}"
                            FontWeight="Normal"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Text="{x:Bind DisplaySummary, Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextTrimming="CharacterEllipsis"
                            MaxLines="1" />
                    </StackPanel>
                </Grid>
            </Expander.Header>

            <Expander.Content>
                <ScrollViewer
                    x:Name="DetailScrollViewer"
                    Margin="28,8,0,0"
                    MaxHeight="{x:Bind PreviewMaxHeight, Mode=OneWay}"
                    VerticalScrollBarVisibility="Hidden"
                    HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Spacing="8">
                    <TextBlock
                        Text="{x:Bind PayloadHeaderText, Mode=OneWay}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Visibility="{x:Bind HasDisplayItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <StackPanel
                        Spacing="8"
                        Visibility="{x:Bind HasPendingPermissionRequest, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock
                            Text="{x:Bind PermissionHeaderText, Mode=OneWay}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                Content="{x:Bind AllowPermissionOption.Name, Mode=OneWay, FallbackValue=Allow}"
                                Tag="{x:Bind AllowPermissionOption, Mode=OneWay}"
                                Click="OnPermissionOptionClick"
                                Style="{StaticResource AccentButtonStyle}"
                                Visibility="{x:Bind HasAllowPermissionOption, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                            <Button
                                Content="{x:Bind RejectPermissionOption.Name, Mode=OneWay, FallbackValue=Reject}"
                                Tag="{x:Bind RejectPermissionOption, Mode=OneWay}"
                                Click="OnPermissionOptionClick"
                                Style="{StaticResource DefaultButtonStyle}"
                                Visibility="{x:Bind HasRejectPermissionOption, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </StackPanel>
                    </StackPanel>

                    <ItemsControl
                        ItemsSource="{x:Bind DetailItems, Mode=OneWay}"
                        ItemTemplate="{StaticResource ToolCallDetailItemTemplate}"
                        Visibility="{x:Bind HasDisplayItems, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </ScrollViewer>
            </Expander.Content>
        </Expander>
    </Border>
</UserControl>
