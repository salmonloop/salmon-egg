<UserControl
    x:Class="SalmonEgg.Controls.XtermTerminalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Background="#0B0D0F">
        <WebView2 x:Name="TerminalWebView"
                  AutomationProperties.Name="{x:Bind RenderedText, Mode=OneWay}"
                  AutomationProperties.AutomationId="BottomPanel.TerminalWebView" />

        <TextBlock x:Name="FallbackText"
                   Text="{x:Bind ContentText, Mode=OneWay}"
                   AutomationProperties.Name="{x:Bind ContentText, Mode=OneWay}"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Margin="16"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextWrapping="Wrap"
                   Visibility="Collapsed" />
    </Grid>
</UserControl>
